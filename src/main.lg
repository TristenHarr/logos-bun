        Let sval be materialize(jsEvalIn(recv, env)).
        Let args be splitArgs2(methodArg(aft)).
        Let subbed be strSubstring(sval, parseInt(jsEvalIn(trim(item 1 of args), env)), parseInt(jsEvalIn(trim(item 2 of args), env))).
        Return resolveMethods(trim(concat(concat(concat(prefix, " "), subbed), rst)), env).
    If lm is equal to " . charCodeAt (":
        Let bef be substringBefore(expr, " . charCodeAt (").
        Let aft be substringAfter(expr, " . charCodeAt (").
        Let rst be methodRest(aft).
        Let recv be recvExpr(concat(bef, "")).
        Let prefix be recvPrefix(concat(bef, "")).
        Let sval be materialize(jsEvalIn(recv, env)).
        Let cc be strCharCodeAt(sval, parseInt(jsEvalIn(trim(methodArg(aft)), env))).
        Return resolveMethods(trim(concat(concat(concat(prefix, " "), toText(cc)), rst)), env).
    If lm is equal to " . split (":
        Let bef be substringBefore(expr, " . split (").
        Let aft be substringAfter(expr, " . split (").
        Let rst be methodRest(aft).
        Let recv be recvExpr(concat(bef, "")).
        Let prefix be recvPrefix(concat(bef, "")).
        Let sval be materialize(jsEvalIn(recv, env)).
        Let sepv be materialize(jsEvalIn(trim(methodArg(aft)), env)).
        Return resolveMethods(trim(concat(concat(concat(prefix, " "), strSplit(sval, sepv)), rst)), env).
    If lm is equal to " . join (":
        Let bef be substringBefore(expr, " . join (").
        Let aft be substringAfter(expr, " . join (").
        Let rst be methodRest(aft).
        Let recv be recvExpr(concat(bef, "")).
        Let prefix be recvPrefix(concat(bef, "")).
        Let aval be jsEvalIn(recv, env).
        Let sepv be materialize(jsEvalIn(trim(methodArg(aft)), env)).
        Return resolveMethods(trim(concat(concat(concat(prefix, " "), arrJoin(aval, sepv)), rst)), env).
    If lm is equal to " . replace (":
        Let bef be substringBefore(expr, " . replace (").
        Let aft be substringAfter(expr, " . replace (").
        Let rst be methodRest(aft).
        Let recv be recvExpr(concat(bef, "")).
        Let prefix be recvPrefix(concat(bef, "")).
        Let sval be materialize(jsEvalIn(recv, env)).
        Let args be splitArgs2(methodArg(aft)).
        Let av be materialize(jsEvalIn(trim(item 1 of args), env)).
        Let bv be materialize(jsEvalIn(trim(item 2 of args), env)).
        Return resolveMethods(trim(concat(concat(concat(prefix, " "), strReplace(sval, av, bv)), rst)), env).
    Return expr.

## To topTernaryQ (toks: Seq of Text, i: Int, depth: Int, g: Text) -> Int:
    If i is greater than length of toks:
        Return 0.
    Let c be item i of toks.
    If depth is equal to 0:
        If c is equal to "?":
            Return i.
    If isOpenGrp(c):
        Return topTernaryQ(toks, i + 1, depth + 1, concat(g, c)).
    If isCloseGrp(c):
        Return topTernaryQ(toks, i + 1, depth - 1, concat(g, c)).
    Return topTernaryQ(toks, i + 1, depth, concat(g, c)).

## To topColon (toks: Seq of Text, i: Int, depth: Int, tern: Int, g: Text) -> Int:
    If i is greater than length of toks:
        Return 0.
    Let c be item i of toks.
    If isOpenGrp(c):
        Return topColon(toks, i + 1, depth + 1, tern, concat(g, c)).
    If isCloseGrp(c):
        Return topColon(toks, i + 1, depth - 1, tern, concat(g, c)).
    If depth is equal to 0:
        If c is equal to "?":
            Return topColon(toks, i + 1, depth, tern + 1, concat(g, c)).
        If c is equal to ":":
            If tern is equal to 0:
                Return i.
            Return topColon(toks, i + 1, depth, tern - 1, concat(g, c)).
    Return topColon(toks, i + 1, depth, tern, concat(g, c)).

## To jsEvalIn (expr: Text, env: Text) -> Text:
    Let te be trim(expr).
    Let tks be split(te, " ").
    Let qIdx be topTernaryQ(tks, 1, 0, "").
    If qIdx is greater than 0:
        Let cIdx be topColon(tks, qIdx + 1, 0, 0, "").
        If cIdx is greater than 0:
            Let cond be joinRange(tks, 1, qIdx - 1, "").
            Let tb be joinRange(tks, qIdx + 1, cIdx - 1, "").
            Let fb be joinRange(tks, cIdx + 1, length of tks, "").
            If boolOf(jsEvalIn(cond, env)):
                Return jsEvalIn(tb, env).
            Return jsEvalIn(fb, env).
    Let subd be substitute(joinNonEmpty(split(resolveCalls(resolveMethods(te, env), env), " "), 1, ""), env).
    Return evalResolved(subd).

## To resolveAccess (expr: Text) -> Text:
    Let once be resolveArrays(resolveObjDot(expr)).
    If once is equal to expr:
        Return once.
    Return resolveAccess(once).

## To evalResolved (expr: Text) -> Text:
    Return jsEvalTernary(resolveTypeof(resolveProps(resolveAccess(resolveObjects(expr))))).

## To envSet (env: Text, name: Text, val: Text) -> Text:
    Return concat(concat(concat(concat(name, "="), val), ";"), env).

## To encFn (s: Text) -> Text:
    Let x1 be replaceAll(s, " ", chr(16)).
    Let x2 be replaceAll(x1, chr(123), chr(17)).
    Let x3 be replaceAll(x2, chr(125), chr(18)).
    Let x4 be replaceAll(x3, "(", chr(19)).
    Let x5 be replaceAll(x4, ")", chr(20)).
    Let x6 be replaceAll(x5, chr(91), chr(21)).
    Let x7 be replaceAll(x6, chr(93), chr(22)).
    Let x8 be replaceAll(x7, ",", chr(23)).
    Return replaceAll(x8, ";", chr(2)).

## To decFn (s: Text) -> Text:
    Let x1 be replaceAll(s, chr(16), " ").
    Let x2 be replaceAll(x1, chr(17), chr(123)).
    Let x3 be replaceAll(x2, chr(18), chr(125)).
    Let x4 be replaceAll(x3, chr(19), "(").
    Let x5 be replaceAll(x4, chr(20), ")").
    Let x6 be replaceAll(x5, chr(21), chr(91)).
    Let x7 be replaceAll(x6, chr(22), chr(93)).
    Let x8 be replaceAll(x7, chr(23), ",").
    Return replaceAll(x8, chr(2), ";").

## To funcValueOf (text: Text) -> Text:
    Let param be trim(substringBefore(substringAfter(text, "("), ")")).
    Let body be trim(braceBody(substringAfter(text, chr(123)), 1, 0, "")).
    Return concat(concat(concat(chr(1), encFn(param)), chr(1)), encFn(body)).

## To defineFn (stmt: Text, env: Text) -> Text:
    Let name be trim(substringBefore(substringAfter(stmt, "function "), "(")).
    Return envSet(env, name, funcValueOf(stmt)).

## To bindAssign (assign: Text, env: Text) -> Text:
    Let name be trim(substringBefore(assign, " = ")).
    Let rhs be trim(substringAfter(assign, " = ")).
    If startsWith(rhs, "function ("):
        Return envSet(env, name, funcValueOf(substitute(rhs, env))).
    Return envSet(env, name, jsEvalIn(rhs, env)).

## To splitTop (s: Text, i: Int, depth: Int, acc: Text) -> Text:
    If i is greater than length of s:
        Return acc.
    Let c be item i of s.
    If c is equal to chr(123):
        Return splitTop(s, i + 1, depth + 1, concat(acc, c)).
    If c is equal to "(":
        Return splitTop(s, i + 1, depth + 1, concat(acc, c)).
    If c is equal to chr(125):
        Return splitTop(s, i + 1, depth - 1, concat(acc, c)).
    If c is equal to ")":
        Return splitTop(s, i + 1, depth - 1, concat(acc, c)).
    If c is equal to ";":
        If depth is equal to 0:
            Return splitTop(s, i + 1, 0, concat(acc, chr(10))).
        Return splitTop(s, i + 1, depth, concat(acc, c)).
    Return splitTop(s, i + 1, depth, concat(acc, c)).

## To execIf (stmt: Text, env: Text) -> Text:
    Let cond be trim(substringBefore(substringAfter(stmt, "("), ")")).
    Let afterBrace be substringAfter(stmt, chr(123)).
    Let thenBlock be braceBody(afterBrace, 1, 0, "").
    If boolOf(jsEvalIn(cond, env)):
        Return runBlockStr(thenBlock, env).
    Let afterClose be trim(substringAfter(substringAfter(afterBrace, thenBlock), chr(125))).
    If startsWith(afterClose, "else"):
        Let afterElse be trim(substringAfter(afterClose, "else")).
        If startsWith(afterElse, "if "):
            Return execIf(afterElse, env).
        Let elseBlock be braceBody(substringAfter(afterElse, chr(123)), 1, 0, "").
        Return runBlockStr(elseBlock, env).
    Return env.

## To braceBody (s: Text, i: Int, depth: Int, acc: Text) -> Text:
    If i is greater than length of s:
        Return acc.
    Let c be item i of s.
    If c is equal to chr(123):
        Return braceBody(s, i + 1, depth + 1, concat(acc, c)).
    If c is equal to chr(125):
        If depth is equal to 0:
            Return acc.
        Return braceBody(s, i + 1, depth - 1, concat(acc, c)).
    Return braceBody(s, i + 1, depth, concat(acc, c)).

## To runBlockStr (body: Text, env: Text) -> Text:
    Return runBlock(split(splitTop(body, 1, 0, ""), chr(10)), 1, env).

## To switchMatchIdx (clauses: Seq of Text, i: Int, disc: Text, env: Text) -> Int:
    If i is greater than length of clauses:
        Return 0.
    Let clause be item i of clauses.
    If startsWith(clause, "case "):
        If jsEvalIn(trim(substringBefore(substringAfter(clause, "case "), ":")), concat(env, "")) is equal to disc:
            Return i.
    Return switchMatchIdx(clauses, i + 1, disc, env).

## To switchDefaultIdx (clauses: Seq of Text, i: Int) -> Int:
    If i is greater than length of clauses:
        Return 0.
    Let c be item i of clauses.
    If startsWith(c, "default "):
        Return i.
    Return switchDefaultIdx(clauses, i + 1).

## To switchFallStmts (clauses: Seq of Text, i: Int, acc: Text) -> Text:
    If i is greater than length of clauses:
        Return acc.
    Let stmts be substringAfter(item i of clauses, ":").
    Return switchFallStmts(clauses, i + 1, concat(concat(acc, " "), stmts)).

## To execSwitch (stmt: Text, env: Text) -> Text:
    Let disc be jsEvalIn(trim(methodArg(substringAfter(stmt, "("))), concat(env, "")).
    Let body be braceBody(substringAfter(stmt, chr(123)), 1, 0, "").
    Let marked be replaceAll(replaceAll(body, "case ", concat(chr(10), "case ")), "default ", concat(chr(10), "default ")).
    Let mi be switchMatchIdx(split(marked, chr(10)), 1, disc, concat(env, "")).
    If mi is greater than 0:
        Return runBlockStr(substringBefore(switchFallStmts(split(marked, chr(10)), mi, ""), "break"), env).
    Let di be switchDefaultIdx(split(marked, chr(10)), 1).
    If di is equal to 0:
        Return env.
    Return runBlockStr(substringBefore(switchFallStmts(split(marked, chr(10)), di, ""), "break"), env).

## To execStmt (stmt: Text, env: Text) -> Text:
    Let s be trim(stmt).
    If startsWith(s, "function "):
        Return defineFn(s, env).
    If startsWith(s, "return"):
        If startsWith(trim(substringAfter(s, "return")), "function ("):
            Return envSet(env, "__ret", funcValueOf(substitute(trim(substringAfter(s, "return")), env))).
        Return envSet(env, "__ret", jsEvalIn(substringAfter(s, "return"), env)).
    If startsWith(s, "while "):
        Return execWhile(s, env).
    If startsWith(s, "for "):
        Return execFor(s, env).
    If startsWith(s, "if "):
        Return execIf(s, env).
    If startsWith(s, "switch "):
        Return execSwitch(s, env).
    If startsWith(s, "let "):
        Return bindAssign(substringAfter(s, "let "), env).
    If startsWith(s, "const "):
        Return bindAssign(substringAfter(s, "const "), env).
    If startsWith(s, "var "):
        Return bindAssign(substringAfter(s, "var "), env).
    If hasSep(s, " . push ("):
        Let pv be trim(substringBefore(s, " . push (")).
        Let pa be balancedArg(substringAfter(s, " . push ("), 1, 0, "").
        Return envSet(env, pv, arrPush(envGet(env, pv), jsEvalIn(trim(pa), env))).
    If hasSep(s, " . pop ("):
        Let ov be trim(substringBefore(s, " . pop (")).
        Return envSet(env, ov, arrPop(envGet(env, ov))).
    If hasSep(s, "++"):
        Return envSet(env, trim(concat(substringBefore(s, "++"), substringAfter(s, "++"))), jsEvalIn(concat(trim(concat(substringBefore(s, "++"), substringAfter(s, "++"))), " + 1"), env)).
    If hasSep(s, "--"):
        Return envSet(env, trim(concat(substringBefore(s, "--"), substringAfter(s, "--"))), jsEvalIn(concat(trim(concat(substringBefore(s, "--"), substringAfter(s, "--"))), " - 1"), env)).
    If hasSep(s, " += "):
        Return envSet(env, trim(substringBefore(s, " += ")), jsEvalIn(concat(concat(trim(substringBefore(s, " += ")), " + "), substringAfter(s, " += ")), env)).
    If hasSep(s, " -= "):
        Return envSet(env, trim(substringBefore(s, " -= ")), jsEvalIn(concat(concat(trim(substringBefore(s, " -= ")), " - "), substringAfter(s, " -= ")), env)).
    If hasSep(s, " *= "):
        Return envSet(env, trim(substringBefore(s, " *= ")), jsEvalIn(concat(concat(trim(substringBefore(s, " *= ")), " * "), substringAfter(s, " *= ")), env)).
    If hasSep(s, " ||= "):
        Return envSet(env, trim(substringBefore(s, " ||= ")), jsEvalIn(concat(concat(trim(substringBefore(s, " ||= ")), " || "), substringAfter(s, " ||= ")), env)).
    If hasSep(s, " &&= "):
        Return envSet(env, trim(substringBefore(s, " &&= ")), jsEvalIn(concat(concat(trim(substringBefore(s, " &&= ")), " && "), substringAfter(s, " &&= ")), env)).
    If hasSep(s, " ??= "):
        Return envSet(env, trim(substringBefore(s, " ??= ")), jsEvalIn(concat(concat(trim(substringBefore(s, " ??= ")), " ?? "), substringAfter(s, " ??= ")), env)).
    If hasSep(s, " = "):
        Return bindAssign(s, env).
    Return env.

## To runBlock (stmts: Seq of Text, i: Int, env: Text) -> Text:
    If i is greater than length of stmts:
        Return env.
    If hasReturn(env):
        Return env.
    Let st be item i of stmts.
    Return runBlock(stmts, i + 1, execStmt(st, env)).

## To execWhile (stmt: Text, env: Text) -> Text:
    If hasReturn(env):
        Return env.
    Let cond be trim(substringBefore(substringAfter(stmt, "("), ")")).
    Let body be braceBody(substringAfter(stmt, chr(123)), 1, 0, "").
    If boolOf(jsEvalIn(cond, env)):
        Return execWhile(stmt, runBlockStr(body, env)).
    Return env.

## To forStmt (stmt: Text, env: Text) -> Text:
    If hasReturn(env):
        Return env.
    Let parts be split(substringBefore(substringAfter(stmt, "("), ")"), ";").
    Let cond be trim(item 2 of parts).
    If boolOf(jsEvalIn(cond, env)):
        Let body be braceBody(substringAfter(stmt, chr(123)), 1, 0, "").
        Let update be trim(item 3 of parts).
        Let afterBody be runBlockStr(body, env).
        Let afterUpdate be execStmt(update, afterBody).
        Return forStmt(stmt, afterUpdate).
    Return env.

## To forOfLoop (els: Seq of Text, i: Int, varName: Text, body: Text, env: Text) -> Text:
    If hasReturn(env):
        Return env.
    If i is greater than length of els:
        Return env.
    Let el be item i of els.
    Let e2 be envSet(env, varName, el).
    Let afterBody be runBlockStr(concat(body, ""), e2).
    Return forOfLoop(els, i + 1, varName, body, afterBody).

## To execForOf (stmt: Text, env: Text) -> Text:
    Let hdr be trim(substringBefore(substringAfter(stmt, "("), ")")).
    Let afterKw be trim(substringAfter(hdr, " ")).
    Let varName be trim(substringBefore(afterKw, " of ")).
    Let arrExpr be trim(substringAfter(afterKw, " of ")).
    Let body be braceBody(substringAfter(stmt, chr(123)), 1, 0, "").
    Return forOfLoop(arrElements(jsEvalIn(arrExpr, env)), 1, varName, body, env).

## To execFor (stmt: Text, env: Text) -> Text:
    Let hdr be substringBefore(substringAfter(stmt, "("), ")").
    If hasSep(hdr, " of "):
        Return execForOf(stmt, env).
    Let init be trim(item 1 of split(hdr, ";")).
    Return forStmt(stmt, execStmt(init, env)).

## To runProgram (stmts: Seq of Text, i: Int, env: Text) -> Text:
    Let stmt be trim(item i of stmts).
    If i is equal to length of stmts:
        Return jsEvalIn(stmt, env).
    Return runProgram(stmts, i + 1, execStmt(stmt, env)).

## To jsRun (program: Text) -> Text:
    Return runProgram(split(splitTop(program, 1, 0, ""), chr(10)), 1, "").

## To nchars (s: Text, i: Int, n: Int) -> Text:
    If i + n is greater than length of s + 1:
        Return "".
    If n is equal to 2:
        Return concat(item i of s, item (i + 1) of s).
    Return concat(concat(item i of s, item (i + 1) of s), item (i + 2) of s).

## To isOp3 (t: Text) -> Bool:
    If t is equal to "===":
        Return true.
    If t is equal to "!==":
        Return true.
    If t is equal to "...":
        Return true.
    If t is equal to "||=":
        Return true.
    If t is equal to "&&=":
        Return true.
    If t is equal to "??=":
        Return true.
    Return false.

## To isOp2 (t: Text) -> Bool:
    If t is equal to "**":
        Return true.
    If t is equal to "??":
        Return true.
    If t is equal to "==":
        Return true.
    If t is equal to "!=":
        Return true.
    If t is equal to "<=":
        Return true.
    If t is equal to ">=":
        Return true.
    If t is equal to "&&":
        Return true.
    If t is equal to "||":
        Return true.
    If t is equal to "+=":
        Return true.
    If t is equal to "-=":
        Return true.
    If t is equal to "*=":
        Return true.
    If t is equal to "++":
        Return true.
    If t is equal to "--":
        Return true.
    If t is equal to "=>":
        Return true.
    Return false.

## To isOp1 (c: Text) -> Bool:
    Let ops be ["+", "-", "*", "%", "<", ">", "(", ")", ";", "?", ":", "=", "!", ",", "."].
    If ops contains c:
        Return true.
    If c is equal to chr(123):
        Return true.
    If c is equal to chr(125):
        Return true.
    If c is equal to chr(91):
        Return true.
    If c is equal to chr(93):
        Return true.
    Return false.

## To spaced (t: Text) -> Text:
    Return concat(concat(" ", t), " ").

## To decodeStr (s: Text) -> Text:
    Let a be replaceAll(s, encSpace (), " ").
    Let b be replaceAll(a, encBrkL (), chr(91)).
    Let c be replaceAll(b, encBrkR (), chr(93)).
    Let d be replaceAll(c, encBraceL (), chr(123)).
    Let e be replaceAll(d, encBraceR (), chr(125)).
    Let f be replaceAll(e, encParenL (), "(").
    Let g be replaceAll(f, encParenR (), ")").
    Let h be replaceAll(g, encQuote (), chr(34)).
    Let ii be replaceAll(h, encBackslash (), chr(92)).
    Return replaceAll(ii, encNewline (), chr(10)).

## To normJs (s: Text, i: Int, inStr: Bool, acc: Text) -> Text:
    If i is greater than length of s:
        Return acc.
    Let c be item i of s.
    If c is equal to chr(34):
        Return normJs(s, i + 1, inStr is equal to false, concat(acc, c)).
    If inStr:
        If c is equal to chr(92):
            If i is less than length of s:
                Let nx be item (i + 1) of s.
                If nx is equal to chr(34):
                    Return normJs(s, i + 2, inStr, concat(acc, encQuote ())).
                If nx is equal to chr(92):
                    Return normJs(s, i + 2, inStr, concat(acc, encBackslash ())).
                If nx is equal to "n":
                    Return normJs(s, i + 2, inStr, concat(acc, encNewline ())).
                If nx is equal to "t":
                    Return normJs(s, i + 2, inStr, concat(acc, chr(9))).
                Return normJs(s, i + 2, inStr, concat(acc, nx)).
            Return normJs(s, i + 1, inStr, concat(acc, c)).
        If c is equal to " ":
            Return normJs(s, i + 1, inStr, concat(acc, encSpace ())).
        If c is equal to chr(91):
            Return normJs(s, i + 1, inStr, concat(acc, encBrkL ())).
        If c is equal to chr(93):
            Return normJs(s, i + 1, inStr, concat(acc, encBrkR ())).
        If c is equal to chr(123):
            Return normJs(s, i + 1, inStr, concat(acc, encBraceL ())).
        If c is equal to chr(125):
            Return normJs(s, i + 1, inStr, concat(acc, encBraceR ())).
        If c is equal to "(":
            Return normJs(s, i + 1, inStr, concat(acc, encParenL ())).
        If c is equal to ")":
            Return normJs(s, i + 1, inStr, concat(acc, encParenR ())).
        Return normJs(s, i + 1, inStr, concat(acc, c)).
    Let op3 be nchars(s, i, 3).
    If isOp3(op3):
        Return normJs(s, i + 3, inStr, concat(acc, spaced(op3))).
    Let op2 be nchars(s, i, 2).
    If isOp2(op2):
        Return normJs(s, i + 2, inStr, concat(acc, spaced(op2))).
    If isOp1(c):
        Return normJs(s, i + 1, inStr, concat(acc, spaced(c))).
    Return normJs(s, i + 1, inStr, concat(acc, c)).

## To joinNonEmpty (parts: Seq of Text, i: Int, acc: Text) -> Text:
    If i is greater than length of parts:
        Return acc.
    Let piece be item i of parts.
    If piece is equal to "":
        Return joinNonEmpty(parts, i + 1, acc).
    If acc is equal to "":
        Return joinNonEmpty(parts, i + 1, piece).
    Return joinNonEmpty(parts, i + 1, concat(concat(acc, " "), piece)).

## To isBodyTerm (c: Text) -> Bool:
    If c is equal to ",":
        Return true.
    If c is equal to ";":
        Return true.
    If c is equal to ")":
        Return true.
    If c is equal to chr(93):
        Return true.
    If c is equal to chr(125):
        Return true.
    Return false.

## To isOpenGrp (c: Text) -> Bool:
    If c is equal to "(":
        Return true.
    If c is equal to chr(91):
        Return true.
    If c is equal to chr(123):
        Return true.
    Return false.

## To isCloseGrp (c: Text) -> Bool:
    If c is equal to ")":
        Return true.
    If c is equal to chr(93):
        Return true.
    If c is equal to chr(125):
        Return true.
    Return false.

## To matchGroupLeft (toks: Seq of Text, i: Int, depth: Int, g: Text) -> Int:
    If i is less than 1:
        Return 1.
    Let c be item i of toks.
    If isCloseGrp(c):
        Return matchGroupLeft(toks, i - 1, depth + 1, concat(g, c)).
    If isOpenGrp(c):
        If depth is equal to 1:
            Return i.
        Return matchGroupLeft(toks, i - 1, depth - 1, concat(g, c)).
    Return matchGroupLeft(toks, i - 1, depth, concat(g, c)).

## To isStopTok (c: Text) -> Bool:
    Let stops be ["+", "-", "*", "/", "%", "<", ">", "=", "!", "?", ":", ",", ";", "(", ".", "==", "!=", "<=", ">=", "&&", "||", "+=", "-=", "*=", "++", "--", "=>", "===", "!==", "&", "|"].
    If stops contains c:
        Return true.
    If c is equal to chr(91):
        Return true.
    If c is equal to chr(123):
        Return true.
    Return false.

## To recvStart (btoks: Seq of Text, i: Int) -> Int:
    If i is less than 1:
        Return 1.
    Let c be item i of btoks.
    If isCloseGrp(c):
        Let openIdx be matchGroupLeft(btoks, i, 0, "").
        If openIdx is less than 2:
            Return openIdx.
        If isStopTok(item (openIdx - 1) of btoks):
            Return openIdx.
        Return recvStart(btoks, openIdx - 1).
    If i is greater than 1:
        If item (i - 1) of btoks is equal to ".":
            Return recvStart(btoks, i - 2).
    Return i.

## To recvExpr (bef: Text) -> Text:
    Let btoks be split(bef, " ").
    Let n be length of btoks.
    Return joinRange(btoks, recvStart(btoks, n), n, "").

## To recvPrefix (bef: Text) -> Text:
    Let btoks be split(bef, " ").
    Let n be length of btoks.
    Return joinRange(btoks, 1, recvStart(btoks, n) - 1, "").

## To matchOpenLeft (toks: Seq of Text, i: Int, depth: Int, g: Text) -> Int:
    If i is less than 1:
        Return 0.
    Let c be item i of toks.
    If c is equal to ")":
        Return matchOpenLeft(toks, i - 1, depth + 1, concat(g, c)).
    If c is equal to "(":
        If depth is equal to 1:
            Return i.
        Return matchOpenLeft(toks, i - 1, depth - 1, concat(g, c)).
    Return matchOpenLeft(toks, i - 1, depth, concat(g, c)).

## To exprBodyEnd (toks: Seq of Text, i: Int, depth: Int, g: Text) -> Int:
    If i is greater than length of toks:
        Return i.
    Let c be item i of toks.
    If depth is equal to 0:
        If isBodyTerm(c):
            Return i.
    If isOpenGrp(c):
        Return exprBodyEnd(toks, i + 1, depth + 1, concat(g, c)).
    If isCloseGrp(c):
        Return exprBodyEnd(toks, i + 1, depth - 1, concat(g, c)).
    Return exprBodyEnd(toks, i + 1, depth, concat(g, c)).

## To blockEndIdx (toks: Seq of Text, i: Int, depth: Int, g: Text) -> Int:
    If i is greater than length of toks:
        Return i.
    Let c be item i of toks.
    If c is equal to chr(123):
        Return blockEndIdx(toks, i + 1, depth + 1, concat(g, c)).
    If c is equal to chr(125):
        If depth is equal to 1:
            Return i.
        Return blockEndIdx(toks, i + 1, depth - 1, concat(g, c)).
    Return blockEndIdx(toks, i + 1, depth, concat(g, c)).

## To fnForm (params: Text, bodyText: Text) -> Text:
    Let head be concat(concat("function ( ", params), " ) ").
    Let withOpen be concat(concat(head, chr(123)), concat(" ", bodyText)).
    Return concat(concat(withOpen, " "), chr(125)).

## To joinFour (pre: Text, fn: Text, rest: Text) -> Text:
    Return concat(concat(concat(concat(pre, " "), fn), " "), rest).

## To buildArrow (preParams: Text, params: Text, right: Text) -> Text:
    Let rt be split(right, " ").
    Let firstR be item 1 of rt.
    Let nR be length of rt.
    If firstR is equal to chr(123):
        Let bEnd be blockEndIdx(rt, 1, 0, "").
        Let bodyInner be joinRange(rt, 2, bEnd - 1, "").
        Let rest be joinRange(rt, bEnd + 1, nR, "").
        Return joinFour(preParams, fnForm(params, bodyInner), rest).
    Let eEnd be exprBodyEnd(rt, 1, 0, "").
    Let body be joinRange(rt, 1, eEnd - 1, "").
    Let rest be joinRange(rt, eEnd, nR, "").
    Return joinFour(preParams, fnForm(params, concat("return ", body)), rest).

## To desugarArrows (expr: Text) -> Text:
    If substringBefore(expr, " => ") is equal to expr:
        Return expr.
    Let left be substringBefore(expr, " => ").
    Let right be substringAfter(expr, " => ").
    Let lt be split(left, " ").
    Let nL be length of lt.
    Let lastL be item nL of lt.
    If lastL is equal to ")":
        Let openIdx be matchOpenLeft(lt, nL, 0, "").
        Return desugarArrows(buildArrow(joinRange(lt, 1, openIdx - 1, ""), joinRange(lt, openIdx + 1, nL - 1, ""), right)).
    Return desugarArrows(buildArrow(joinRange(lt, 1, nL - 1, ""), lastL, right)).

## To desugarTemplates (s: Text, i: Int, mode: Int, depth: Int, acc: Text) -> Text:
    If i is greater than length of s:
        Return acc.
    Let c be item i of s.
    If mode is equal to 0:
        If c is equal to chr(96):
            Return desugarTemplates(s, i + 1, 1, 0, concat(acc, chr(34))).
        Return desugarTemplates(s, i + 1, 0, 0, concat(acc, c)).
    If mode is equal to 1:
        If c is equal to chr(96):
            Return desugarTemplates(s, i + 1, 0, 0, concat(acc, chr(34))).
        If c is equal to "$":
            If i is less than length of s:
                If item (i + 1) of s is equal to chr(123):
                    Return desugarTemplates(s, i + 2, 2, 1, concat(acc, concat(chr(34), " + ("))).
            Return desugarTemplates(s, i + 1, 1, 0, concat(acc, c)).
        Return desugarTemplates(s, i + 1, 1, 0, concat(acc, c)).
    If mode is equal to 3:
        If c is equal to chr(34):
            Return desugarTemplates(s, i + 1, 2, depth, concat(acc, c)).
        Return desugarTemplates(s, i + 1, 3, depth, concat(acc, c)).
    If c is equal to chr(34):
        Return desugarTemplates(s, i + 1, 3, depth, concat(acc, c)).
    If c is equal to chr(123):
        Return desugarTemplates(s, i + 1, 2, depth + 1, concat(acc, c)).
    If c is equal to chr(125):
        If depth is equal to 1:
            Return desugarTemplates(s, i + 1, 1, 0, concat(acc, concat(") + ", chr(34)))).
        Return desugarTemplates(s, i + 1, 2, depth - 1, concat(acc, c)).
    Return desugarTemplates(s, i + 1, 2, depth, concat(acc, c)).

## To normalizeJs (s: Text) -> Text:
    Let templated be desugarTemplates(s, 1, 0, 0, "").
    Let normed be joinNonEmpty(split(normJs(templated, 1, false, ""), " "), 1, "").
    Return joinNonEmpty(split(desugarArrows(normed), " "), 1, "").

## To jsExec (program: Text) -> Text:
    Return decodeStr(materialize(jsRun(normalizeJs(program)))).

## To secondArg (xs: Seq of Text) -> Text:
    If length of xs is greater than 1:
        Return item 2 of xs.
    Return "".

## To isSubcommand (cmd: Text) -> Bool:
    Let subcommands be ["install", "i", "add", "a", "remove", "rm", "update", "upgrade", "outdated", "link", "unlink", "pm", "patch", "publish", "audit", "why", "info", "run", "test", "build", "x", "bunx", "create", "c", "init", "repl", "exec", "lint", "feedback", "completions", "discord"].
    If subcommands contains cmd:
        Return true.
    Return false.

## To startsWithDash (s: Text) -> Bool:
    If length of s is greater than 0:
        If item 1 of s is equal to "-":
            Return true.
    Return false.

## Main
Let arguments be args().
Let cmd be secondArg(arguments).
If cmd is equal to "--version":
    Show "1.4.0".
Otherwise If cmd is equal to "-v":
    Show "1.4.0".
Otherwise If cmd is equal to "--revision":
    Show "1.4.0-canary.1+43ee03834".
Otherwise If cmd is equal to "__semver-compare":
    Let versionA be item 3 of arguments.
    Let versionB be item 4 of arguments.
    Show orderingToInt(compareVersions(versionA, versionB)).
Otherwise If cmd is equal to "__semver-satisfies":
    Let theVersion be item 3 of arguments.
    Let theRange be item 4 of arguments.
    If satisfies(theVersion, theRange):
        Show "true".
    Otherwise:
        Show "false".
Otherwise If cmd is equal to "__semver-max":
    Show maxSatisfying(item 3 of arguments, item 4 of arguments).
Otherwise If cmd is equal to "__semver-min":
    Show minSatisfying(item 3 of arguments, item 4 of arguments).
Otherwise If cmd is equal to "__glob":
    If glob(item 3 of arguments, item 4 of arguments):
        Show "true".
    Otherwise:
        Show "false".
Otherwise If cmd is equal to "__glob-path":
    If globPath(item 3 of arguments, item 4 of arguments):
        Show "true".
    Otherwise:
        Show "false".
Otherwise If cmd is equal to "__toml-get":
    Show tomlGet(item 3 of arguments, item 4 of arguments).
Otherwise If cmd is equal to "__base64":
    Show base64Encode(item 3 of arguments).
Otherwise If cmd is equal to "__base64-decode":
    Show base64Decode(item 3 of arguments).
Otherwise If cmd is equal to "__hex":
    Show toHex(item 3 of arguments).
Otherwise If cmd is equal to "__hex-decode":
    Show fromHex(item 3 of arguments).
Otherwise If cmd is equal to "__js-eval":
    Show decodeStr(materialize(jsEvalTernary(item 3 of arguments))).
Otherwise If cmd is equal to "__js-run":
    Show decodeStr(materialize(jsRun(item 3 of arguments))).
Otherwise If cmd is equal to "__js":
    Show jsExec(item 3 of arguments).
Otherwise If isSubcommand(cmd):
    eputs("error: this command is not yet implemented in logos-bun").
    exitWith(1).
Otherwise If cmd is equal to "":
    Show "Bun is a fast JavaScript runtime, package manager, bundler, and test runner. (1.4.0-canary.1+43ee03834)".
Otherwise If startsWithDash(cmd):
    Show "Bun is a fast JavaScript runtime, package manager, bundler, and test runner. (1.4.0-canary.1+43ee03834)".
Otherwise:
    eputs("error: Script not found " + chr(34) + cmd + chr(34)).
    exitWith(1).
