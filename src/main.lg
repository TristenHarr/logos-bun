        Let prefix be recvPrefix(concat(bef, "")).
        Let aval be jsEvalIn(recv, env).
        Let sepv be joinSep(trim(methodArg(aft)), env).
        Return resolveMethods(trim(concat(concat(concat(prefix, " "), arrJoin(aval, sepv)), rst)), env).
    If lm is equal to " . replace (":
        Let bef be substringBefore(expr, " . replace (").
        Let aft be substringAfter(expr, " . replace (").
        Let rst be methodRest(aft).
        Let recv be recvExpr(concat(bef, "")).
        Let prefix be recvPrefix(concat(bef, "")).
        Let sval be materialize(jsEvalIn(recv, env)).
        Let args be splitArgs2(methodArg(aft)).
        Let araw be jsEvalIn(trim(item 1 of args), env).
        If isRegex(araw):
            If isFnLiteral(trim(item 2 of args)):
                Return resolveMethods(trim(concat(concat(concat(prefix, " "), reReplaceFn(decodeStr(materialize(objGet(concat(araw, ""), "__regex_src"))), decodeStr(concat(sval, "")), fnArgValRaw(trim(item 2 of args), env), materialize(objGet(concat(araw, ""), "__regex_flags")), env)), rst)), env).
            Let rb2 be jsEvalIn(trim(item 2 of args), env).
            If startsWith(rb2, chr(1)):
                Return resolveMethods(trim(concat(concat(concat(prefix, " "), reReplaceFn(decodeStr(materialize(objGet(concat(araw, ""), "__regex_src"))), decodeStr(concat(sval, "")), concat(rb2, ""), materialize(objGet(concat(araw, ""), "__regex_flags")), env)), rst)), env).
            Return resolveMethods(trim(concat(concat(concat(prefix, " "), reReplace(decodeStr(materialize(objGet(concat(araw, ""), "__regex_src"))), decodeStr(concat(sval, "")), decodeStr(materialize(rb2)), materialize(objGet(concat(araw, ""), "__regex_flags")))), rst)), env).
        Return resolveMethods(trim(concat(concat(concat(prefix, " "), strReplace(sval, materialize(araw), materialize(jsEvalIn(trim(item 2 of args), env)))), rst)), env).
    If lm is equal to " . replaceAll (":
        Let bef be substringBefore(expr, " . replaceAll (").
        Let aft be substringAfter(expr, " . replaceAll (").
        Let rst be methodRest(aft).
        Let recv be recvExpr(concat(bef, "")).
        Let prefix be recvPrefix(concat(bef, "")).
        Let sval be materialize(jsEvalIn(recv, env)).
        Let args be splitArgs2(methodArg(aft)).
        Let av be materialize(jsEvalIn(trim(item 1 of args), env)).
        Let bv be materialize(jsEvalIn(trim(item 2 of args), env)).
        Return resolveMethods(trim(concat(concat(concat(prefix, " "), strReplaceAll(sval, av, bv)), rst)), env).
    If lm is equal to " . findIndex (":
        Let bef be substringBefore(expr, " . findIndex (").
        Let aft be substringAfter(expr, " . findIndex (").
        Let argStr be balancedArg(aft, 1, 0, "").
        Let rst be strSliceLoop(aft, (length of argStr) + 2, length of aft, "").
        Let recv be recvExpr(concat(bef, "")).
        Let prefix be recvPrefix(concat(bef, "")).
        Let raw be jsEvalIn(recv, env).
        Let fnval be fnArgValRaw(trim(argStr), env).
        Return resolveMethods(trim(concat(concat(concat(prefix, " "), toText(arrFindIndex(raw, fnval, env))), rst)), env).
    Return expr.

## To topTernaryQ (toks: Seq of Text, i: Int, depth: Int, g: Text) -> Int:
    If i is greater than length of toks:
        Return 0.
    Let c be item i of toks.
    If depth is equal to 0:
        If c is equal to "?":
            Return i.
    If isOpenGrp(c):
        Return topTernaryQ(toks, i + 1, depth + 1, concat(g, c)).
    If isCloseGrp(c):
        Return topTernaryQ(toks, i + 1, depth - 1, concat(g, c)).
    Return topTernaryQ(toks, i + 1, depth, concat(g, c)).

## To topColon (toks: Seq of Text, i: Int, depth: Int, tern: Int, g: Text) -> Int:
    If i is greater than length of toks:
        Return 0.
    Let c be item i of toks.
    If isOpenGrp(c):
        Return topColon(toks, i + 1, depth + 1, tern, concat(g, c)).
    If isCloseGrp(c):
        Return topColon(toks, i + 1, depth - 1, tern, concat(g, c)).
    If depth is equal to 0:
        If c is equal to "?":
            Return topColon(toks, i + 1, depth, tern + 1, concat(g, c)).
        If c is equal to ":":
            If tern is equal to 0:
                Return i.
            Return topColon(toks, i + 1, depth, tern - 1, concat(g, c)).
    Return topColon(toks, i + 1, depth, tern, concat(g, c)).

## To encodeRaw (s: Text) -> Text:
    Let a be replaceAll(s, " ", encSpace ()).
    Let b be replaceAll(a, chr(91), encBrkL ()).
    Let c be replaceAll(b, chr(93), encBrkR ()).
    Let d be replaceAll(c, chr(123), encBraceL ()).
    Let e be replaceAll(d, chr(125), encBraceR ()).
    Let f be replaceAll(e, "(", encParenL ()).
    Return replaceAll(f, ")", encParenR ()).

## To firstIdent (s: Text) -> Text:
    Return substringBefore(concat(s, " "), " ").

## To resolveProcessEnv (expr: Text) -> Text:
    If substringBefore(expr, "process . env . ") is equal to expr:
        Return expr.
    Let bef be substringBefore(expr, "process . env . ").
    Let aft be substringAfter(expr, "process . env . ").
    Let key be firstIdent(concat(aft, "")).
    Let rest be strSliceLoop(concat(aft, ""), (length of key) + 1, length of aft, "").
    Return resolveProcessEnv(concat(concat(bef, concat(tagStr (), encodeRaw(getEnv(key)))), rest)).

# `a instanceof C`: evaluate the left operand to its heap ref, read its class-ancestry chain
# from the class-tag table, and test membership of C. A non-object left operand has no chain, so
# yields false. Only a top-level (paren-depth 0) `instanceof` is processed — a parenthesized one
# is handled when the paren interior is evaluated. Runs before substitution so C stays a bare token.
## To topInstanceofIdx (toks: Seq of Text, i: Int, depth: Int, g: Text) -> Int:
    If i is greater than length of toks:
        Return 0.
    Let c be item i of toks.
    If isOpenGrp(c):
        Return topInstanceofIdx(toks, i + 1, depth + 1, concat(g, c)).
    If isCloseGrp(c):
        Return topInstanceofIdx(toks, i + 1, depth - 1, concat(g, c)).
    If c is equal to "instanceof":
        If depth is equal to 0:
            Return i.
    Return topInstanceofIdx(toks, i + 1, depth, concat(g, c)).

## To resolveInstanceof (expr: Text, env: Text) -> Text:
    Let toks be split(expr, " ").
    Let idx be topInstanceofIdx(toks, 1, 0, "").
    If idx is equal to 0:
        Return expr.
    Let lhs be joinRange(toks, 1, idx - 1, "").
    Let cname be item (idx + 1) of toks.
    Let restR be joinRange(toks, idx + 2, length of toks, "").
    Let inst be jsEvalIn(lhs, concat(env, "")).
    Let isInst be split(classTagGet(refId(concat(inst, ""))), ",") contains cname.
    Return resolveInstanceof(trim(concat(concat(cmpResult(isInst), " "), restR)), env).

## To jsEvalIn (expr: Text, env: Text) -> Text:
    Let te be trim(resolveInstanceof(resolveProcessEnv(expr), env)).
    If startsWith(te, "await "):
        Return awaitValue(jsEvalIn(substringAfter(te, "await "), env)).
    Let tks be split(te, " ").
    Let qIdx be topTernaryQ(tks, 1, 0, "").
    If qIdx is greater than 0:
        Let cIdx be topColon(tks, qIdx + 1, 0, 0, "").
        If cIdx is greater than 0:
            Let cond be joinRange(tks, 1, qIdx - 1, "").
            Let tb be joinRange(tks, qIdx + 1, cIdx - 1, "").
            Let fb be joinRange(tks, cIdx + 1, length of tks, "").
            If boolOf(jsEvalIn(cond, env)):
                Return jsEvalIn(tb, env).
            Return jsEvalIn(fb, env).
    Let subd be substitute(joinNonEmpty(split(resolveCalls(resolveMethods(te, env), env), " "), 1, ""), env).
    Return evalResolved(subd).

# Optional chaining `a ?. b`: if the receiver is null/undefined the whole access is
# undefined (and `undefined ?. x` stays undefined, short-circuiting the rest of the
# chain); otherwise it behaves like `.` — so we rewrite `?.` to `.` and let the normal
# member/index resolution take over on the next fixpoint pass.
## To resolveOptChain (expr: Text) -> Text:
    If substringBefore(expr, " ?. ") is equal to expr:
        Return expr.
    Let lhs be substringBefore(expr, " ?. ").
    Let tail be substringAfter(expr, " ?. ").
    Let lhsToks be split(lhs, " ").
    Let recv be item (length of lhsToks) of lhsToks.
    If isNullish(recv):
        Let tailToks be split(tail, " ").
        Let newPrefix be joinRange(lhsToks, 1, (length of lhsToks) - 1, "").
        Let restToks be joinRange(tailToks, 2, length of tailToks, "").
        Return trim(concat(concat(concat(newPrefix, " "), "undefined"), restToks)).
    Return concat(concat(lhs, " . "), tail).

## To resolveAccess (expr: Text) -> Text:
    Let once be resolveOptChain(resolveArrays(resolveObjDot(expr))).
    If once is equal to expr:
        Return once.
    Return resolveAccess(once).

## To evalResolved (expr: Text) -> Text:
    Return jsEvalTernary(resolveTypeof(resolveProps(resolveAccess(resolveObjects(expr))))).

## To envSet (env: Text, name: Text, val: Text) -> Text:
    Return concat(concat(concat(concat(name, "="), val), ";"), env).

## To encFn (s: Text) -> Text:
    Let x1 be replaceAll(s, " ", chr(16)).
    Let x2 be replaceAll(x1, chr(123), chr(17)).
    Let x3 be replaceAll(x2, chr(125), chr(18)).
    Let x4 be replaceAll(x3, "(", chr(19)).
    Let x5 be replaceAll(x4, ")", chr(20)).
    Let x6 be replaceAll(x5, chr(91), chr(21)).
    Let x7 be replaceAll(x6, chr(93), chr(22)).
    Let x8 be replaceAll(x7, ",", chr(23)).
    Return replaceAll(x8, ";", chr(2)).

## To decFn (s: Text) -> Text:
    Let x1 be replaceAll(s, chr(16), " ").
    Let x2 be replaceAll(x1, chr(17), chr(123)).
    Let x3 be replaceAll(x2, chr(18), chr(125)).
    Let x4 be replaceAll(x3, chr(19), "(").
    Let x5 be replaceAll(x4, chr(20), ")").
    Let x6 be replaceAll(x5, chr(21), chr(91)).
    Let x7 be replaceAll(x6, chr(22), chr(93)).
    Let x8 be replaceAll(x7, chr(23), ",").
    Return replaceAll(x8, chr(2), ";").

# A function LITERAL in value position: anonymous `function ( … )` or a named function EXPRESSION
# `function name ( … )`. funcValueOf already keys off the first `(`, so a name is transparent to it —
# this predicate just lets the name past the guards that previously only recognized `function (`.
## To isFnLiteral (s: Text) -> Bool:
    If startsWith(s, "function (") is equal to true:
        Return true.
    If startsWith(s, "function ") is equal to false:
        Return false.
    Let toks be split(concat(s, ""), " ").
    If length of toks is greater than 2:
        If item 3 of toks is equal to "(":
            Return true.
    Return false.

## To funcValueOf (text: Text) -> Text:
    Let afterOpen be substringAfter(text, "(").
    Let param be trim(substringBefore(concat(afterOpen, ""), ")")).
    Let afterParams be substringAfter(concat(afterOpen, ""), ")").
    Let body be trim(braceBody(substringAfter(afterParams, chr(123)), 1, 0, "")).
    Return concat(concat(concat(chr(1), encFn(param)), chr(1)), encFn(body)).

## To defineFn (stmt: Text, env: Text) -> Text:
    Let name be trim(substringBefore(substringAfter(stmt, "function "), "(")).
    Return envSet(env, name, funcValueOf(stmt)).

## To defaultOr (cur: Text, defExpr: Text, env: Text) -> Text:
    If cur is equal to "undefined":
        Return jsEvalIn(defExpr, env).
    Return cur.

## To patFieldSplit (s: Text, i: Int, depth: Int, q: Int, g: Text) -> Text:
    If i is greater than length of s:
        Return g.
    Let c be item i of s.
    If c is equal to chr(34):
        If q is equal to 0:
            Return patFieldSplit(s, i + 1, depth, 1, concat(g, c)).
        Return patFieldSplit(s, i + 1, depth, 0, concat(g, c)).
    If q is equal to 1:
        Return patFieldSplit(s, i + 1, depth, 1, concat(g, c)).
    If c is equal to chr(123):
        Return patFieldSplit(s, i + 1, depth + 1, q, concat(g, c)).
    If c is equal to chr(91):
        Return patFieldSplit(s, i + 1, depth + 1, q, concat(g, c)).
    If c is equal to "(":
        Return patFieldSplit(s, i + 1, depth + 1, q, concat(g, c)).
    If c is equal to chr(125):
        Return patFieldSplit(s, i + 1, depth - 1, q, concat(g, c)).
    If c is equal to chr(93):
        Return patFieldSplit(s, i + 1, depth - 1, q, concat(g, c)).
    If c is equal to ")":
        Return patFieldSplit(s, i + 1, depth - 1, q, concat(g, c)).
    If c is equal to ",":
        If depth is equal to 0:
            Return patFieldSplit(s, i + 1, 0, q, concat(g, chr(10))).
        Return patFieldSplit(s, i + 1, depth, q, concat(g, c)).
    Return patFieldSplit(s, i + 1, depth, q, concat(g, c)).

## To patFields (inner: Text) -> Seq of Text:
    Return split(patFieldSplit(inner, 1, 0, 0, ""), chr(10)).

## To topEqIdx (s: Text, i: Int, depth: Int) -> Int:
    If i is greater than length of s:
        Return 0.
    Let c be item i of s.
    If c is equal to chr(123):
        Return topEqIdx(s, i + 1, depth + 1).
    If c is equal to chr(91):
        Return topEqIdx(s, i + 1, depth + 1).
    If c is equal to "(":
        Return topEqIdx(s, i + 1, depth + 1).
    If c is equal to chr(125):
        Return topEqIdx(s, i + 1, depth - 1).
    If c is equal to chr(93):
        Return topEqIdx(s, i + 1, depth - 1).
    If c is equal to ")":
        Return topEqIdx(s, i + 1, depth - 1).
    If c is equal to "=":
        If depth is equal to 0:
            Return i.
    Return topEqIdx(s, i + 1, depth).

## To destructObjLoop (fields: Seq of Text, i: Int, objval: Text, env: Text) -> Text:
    If i is greater than length of fields:
        Return env.
    Let field be trim(item i of fields).
    If field is equal to "":
        Return destructObjLoop(fields, i + 1, objval, env).
    If hasSep(field, " = "):
        Let lhsPart be trim(substringBefore(field, " = ")).
        Let defExpr be trim(substringAfter(field, " = ")).
        If hasSep(lhsPart, ":"):
            Let dk be trim(substringBefore(lhsPart, ":")).
            Let dvn be trim(substringAfter(lhsPart, ":")).
            Let dval be defaultOr(objGet(concat(objval, ""), dk), defExpr, concat(env, "")).
            Return destructObjLoop(fields, i + 1, concat(objval, ""), envSet(env, dvn, dval)).
        Let bval be defaultOr(objGet(concat(objval, ""), concat(lhsPart, "")), defExpr, concat(env, "")).
        Return destructObjLoop(fields, i + 1, concat(objval, ""), envSet(env, lhsPart, bval)).
    If hasSep(field, ":"):
        Let k be trim(substringBefore(field, ":")).
        Let vn be trim(substringAfter(field, ":")).
        Return destructObjLoop(fields, i + 1, concat(objval, ""), envSet(env, vn, objGet(concat(objval, ""), k))).
    Return destructObjLoop(fields, i + 1, concat(objval, ""), envSet(env, concat(field, ""), objGet(concat(objval, ""), field))).

## To destructArrLoop (fields: Seq of Text, i: Int, arrval: Text, env: Text) -> Text:
    If i is greater than length of fields:
        Return env.
    Let field be trim(item i of fields).
    If field is equal to "":
        Return destructArrLoop(fields, i + 1, arrval, env).
    If startsWith(field, "..."):
        Let rv be trim(substringAfter(field, "...")).
        Return destructArrLoop(fields, i + 1, concat(arrval, ""), envSet(env, rv, arrSlice(concat(arrval, ""), i - 1, 1000000))).
    If hasSep(field, " = "):
        Let avn be trim(substringBefore(field, " = ")).
        Let adef be trim(substringAfter(field, " = ")).
        Let aval be defaultOr(arrGet(concat(arrval, ""), i - 1), adef, concat(env, "")).
        Return destructArrLoop(fields, i + 1, concat(arrval, ""), envSet(env, avn, aval)).
    Return destructArrLoop(fields, i + 1, concat(arrval, ""), envSet(env, concat(field, ""), arrGet(concat(arrval, ""), i - 1))).

## To destructureObj (pattern: Text, objval: Text, env: Text) -> Text:
    Let inner be trim(substringBefore(substringAfter(pattern, chr(123)), chr(125))).
    Return destructObjLoop(patFields(inner), 1, objval, env).

## To destructureArr (pattern: Text, arrval: Text, env: Text) -> Text:
    Let inner be trim(substringBefore(substringAfter(pattern, chr(91)), chr(93))).
    Return destructArrLoop(patFields(inner), 1, arrval, env).

## To bindOne (assign: Text, env: Text) -> Text:
    Let trimmed be trim(assign).
    If startsWith(trimmed, chr(123)):
        Let eqAt be topEqIdx(concat(trimmed, ""), 1, 0).
        Let pat be trim(strSliceLoop(concat(trimmed, ""), 1, eqAt - 1, "")).
        Let prhs be trim(strSliceLoop(concat(trimmed, ""), eqAt + 1, length of trimmed, "")).
        Return destructureObj(pat, jsEvalIn(prhs, env), env).
    If startsWith(trimmed, chr(91)):
        Let eqAt2 be topEqIdx(concat(trimmed, ""), 1, 0).
        Let pat2 be trim(strSliceLoop(concat(trimmed, ""), 1, eqAt2 - 1, "")).
        Let prhs2 be trim(strSliceLoop(concat(trimmed, ""), eqAt2 + 1, length of trimmed, "")).
        Return destructureArr(pat2, jsEvalIn(prhs2, env), env).
    If substringBefore(assign, " = ") is equal to assign:
        Return envSet(env, trim(assign), "undefined").
    Let name be trim(substringBefore(assign, " = ")).
    Let rhs be trim(substringAfter(assign, " = ")).
    If isFnLiteral(rhs):
        Return envSet(env, name, funcValueOf(substitute(rhs, env))).
    Return envSet(env, name, jsEvalIn(rhs, env)).

## To bindDeclList (decls: Seq of Text, i: Int, env: Text) -> Text:
    If i is greater than length of decls:
        Return env.
    Let e2 be bindOne(trim(item i of decls), env).
    Return bindDeclList(decls, i + 1, e2).

## To bindAssign (assign: Text, env: Text) -> Text:
    Let decls be patFields(concat(assign, "")).
    If length of decls is greater than 1:
        Return bindDeclList(decls, 1, env).
    Return bindOne(assign, env).

# After a `}` closes to top level (depth 0), a new statement often follows with NO `;` between them —
# `function f(){}g()`, `for(…){…}return x`, `if(…){…}foo()` (minified/packed code, or just terse
# source). splitContinues reports whether what follows the `}` is instead a CONTINUATION of the same
# statement — `else`/`catch`/`finally`/`while` (do-while), an operator / `.` / `(` / `[` using the
# value, a `;` (which already splits), or end of input — in which case no boundary is inserted. Only
# when a genuine new statement begins (an identifier/keyword that isn't a continuation) is a newline
# spliced in. Runs on normalized (space-joined) source, so only spaces are skipped.
## To splitSkipSpaces (s: Text, j: Int) -> Int:
    If j is greater than length of s:
        Return j.
    If item j of s is equal to " ":
        Return splitSkipSpaces(s, j + 1).
    Return j.

## To splitWordIs (s: Text, k: Int, w: Text) -> Bool:
    Let m be length of w.
    If k + m - 1 is greater than length of s:
        Return false.
    If strSliceLoop(s, k, k + m - 1, "") is not equal to w:
        Return false.
    If k + m is greater than length of s:
        Return true.
    Return rxIsIdentChar(item (k + m) of s) is equal to false.

## To splitContinues (s: Text, j: Int) -> Bool:
    Let k be splitSkipSpaces(s, j).
    If k is greater than length of s:
        Return true.
    Let c be item k of s.
    Let conts be [";", ")", ",", ".", "+", "-", "*", "/", "%", "<", ">", "=", "&", "|", "?", ":", "(", "!", chr(91), chr(93), chr(125)].
    If conts contains c:
        Return true.
    If splitWordIs(s, k, "else"):
        Return true.
    If splitWordIs(s, k, "catch"):
        Return true.
    If splitWordIs(s, k, "finally"):
        Return true.
    If splitWordIs(s, k, "while"):
        Return true.
    Return false.

## To splitTop (s: Text, i: Int, depth: Int, acc: Text) -> Text:
    If i is greater than length of s:
        Return acc.
    Let c be item i of s.
    If c is equal to chr(123):
        Return splitTop(s, i + 1, depth + 1, concat(acc, c)).
    If c is equal to "(":
        Return splitTop(s, i + 1, depth + 1, concat(acc, c)).
    If c is equal to chr(125):
        If depth is equal to 1:
            If splitContinues(s, i + 1):
                Return splitTop(s, i + 1, 0, concat(acc, c)).
            Return splitTop(s, i + 1, 0, concat(concat(acc, c), chr(10))).
        Return splitTop(s, i + 1, depth - 1, concat(acc, c)).
    If c is equal to ")":
        Return splitTop(s, i + 1, depth - 1, concat(acc, c)).
    If c is equal to ";":
        If depth is equal to 0:
            If splitWordIs(s, splitSkipSpaces(s, i + 1), "else"):
                Return splitTop(s, i + 1, 0, concat(acc, c)).
            Return splitTop(s, i + 1, 0, concat(acc, chr(10))).
        Return splitTop(s, i + 1, depth, concat(acc, c)).
    Return splitTop(s, i + 1, depth, concat(acc, c)).

## To tryCatchRun (afterTry: Text, cparam: Text, catchBlock: Text) -> Text:
    If hasThrow(afterTry):
        Let thrown be envGet(concat(afterTry, ""), "__throw").
        Return runBlockStr(catchBlock, envSet(envSet(afterTry, "__throw", ""), cparam, thrown)).
    Return afterTry.

# A `finally` block runs after the try (and catch) whether or not an exception occurred, then the
# original control-flow signal (a pending `return`/`throw` from the try/catch) resumes — unless the
# finally itself returns or throws, which supersedes it (JS semantics). Halt flags are cleared so the
# finally body actually executes, then restored.
## To runFinally (finBlock: Text, incoming: Text) -> Text:
    Let savedRet be envGet(concat(incoming, ""), "__ret").
    Let savedThrow be envGet(concat(incoming, ""), "__throw").
    Let cleared be envSet(envSet(concat(incoming, ""), "__ret", ""), "__throw", "").
    Let afterFin be runBlockStr(finBlock, cleared).
    If envGet(concat(afterFin, ""), "__ret") is not equal to "":
        Return afterFin.
    If envGet(concat(afterFin, ""), "__throw") is not equal to "":
        Return afterFin.
    Return envSet(envSet(afterFin, "__ret", savedRet), "__throw", savedThrow).

## To execTry (stmt: Text, env: Text) -> Text:
    Let afterTryBrace be substringAfter(stmt, chr(123)).
    Let tryBlock be braceBody(concat(afterTryBrace, ""), 1, 0, "").
    Let rest1 be trim(substringAfter(substringAfter(afterTryBrace, tryBlock), chr(125))).
    Let afterTry be runBlockStr(tryBlock, env).
    If startsWith(rest1, "catch"):
        Let cparam be trim(substringBefore(substringAfter(rest1, "("), ")")).
        Let afterCP be substringAfter(rest1, ")").
        Let catchBlock be braceBody(substringAfter(afterCP, chr(123)), 1, 0, "").
        Let afterCatch be tryCatchRun(afterTry, cparam, catchBlock).
        Let restC be trim(substringAfter(substringAfter(afterCP, catchBlock), chr(125))).
        If startsWith(restC, "finally"):
            Return runFinally(braceBody(substringAfter(restC, chr(123)), 1, 0, ""), afterCatch).
        Return afterCatch.
    If startsWith(rest1, "finally"):
        Return runFinally(braceBody(substringAfter(rest1, chr(123)), 1, 0, ""), afterTry).
    Return afterTry.

# if-statement, braced OR braceless. The condition is extracted with balancedArg so nested parens
# (`if (f(x))`) survive; what follows is a `{ … }` block or, for a braceless if, a single statement
# (`if (c) break;` / `if (c) return x;`) that runs via execStmt. An inline `else` (no `;` before it)
# is honored in both forms.
## To execIf (stmt: Text, env: Text) -> Text:
    Let inner be substringAfter(stmt, "(").
    Let condRaw be balancedArg(concat(inner, ""), 1, 0, "").
    Let cond be trim(condRaw).
    Let afterCond be trim(strSliceLoop(inner, (length of condRaw) + 2, length of inner, "")).
    If startsWith(afterCond, chr(123)):
        Let thenBlock be braceBody(substringAfter(afterCond, chr(123)), 1, 0, "").
        If boolOf(jsEvalIn(cond, env)):
            Return runBlockStr(thenBlock, env).
        Let afterClose be trim(substringAfter(substringAfter(afterCond, chr(123)), chr(125))).
        If startsWith(afterClose, "else"):
            Let afterElse be trim(substringAfter(afterClose, "else")).
            If startsWith(afterElse, "if "):
                Return execIf(afterElse, env).
            Let elseBlock be braceBody(substringAfter(afterElse, chr(123)), 1, 0, "").
            Return runBlockStr(elseBlock, env).
        Return env.
    Let consequent be trim(substringBefore(afterCond, " else ")).
    If boolOf(jsEvalIn(cond, env)):
        Return execStmt(consequent, env).
    If substringBefore(afterCond, " else ") is not equal to afterCond:
        Let elsePart be trim(substringAfter(afterCond, " else ")).
        If startsWith(elsePart, "if "):
            Return execIf(elsePart, env).
        Return execStmt(elsePart, env).
    Return env.

## To braceBody (s: Text, i: Int, depth: Int, acc: Text) -> Text:
    If i is greater than length of s:
        Return acc.
    Let c be item i of s.
    If c is equal to chr(123):
        Return braceBody(s, i + 1, depth + 1, concat(acc, c)).
    If c is equal to chr(125):
        If depth is equal to 0:
            Return acc.
        Return braceBody(s, i + 1, depth - 1, concat(acc, c)).
    Return braceBody(s, i + 1, depth, concat(acc, c)).

## To runBlockStr (body: Text, env: Text) -> Text:
    Return runBlock(split(splitTop(body, 1, 0, ""), chr(10)), 1, env).

## To switchMatchIdx (clauses: Seq of Text, i: Int, disc: Text, env: Text) -> Int:
    If i is greater than length of clauses:
        Return 0.
    Let clause be item i of clauses.
    If startsWith(clause, "case "):
        If jsEvalIn(trim(substringBefore(substringAfter(clause, "case "), ":")), concat(env, "")) is equal to disc:
            Return i.
    Return switchMatchIdx(clauses, i + 1, disc, env).

## To switchDefaultIdx (clauses: Seq of Text, i: Int) -> Int:
    If i is greater than length of clauses:
        Return 0.
    Let c be item i of clauses.
    If startsWith(c, "default "):
        Return i.
    Return switchDefaultIdx(clauses, i + 1).

## To switchFallStmts (clauses: Seq of Text, i: Int, acc: Text) -> Text:
    If i is greater than length of clauses:
        Return acc.
    Let stmts be substringAfter(item i of clauses, ":").
    Return switchFallStmts(clauses, i + 1, concat(concat(acc, " "), stmts)).

## To execSwitch (stmt: Text, env: Text) -> Text:
    Let disc be jsEvalIn(trim(methodArg(substringAfter(stmt, "("))), concat(env, "")).
    Let body be braceBody(substringAfter(stmt, chr(123)), 1, 0, "").
    Let marked be replaceAll(replaceAll(body, "case ", concat(chr(10), "case ")), "default ", concat(chr(10), "default ")).
    Let mi be switchMatchIdx(split(marked, chr(10)), 1, disc, concat(env, "")).
    If mi is greater than 0:
        Return runBlockStr(substringBefore(switchFallStmts(split(marked, chr(10)), mi, ""), "break"), env).
    Let di be switchDefaultIdx(split(marked, chr(10)), 1).
    If di is equal to 0:
        Return env.
    Return runBlockStr(substringBefore(switchFallStmts(split(marked, chr(10)), di, ""), "break"), env).

## To isMemberTarget (lhs: Text) -> Bool:
    If hasSep(lhs, " . "):
        Return true.
    If hasSep(lhs, chr(91)):
        Return true.
    Return false.

## To isSimpleName (sv: Text) -> Bool:
    If hasSep(sv, " . "):
        Return false.
    If hasSep(sv, chr(91)):
        Return false.
    If hasSep(sv, " "):
        Return false.
    Return true.

# `++`/`--` as an EXPRESSION (prefix `++x`, postfix `x++`) — not just a bare `x++` statement. Both a
# statement's env effect and its in-place value matter, but the expression evaluator is value-returning,
# so we resolve the increments at the STATEMENT level: incDecEnv threads the env forward applying every
# increment left-to-right, and incDecRewrite (threading the same env) substitutes each increment's value
# in place — prefix yields the NEW value, postfix the OLD — leaving a statement with no `++`/`--` that the
# ordinary handlers run against the already-incremented env. A bare `x++` falls out as a value-only no-op
# statement plus the env bump, so this subsumes the old whole-statement handler too.
# A postfix `x++` whose `x` is preceded by `.` is a MEMBER increment (`o.c++`) — left to
# memberCompoundRewrite, not the simple-scalar path.
## To prevIsDot (toks: Seq of Text, i: Int) -> Bool:
    If i is greater than 1:
        Return item (i - 1) of toks is equal to ".".
    Return false.

# A postfix `x++` target must be a real identifier, not a keyword: in `return ++c` the `++` is a PREFIX
# of `c`, so `return` must not be read as `return++`. Excludes the word-like keywords that can precede a
# unary `++`/`--`.
## To isIncTarget (t: Text) -> Bool:
    If isWordChar1(t) is equal to false:
        Return false.
    If t is equal to "return":
        Return false.
    If t is equal to "typeof":
        Return false.
    If t is equal to "delete":
        Return false.
    If t is equal to "void":
        Return false.
    If t is equal to "yield":
        Return false.
    If t is equal to "throw":
        Return false.
    If t is equal to "await":
        Return false.
    If t is equal to "new":
        Return false.
    If t is equal to "in":
        Return false.
    If t is equal to "of":
        Return false.
    If t is equal to "case":
        Return false.
    If t is equal to "do":
        Return false.
    If t is equal to "else":
        Return false.
    Return true.

## To incDecEnv (toks: Seq of Text, i: Int, depth: Int, env: Text) -> Text:
    If i is greater than length of toks:
        Return env.
    Let t be item i of toks.
    If t is equal to chr(123):
        Return incDecEnv(toks, i + 1, depth + 1, env).
    If t is equal to chr(125):
        Return incDecEnv(toks, i + 1, depth - 1, env).
    If depth is greater than 0:
        Return incDecEnv(toks, i + 1, depth, env).
    If t is equal to "++":
        If i is less than length of toks:
            Let x be item (i + 1) of toks.
            If isWordChar1(x):
                Let nv be jsEvalIn(concat(x, " + 1"), concat(env, "")).
                Return incDecEnv(toks, i + 2, depth, envSet(env, x, nv)).
    If t is equal to "--":
        If i is less than length of toks:
            Let xd be item (i + 1) of toks.
            If isWordChar1(xd):
                Let nvd be jsEvalIn(concat(xd, " - 1"), concat(env, "")).
                Return incDecEnv(toks, i + 2, depth, envSet(env, xd, nvd)).
    If i is less than length of toks:
        Let nx be item (i + 1) of toks.
        If nx is equal to "++":
            If isIncTarget(t):
                If prevIsDot(toks, i) is equal to false:
                    Let pv be jsEvalIn(concat(t, " + 1"), concat(env, "")).
                    Return incDecEnv(toks, i + 2, depth, envSet(env, t, pv)).
        If nx is equal to "--":
            If isIncTarget(t):
                If prevIsDot(toks, i) is equal to false:
                    Let pvd be jsEvalIn(concat(t, " - 1"), concat(env, "")).
                    Return incDecEnv(toks, i + 2, depth, envSet(env, t, pvd)).
    Return incDecEnv(toks, i + 1, depth, env).

## To incDecRewrite (toks: Seq of Text, i: Int, depth: Int, env: Text, acc: Text) -> Text:
    If i is greater than length of toks:
        Return trim(acc).
    Let t be item i of toks.
    If t is equal to chr(123):
        Return incDecRewrite(toks, i + 1, depth + 1, env, concat(concat(acc, " "), t)).
    If t is equal to chr(125):
        Return incDecRewrite(toks, i + 1, depth - 1, env, concat(concat(acc, " "), t)).
    If depth is greater than 0:
        Return incDecRewrite(toks, i + 1, depth, env, concat(concat(acc, " "), t)).
    If t is equal to "++":
        If i is less than length of toks:
            Let x be item (i + 1) of toks.
            If isWordChar1(x):
                Let nv be materialize(jsEvalIn(concat(x, " + 1"), concat(env, ""))).
                Let e2 be envSet(env, x, nv).
                Return incDecRewrite(toks, i + 2, depth, e2, concat(concat(acc, " "), nv)).
    If t is equal to "--":
        If i is less than length of toks:
            Let xd be item (i + 1) of toks.
            If isWordChar1(xd):
                Let nvd be materialize(jsEvalIn(concat(xd, " - 1"), concat(env, ""))).
                Let e3 be envSet(env, xd, nvd).
                Return incDecRewrite(toks, i + 2, depth, e3, concat(concat(acc, " "), nvd)).
    If i is less than length of toks:
        Let nx be item (i + 1) of toks.
        If nx is equal to "++":
            If isIncTarget(t):
                If prevIsDot(toks, i) is equal to false:
                    Let ov be materialize(jsEvalIn(concat(t, ""), concat(env, ""))).
                    Let inc be materialize(jsEvalIn(concat(t, " + 1"), concat(env, ""))).
                    Let e4 be envSet(env, t, inc).
                    Return incDecRewrite(toks, i + 2, depth, e4, concat(concat(acc, " "), ov)).
        If nx is equal to "--":
            If isIncTarget(t):
                If prevIsDot(toks, i) is equal to false:
                    Let ovd be materialize(jsEvalIn(concat(t, ""), concat(env, ""))).
                    Let dec be materialize(jsEvalIn(concat(t, " - 1"), concat(env, ""))).
                    Let e5 be envSet(env, t, dec).
                    Return incDecRewrite(toks, i + 2, depth, e5, concat(concat(acc, " "), ovd)).
    Return incDecRewrite(toks, i + 1, depth, env, concat(concat(acc, " "), t)).

# True only for a SIMPLE-identifier `++`/`--` (`x++`, `++x`, `a[i++]`) that incDecRewrite will actually
# rewrite — NOT a member target like `a[i]++`/`o.c++` (handled by memberCompoundRewrite) nor a `++` living
# inside a string token. This gates the top-of-execStmt routing so it always makes progress (no re-loop).
## To hasSimpleIncDec (toks: Seq of Text, i: Int, depth: Int) -> Bool:
    If i is greater than length of toks:
        Return false.
    Let t be item i of toks.
    If t is equal to chr(123):
        Return hasSimpleIncDec(toks, i + 1, depth + 1).
    If t is equal to chr(125):
        Return hasSimpleIncDec(toks, i + 1, depth - 1).
    If depth is greater than 0:
        Return hasSimpleIncDec(toks, i + 1, depth).
    If t is equal to "++":
        If i is less than length of toks:
            If isWordChar1(item (i + 1) of toks):
                Return true.
    If t is equal to "--":
        If i is less than length of toks:
            If isWordChar1(item (i + 1) of toks):
                Return true.
    If i is less than length of toks:
        Let nx be item (i + 1) of toks.
        If nx is equal to "++":
            If isIncTarget(t):
                If prevIsDot(toks, i) is equal to false:
                    Return true.
        If nx is equal to "--":
            If isIncTarget(t):
                If prevIsDot(toks, i) is equal to false:
                    Return true.
    Return hasSimpleIncDec(toks, i + 1, depth).

## To needsIncDec (s: Text) -> Bool:
    If startsWith(s, "for "):
        Return false.
    If startsWith(s, "while "):
        Return false.
    If startsWith(s, "if "):
        Return false.
    If startsWith(s, "switch "):
        Return false.
    Return hasSimpleIncDec(split(concat(s, ""), " "), 1, 0).

## To memberCompoundRewrite (s: Text) -> Text:
    If hasSep(s, "++"):
        If isMemberTarget(trim(concat(substringBefore(s, "++"), substringAfter(s, "++")))):
            Return concat(concat(trim(concat(substringBefore(s, "++"), substringAfter(s, "++"))), " = "), concat(trim(concat(substringBefore(s, "++"), substringAfter(s, "++"))), " + 1")).
    If hasSep(s, "--"):
        If isMemberTarget(trim(concat(substringBefore(s, "--"), substringAfter(s, "--")))):
            Return concat(concat(trim(concat(substringBefore(s, "--"), substringAfter(s, "--"))), " = "), concat(trim(concat(substringBefore(s, "--"), substringAfter(s, "--"))), " - 1")).
    If hasSep(s, " += "):
        If isMemberTarget(trim(substringBefore(s, " += "))):
            Return concat(concat(trim(substringBefore(s, " += ")), " = "), concat(concat(trim(substringBefore(s, " += ")), " + "), trim(substringAfter(s, " += ")))).
    If hasSep(s, " -= "):
        If isMemberTarget(trim(substringBefore(s, " -= "))):
            Return concat(concat(trim(substringBefore(s, " -= ")), " = "), concat(concat(trim(substringBefore(s, " -= ")), " - "), trim(substringAfter(s, " -= ")))).
    If hasSep(s, " *= "):
        If isMemberTarget(trim(substringBefore(s, " *= "))):
            Return concat(concat(trim(substringBefore(s, " *= ")), " = "), concat(concat(trim(substringBefore(s, " *= ")), " * "), trim(substringAfter(s, " *= ")))).
    If hasSep(s, " ||= "):
        If isMemberTarget(trim(substringBefore(s, " ||= "))):
            Return concat(concat(trim(substringBefore(s, " ||= ")), " = "), concat(concat(trim(substringBefore(s, " ||= ")), " || "), trim(substringAfter(s, " ||= ")))).
    If hasSep(s, " &&= "):
        If isMemberTarget(trim(substringBefore(s, " &&= "))):
            Return concat(concat(trim(substringBefore(s, " &&= ")), " = "), concat(concat(trim(substringBefore(s, " &&= ")), " && "), trim(substringAfter(s, " &&= ")))).
    If hasSep(s, " ??= "):
        If isMemberTarget(trim(substringBefore(s, " ??= "))):
            Return concat(concat(trim(substringBefore(s, " ??= ")), " = "), concat(concat(trim(substringBefore(s, " ??= ")), " ?? "), trim(substringAfter(s, " ??= ")))).
    Return "".

## To objSetPath (objval: Text, segs: Seq of Text, i: Int, v: Text) -> Text:
    If i is equal to length of segs:
        Return objSet(objval, trim(item i of segs), v).
    Let child be objGet(concat(objval, ""), trim(item i of segs)).
    Return objSet(objval, trim(item i of segs), objSetPath(child, segs, i + 1, v)).

## To assignTarget (target: Text, value: Text, env: Text) -> Text:
    If hasSep(target, " . "):
        Let base be trim(substringBefore(target, " . ")).
        Let recvV be envGet(concat(env, ""), concat(base, "")).
        Let setter be objGet(concat(recvV, ""), concat("__set_", trim(substringAfter(target, " . ")))).
        If startsWith(setter, chr(1)):
            Let ran be callSetter(setter, recvV, value, env).
            Return env.
        Let newobj be objSetPath(recvV, split(substringAfter(target, " . "), " . "), 1, value).
        Return envSet(env, base, newobj).
    If hasSep(target, chr(91)):
        Let ivar be trim(substringBefore(target, chr(91))).
        Let iidx be safeInt(materialize(jsEvalIn(trim(substringBefore(substringAfter(target, chr(91)), chr(93))), concat(env, "")))).
        Let newarr be arrSetIdx(envGet(concat(env, ""), concat(ivar, "")), iidx, value).
        Return envSet(env, ivar, newarr).
    Return envSet(env, target, value).

## To execStmt (stmt: Text, env: Text) -> Text:
    Let s be trim(stmt).
    If needsIncDec(s):
        Let nStmt be incDecRewrite(split(concat(s, ""), " "), 1, 0, concat(env, ""), "").
        Let nEnv be incDecEnv(split(concat(s, ""), " "), 1, 0, concat(env, "")).
        Return execStmt(nStmt, nEnv).
    If s is equal to "break":
        Return envSet(env, "__break", "1").
    If startsWith(s, "break "):
        Return envSet(env, "__break", "1").
    If s is equal to "continue":
        Return envSet(env, "__continue", "1").
    If startsWith(s, "continue "):
        Return envSet(env, "__continue", "1").
    If startsWith(s, "delete "):
        Let dtgt be trim(substringAfter(s, "delete ")).
        If hasSep(dtgt, chr(91)):
            Let dbase be trim(substringBefore(dtgt, chr(91))).
            Let drecv be envGet(concat(env, ""), concat(dbase, "")).
            Let dkey be materialize(jsEvalIn(trim(substringBefore(substringAfter(dtgt, chr(91)), chr(93))), concat(env, ""))).
            If isArrRef(concat(drecv, "")):
                Let da be arrSetIdx(concat(drecv, ""), safeInt(concat(dkey, "")), "undefined").
                Return env.
            Let dob be objDelete(concat(drecv, ""), concat(dkey, "")).
            Return env.
        If hasSep(dtgt, " . "):
            Let mbase be trim(substringBefore(dtgt, " . ")).
            Let mrecv be envGet(concat(env, ""), concat(mbase, "")).
            Let md be objDelete(concat(mrecv, ""), trim(substringAfter(dtgt, " . "))).
            Return env.
        Return env.
    If s is equal to "__GENRESET":
        genReset().
        Return env.
    If startsWith(s, "yield "):
        genPush(jsEvalIn(substringAfter(s, "yield "), env)).
        Return env.
    If s is equal to "yield":
        genPush("undefined").
        Return env.
    If startsWith(s, "__super__ "):
        Let srest be substringAfter(s, "__super__ ").
        Let pname be item 1 of split(srest, " ").
        Let sargs be balancedArg(substringAfter(srest, chr(40)), 1, 0, "").
        Let ran be callMethod(envGet(concat(env, ""), concat(pname, "")), sargs, envGet(concat(env, ""), "this"), env).
        Return env.
    If startsWith(s, "console . log ("):
        Return doConsoleLog(balancedArg(substringAfter(s, "console . log ("), 1, 0, ""), env).
    If startsWith(s, "console . info ("):
        Return doConsoleLog(balancedArg(substringAfter(s, "console . info ("), 1, 0, ""), env).
    If startsWith(s, "console . error ("):
        Return doConsoleErr(balancedArg(substringAfter(s, "console . error ("), 1, 0, ""), env).
    If startsWith(s, "console . warn ("):
        Return doConsoleErr(balancedArg(substringAfter(s, "console . warn ("), 1, 0, ""), env).
    If startsWith(s, "process . exit ("):
        Return doExit(balancedArg(substringAfter(s, "process . exit ("), 1, 0, ""), env).
    If startsWith(s, "function "):
        Return defineFn(s, env).
    If startsWith(s, "return"):
        If trim(substringAfter(s, "return")) is equal to "__GENMAKE":
            Return envSet(env, "__ret", genMake()).
        If isFnLiteral(trim(substringAfter(s, "return"))):
            Return envSet(env, "__ret", funcValueOf(substitute(trim(substringAfter(s, "return")), env))).
        If startsWith(trim(substringAfter(s, "return")), "console . log ("):
            Let logged be doConsoleLog(balancedArg(substringAfter(trim(substringAfter(s, "return")), "console . log ("), 1, 0, ""), env).
            Return envSet(env, "__ret", "undefined").
        Return envSet(env, "__ret", jsEvalIn(substringAfter(s, "return"), env)).
    If startsWith(s, "throw "):
        Return envSet(env, "__throw", jsEvalIn(substringAfter(s, "throw "), env)).
    If startsWith(s, "try "):
        Return execTry(s, env).
    If startsWith(s, "do "):
        Return execDoWhile(s, env).
    If startsWith(s, concat("do", chr(123))):
        Return execDoWhile(s, env).
    If startsWith(s, "while "):
        Return execWhile(s, env).
    If startsWith(s, "for "):
        Return execFor(s, env).
    If startsWith(s, "if "):
        Return execIf(s, env).
    If startsWith(s, "switch "):
        Return execSwitch(s, env).
    If startsWith(s, "let "):
        Return bindAssign(substringAfter(s, "let "), env).
    If startsWith(s, "const "):
        Return bindAssign(substringAfter(s, "const "), env).
    If startsWith(s, "var "):
        Return bindAssign(substringAfter(s, "var "), env).
    If hasSep(s, " . push ("):
        Let pv be trim(substringBefore(s, " . push (")).
        If isArrRef(jsEvalIn(concat(pv, ""), concat(env, ""))):
            Let pa be balancedArg(substringAfter(s, " . push ("), 1, 0, "").
            Return assignTarget(concat(pv, ""), arrPushAll(jsEvalIn(concat(pv, ""), concat(env, "")), splitArgsN(concat(pa, "")), 1, env), env).
    If hasSep(s, " . pop ("):
        Let ov be trim(substringBefore(s, " . pop (")).
        If isArrRef(jsEvalIn(concat(ov, ""), concat(env, ""))):
            Return assignTarget(concat(ov, ""), arrPop(jsEvalIn(concat(ov, ""), concat(env, ""))), env).
    If hasSep(s, " . sort ("):
        Let sv be trim(substringBefore(s, " . sort (")).
        Let saft be substringAfter(s, " . sort (").
        Let srest be trim(strSliceLoop(saft, (length of balancedArg(concat(saft, ""), 1, 0, "")) + 2, length of saft, "")).
        If srest is equal to "":
            If isSimpleName(concat(sv, "")):
                If isArrRef(jsEvalIn(concat(sv, ""), concat(env, ""))):
                    Return envSet(env, sv, jsEvalIn(concat(s, ""), env)).
    If hasSep(s, " . fill ("):
        Let fv be trim(substringBefore(s, " . fill (")).
        Let faft be substringAfter(s, " . fill (").
        Let frest be trim(strSliceLoop(faft, (length of balancedArg(concat(faft, ""), 1, 0, "")) + 2, length of faft, "")).
        If frest is equal to "":
            If isSimpleName(concat(fv, "")):
                If isArrRef(jsEvalIn(concat(fv, ""), concat(env, ""))):
                    Return envSet(env, fv, jsEvalIn(concat(s, ""), env)).
    If hasSep(s, " . reverse ("):
        Let rv be trim(substringBefore(s, " . reverse (")).
        Let raft be substringAfter(s, " . reverse (").
        Let rrest be trim(strSliceLoop(raft, (length of balancedArg(concat(raft, ""), 1, 0, "")) + 2, length of raft, "")).
        If rrest is equal to "":
            If isSimpleName(concat(rv, "")):
                If isArrRef(jsEvalIn(concat(rv, ""), concat(env, ""))):
                    Return envSet(env, rv, jsEvalIn(concat(s, ""), env)).
    Let mcr be memberCompoundRewrite(concat(s, "")).
    If hasSep(mcr, " = "):
        Return execStmt(mcr, env).
    If hasSep(s, " += "):
        Return envSet(env, trim(substringBefore(s, " += ")), jsEvalIn(concat(concat(trim(substringBefore(s, " += ")), " + "), substringAfter(s, " += ")), env)).
    If hasSep(s, " -= "):
        Return envSet(env, trim(substringBefore(s, " -= ")), jsEvalIn(concat(concat(trim(substringBefore(s, " -= ")), " - "), substringAfter(s, " -= ")), env)).
    If hasSep(s, " *= "):
        Return envSet(env, trim(substringBefore(s, " *= ")), jsEvalIn(concat(concat(trim(substringBefore(s, " *= ")), " * "), substringAfter(s, " *= ")), env)).
    If hasSep(s, " ||= "):
        Return envSet(env, trim(substringBefore(s, " ||= ")), jsEvalIn(concat(concat(trim(substringBefore(s, " ||= ")), " || "), substringAfter(s, " ||= ")), env)).
    If hasSep(s, " &&= "):
        Return envSet(env, trim(substringBefore(s, " &&= ")), jsEvalIn(concat(concat(trim(substringBefore(s, " &&= ")), " && "), substringAfter(s, " &&= ")), env)).
    If hasSep(s, " ??= "):
        Return envSet(env, trim(substringBefore(s, " ??= ")), jsEvalIn(concat(concat(trim(substringBefore(s, " ??= ")), " ?? "), substringAfter(s, " ??= ")), env)).
    If hasSep(s, " = "):
        Let lhs be trim(substringBefore(s, " = ")).
        If hasSep(lhs, " . "):
            Return assignTarget(lhs, jsEvalIn(substringAfter(s, " = "), concat(env, "")), env).
        If hasSep(lhs, chr(91)):
            Return assignTarget(lhs, jsEvalIn(substringAfter(s, " = "), concat(env, "")), env).
        Return bindAssign(s, env).
    If hasSep(s, "("):
        Let sideEffect be jsEvalIn(concat(s, ""), env).
        Return env.
    Return env.

# A callee that threw stashes the value in the thread-local pending-throw channel (throwSet); after each
# statement runBlock drains it back into THIS block's env as `__throw`, so the ordinary halt + try/catch
# machinery takes over — this is what carries a `throw` out of a called function to the caller's try.
## To maybePropagateThrow (env: Text) -> Text:
    If hasThrow(env):
        Return throwSet(envGet(env, "__throw")).
    Return "".

## To drainPendingThrow (env: Text) -> Text:
    If throwPending() is equal to "1":
        Let tv be throwGet().
        Let c be throwClear().
        Return envSet(env, "__throw", tv).
    Return env.

## To runBlock (stmts: Seq of Text, i: Int, env: Text) -> Text:
    If i is greater than length of stmts:
        Return env.
    If hasHalt(env):
        Return env.
    If hasBreak(env):
        Return env.
    If hasContinue(env):
        Return env.
    Let st be item i of stmts.
    Return runBlock(stmts, i + 1, drainPendingThrow(execStmt(st, env))).

## To execWhile (stmt: Text, env: Text) -> Text:
    If hasHalt(env):
        Return env.
    Let cond be trim(substringBefore(substringAfter(stmt, "("), ")")).
    Let body be braceBody(substringAfter(stmt, chr(123)), 1, 0, "").
    If boolOf(jsEvalIn(cond, env)):
        Let afterBody be runBlockStr(body, env).
        If hasHalt(afterBody):
            Return afterBody.
        If hasBreak(afterBody):
            Return clearBreak(afterBody).
        If hasContinue(afterBody):
            Return execWhile(stmt, clearContinue(afterBody)).
        Return execWhile(stmt, afterBody).
    Return env.

## To clearContIf (env: Text) -> Text:
    If hasContinue(env):
        Return clearContinue(env).
    Return env.

# do-while runs the body ONCE before testing the guard (unlike while). The body is the first brace
# group; the condition is the while-paren that follows it. break exits, continue jumps to the guard
# test (both handled like execWhile). Loops by re-running the whole statement while the guard holds.
## To execDoWhile (stmt: Text, env: Text) -> Text:
    If hasHalt(env):
        Return env.
    Let body be braceBody(substringAfter(stmt, chr(123)), 1, 0, "").
    Let cond be trim(substringBefore(substringAfter(substringAfter(stmt, "while"), "("), ")")).
    Let afterBody be runBlockStr(body, env).
    If hasHalt(afterBody):
        Return afterBody.
    If hasBreak(afterBody):
        Return clearBreak(afterBody).
    Let e2 be clearContIf(afterBody).
    If boolOf(jsEvalIn(cond, e2)):
        Return execDoWhile(stmt, e2).
    Return e2.

## To forStmt (stmt: Text, env: Text) -> Text:
    If hasHalt(env):
        Return env.
    Let parts be split(substringBefore(substringAfter(stmt, "("), ")"), ";").
    Let cond be trim(item 2 of parts).
    If boolOf(jsEvalIn(cond, env)):
        Let body be braceBody(substringAfter(stmt, chr(123)), 1, 0, "").
        Let update be trim(item 3 of parts).
        Let afterBody be runBlockStr(body, env).
        If hasHalt(afterBody):
            Return afterBody.
        If hasBreak(afterBody):
            Return clearBreak(afterBody).
        If hasContinue(afterBody):
            Return forStmt(stmt, execStmt(update, clearContinue(afterBody))).
        Return forStmt(stmt, execStmt(update, afterBody)).
    Return env.

# The for-of / for-in loop variable may be a destructuring pattern (`for (const [k,v] of …)`), so
# bind it per element through destructureArr/Obj; a plain name binds directly.
## To bindLoopVar (varName: Text, el: Text, env: Text) -> Text:
    If startsWith(varName, chr(91)):
        Return destructureArr(varName, el, env).
    If startsWith(varName, chr(123)):
        Return destructureObj(varName, el, env).
    Return envSet(env, varName, el).

## To forOfLoop (els: Seq of Text, i: Int, varName: Text, body: Text, env: Text) -> Text:
    If hasHalt(env):
        Return env.
    If i is greater than length of els:
        Return env.
    Let el be item i of els.
    Let e2 be bindLoopVar(concat(varName, ""), el, env).
    Let afterBody be runBlockStr(concat(body, ""), e2).
    If hasHalt(afterBody):
        Return afterBody.
    If hasBreak(afterBody):
        Return clearBreak(afterBody).
    If hasContinue(afterBody):
        Return forOfLoop(els, i + 1, varName, body, clearContinue(afterBody)).
    Return forOfLoop(els, i + 1, varName, body, afterBody).

## To execForOf (stmt: Text, env: Text) -> Text:
    Let hdr be trim(substringBefore(substringAfter(stmt, "("), ")")).
    Let afterKw be trim(substringAfter(hdr, " ")).
    Let varName be trim(substringBefore(afterKw, " of ")).
    Let arrExpr be trim(substringAfter(afterKw, " of ")).
    Let body be braceBody(substringAfter(stmt, chr(123)), 1, 0, "").
    Return forOfLoop(iterElements(jsEvalIn(arrExpr, env)), 1, varName, body, env).

## To arrIndexKeys (n: Int, i: Int, acc: Text) -> Text:
    If i is greater than n:
        Return acc.
    Let k be concat(tagStr (), toText(i - 1)).
    If acc is equal to "":
        Return arrIndexKeys(n, i + 1, k).
    Return arrIndexKeys(n, i + 1, concat(concat(acc, tagArrSep ()), k)).

## To forInKeys (v: Text) -> Text:
    If isObjRef(v):
        Return objKeys(v).
    If isArrRef(v):
        Return newArr(concat(concat(tagArr (), arrIndexKeys(length of arrElements(v), 1, "")), tagArrEnd ())).
    Return newArr(concat(tagArr (), tagArrEnd ())).

## To execForIn (stmt: Text, env: Text) -> Text:
    Let hdr be trim(substringBefore(substringAfter(stmt, "("), ")")).
    Let afterKw be trim(substringAfter(hdr, " ")).
    Let varName be trim(substringBefore(afterKw, " in ")).
    Let objExpr be trim(substringAfter(afterKw, " in ")).
    Let body be braceBody(substringAfter(stmt, chr(123)), 1, 0, "").
    Return forOfLoop(arrElements(forInKeys(jsEvalIn(objExpr, env))), 1, varName, body, env).

## To execFor (stmt: Text, env: Text) -> Text:
    Let hdr be substringBefore(substringAfter(stmt, "("), ")").
    If hasSep(hdr, " of "):
        Return execForOf(stmt, env).
    If hasSep(hdr, " in "):
        Return execForIn(stmt, env).
    Let init be trim(item 1 of split(hdr, ";")).
    Return forStmt(stmt, execStmt(init, env)).

## To runProgram (stmts: Seq of Text, i: Int, env: Text) -> Text:
    Let stmt be trim(item i of stmts).
    If i is equal to length of stmts:
        Return jsEvalIn(stmt, env).
    Return runProgram(stmts, i + 1, execStmt(stmt, env)).

## To jsRun (program: Text) -> Text:
    Let v be runProgram(split(splitTop(program, 1, 0, ""), chr(10)), 1, "").
    Let drained be drainMicrotasks("", "").
    Return v.

## To nchars (s: Text, i: Int, n: Int) -> Text:
    If i + n is greater than length of s + 1:
        Return "".
    If n is equal to 2:
        Return concat(item i of s, item (i + 1) of s).
    Return concat(concat(item i of s, item (i + 1) of s), item (i + 2) of s).

## To isOp3 (t: Text) -> Bool:
    If t is equal to "===":
        Return true.
    If t is equal to ">>>":
        Return true.
    If t is equal to "!==":
        Return true.
    If t is equal to "...":
        Return true.
    If t is equal to "||=":
        Return true.
    If t is equal to "&&=":
        Return true.
    If t is equal to "??=":
        Return true.
    Return false.

## To isOp2 (t: Text) -> Bool:
    If t is equal to "**":
        Return true.
    If t is equal to "<<":
        Return true.
    If t is equal to ">>":
        Return true.
    If t is equal to "??":
        Return true.
    If t is equal to "?.":
        Return true.
    If t is equal to "==":
        Return true.
    If t is equal to "!=":
        Return true.
    If t is equal to "<=":
        Return true.
    If t is equal to ">=":
        Return true.
    If t is equal to "&&":
        Return true.
    If t is equal to "||":
        Return true.
    If t is equal to "+=":
        Return true.
    If t is equal to "-=":
        Return true.
    If t is equal to "*=":
        Return true.
    If t is equal to "++":
        Return true.
    If t is equal to "--":
        Return true.
    If t is equal to "=>":
        Return true.
    Return false.

## To isOp1 (c: Text) -> Bool:
    Let ops be ["+", "-", "*", "/", "%", "<", ">", "(", ")", ";", "?", ":", "=", "!", ",", ".", "&", "|", "^", "~"].
    If ops contains c:
        Return true.
    If c is equal to chr(123):
        Return true.
    If c is equal to chr(125):
        Return true.
    If c is equal to chr(91):
        Return true.
    If c is equal to chr(93):
        Return true.
    Return false.

## To spaced (t: Text) -> Text:
    Return concat(concat(" ", t), " ").

## To decodeStr (s: Text) -> Text:
    Let a be replaceAll(s, encSpace (), " ").
    Let b be replaceAll(a, encBrkL (), chr(91)).
    Let c be replaceAll(b, encBrkR (), chr(93)).
    Let d be replaceAll(c, encBraceL (), chr(123)).
    Let e be replaceAll(d, encBraceR (), chr(125)).
    Let f be replaceAll(e, encParenL (), "(").
    Let g be replaceAll(f, encParenR (), ")").
    Let h be replaceAll(g, encQuote (), chr(34)).
    Let ii be replaceAll(h, encBackslash (), chr(92)).
    Return replaceAll(ii, encNewline (), chr(10)).

## To normJs (s: Text, i: Int, inStr: Bool, acc: Text) -> Text:
    If i is greater than length of s:
        Return acc.
    Let c be item i of s.
    If c is equal to chr(34):
        Return normJs(s, i + 1, inStr is equal to false, concat(acc, c)).
    If inStr:
        If c is equal to chr(92):
            If i is less than length of s:
                Let nx be item (i + 1) of s.
                If nx is equal to chr(34):
                    Return normJs(s, i + 2, inStr, concat(acc, encQuote ())).
                If nx is equal to chr(92):
                    Return normJs(s, i + 2, inStr, concat(acc, encBackslash ())).
                If nx is equal to "n":
                    Return normJs(s, i + 2, inStr, concat(acc, encNewline ())).
                If nx is equal to "t":
                    Return normJs(s, i + 2, inStr, concat(acc, chr(9))).
                Return normJs(s, i + 2, inStr, concat(acc, nx)).
            Return normJs(s, i + 1, inStr, concat(acc, c)).
        If c is equal to " ":
            Return normJs(s, i + 1, inStr, concat(acc, encSpace ())).
        If c is equal to chr(91):
            Return normJs(s, i + 1, inStr, concat(acc, encBrkL ())).
        If c is equal to chr(93):
            Return normJs(s, i + 1, inStr, concat(acc, encBrkR ())).
        If c is equal to chr(123):
            Return normJs(s, i + 1, inStr, concat(acc, encBraceL ())).
        If c is equal to chr(125):
            Return normJs(s, i + 1, inStr, concat(acc, encBraceR ())).
        If c is equal to "(":
            Return normJs(s, i + 1, inStr, concat(acc, encParenL ())).
        If c is equal to ")":
            Return normJs(s, i + 1, inStr, concat(acc, encParenR ())).
        Return normJs(s, i + 1, inStr, concat(acc, c)).
    If c is equal to ".":
        If digitChar(lastCharOf(acc)):
            If i is less than length of s:
                If digitChar(item (i + 1) of s):
                    Return normJs(s, i + 1, inStr, concat(acc, c)).
    Let op3 be nchars(s, i, 3).
    If isOp3(op3):
        Return normJs(s, i + 3, inStr, concat(acc, spaced(op3))).
    Let op2 be nchars(s, i, 2).
    If isOp2(op2):
        Return normJs(s, i + 2, inStr, concat(acc, spaced(op2))).
    If isOp1(c):
        Return normJs(s, i + 1, inStr, concat(acc, spaced(c))).
    Return normJs(s, i + 1, inStr, concat(acc, c)).

## To digitChar (c: Text) -> Bool:
    If c is equal to "":
        Return false.
    Let o be ord(c).
    If o is less than 48:
        Return false.
    If o is greater than 57:
        Return false.
    Return true.

## To lastCharOf (s: Text) -> Text:
    If s is equal to "":
        Return "".
    Return item (length of s) of s.

## To joinNonEmpty (parts: Seq of Text, i: Int, acc: Text) -> Text:
    If i is greater than length of parts:
        Return acc.
    Let piece be item i of parts.
    If piece is equal to "":
        Return joinNonEmpty(parts, i + 1, acc).
    If acc is equal to "":
        Return joinNonEmpty(parts, i + 1, piece).
    Return joinNonEmpty(parts, i + 1, concat(concat(acc, " "), piece)).

## To isBodyTerm (c: Text) -> Bool:
    If c is equal to ",":
        Return true.
    If c is equal to ";":
        Return true.
    If c is equal to ")":
        Return true.
    If c is equal to chr(93):
        Return true.
    If c is equal to chr(125):
        Return true.
    Return false.

## To isOpenGrp (c: Text) -> Bool:
    If c is equal to "(":
        Return true.
    If c is equal to chr(91):
        Return true.
    If c is equal to chr(123):
        Return true.
    Return false.

## To isCloseGrp (c: Text) -> Bool:
    If c is equal to ")":
        Return true.
    If c is equal to chr(93):
        Return true.
    If c is equal to chr(125):
        Return true.
    Return false.

## To matchGroupLeft (toks: Seq of Text, i: Int, depth: Int, g: Text) -> Int:
    If i is less than 1:
        Return 1.
    Let c be item i of toks.
    If isCloseGrp(c):
        Return matchGroupLeft(toks, i - 1, depth + 1, concat(g, c)).
    If isOpenGrp(c):
        If depth is equal to 1:
            Return i.
        Return matchGroupLeft(toks, i - 1, depth - 1, concat(g, c)).
    Return matchGroupLeft(toks, i - 1, depth, concat(g, c)).

## To isStopTok (c: Text) -> Bool:
    Let stops be ["+", "-", "*", "/", "%", "<", ">", "=", "!", "?", ":", ",", ";", "(", ".", "==", "!=", "<=", ">=", "&&", "||", "+=", "-=", "*=", "++", "--", "=>", "===", "!==", "&", "|"].
    If stops contains c:
        Return true.
    If c is equal to chr(91):
        Return true.
    If c is equal to chr(123):
        Return true.
    Return false.

## To recvStart (btoks: Seq of Text, i: Int) -> Int:
    If i is less than 1:
        Return 1.
    Let c be item i of btoks.
    If isCloseGrp(c):
        Let openIdx be matchGroupLeft(btoks, i, 0, "").
        If openIdx is less than 2:
            Return openIdx.
        If isStopTok(item (openIdx - 1) of btoks):
            Return openIdx.
        Return recvStart(btoks, openIdx - 1).
    If i is greater than 1:
        If item (i - 1) of btoks is equal to ".":
            Return recvStart(btoks, i - 2).
    Return i.

## To recvExpr (bef: Text) -> Text:
    Let btoks be split(bef, " ").
    Let n be length of btoks.
    Return joinRange(btoks, recvStart(btoks, n), n, "").

## To recvPrefix (bef: Text) -> Text:
    Let btoks be split(bef, " ").
    Let n be length of btoks.
    Return joinRange(btoks, 1, recvStart(btoks, n) - 1, "").

## To matchOpenLeft (toks: Seq of Text, i: Int, depth: Int, g: Text) -> Int:
    If i is less than 1:
        Return 0.
    Let c be item i of toks.
    If c is equal to ")":
        Return matchOpenLeft(toks, i - 1, depth + 1, concat(g, c)).
    If c is equal to "(":
        If depth is equal to 1:
            Return i.
        Return matchOpenLeft(toks, i - 1, depth - 1, concat(g, c)).
    Return matchOpenLeft(toks, i - 1, depth, concat(g, c)).

## To exprBodyEnd (toks: Seq of Text, i: Int, depth: Int, g: Text) -> Int:
    If i is greater than length of toks:
        Return i.
    Let c be item i of toks.
    If depth is equal to 0:
        If isBodyTerm(c):
            Return i.
    If isOpenGrp(c):
        Return exprBodyEnd(toks, i + 1, depth + 1, concat(g, c)).
    If isCloseGrp(c):
        Return exprBodyEnd(toks, i + 1, depth - 1, concat(g, c)).
    Return exprBodyEnd(toks, i + 1, depth, concat(g, c)).

## To blockEndIdx (toks: Seq of Text, i: Int, depth: Int, g: Text) -> Int:
    If i is greater than length of toks:
        Return i.
    Let c be item i of toks.
    If c is equal to chr(123):
        Return blockEndIdx(toks, i + 1, depth + 1, concat(g, c)).
    If c is equal to chr(125):
        If depth is equal to 1:
            Return i.
        Return blockEndIdx(toks, i + 1, depth - 1, concat(g, c)).
    Return blockEndIdx(toks, i + 1, depth, concat(g, c)).

## To fnForm (params: Text, bodyText: Text) -> Text:
    Let head be concat(concat("function ( ", params), " ) ").
    Let withOpen be concat(concat(head, chr(123)), concat(" ", bodyText)).
    Return concat(concat(withOpen, " "), chr(125)).

## To joinFour (pre: Text, fn: Text, rest: Text) -> Text:
    Return concat(concat(concat(concat(pre, " "), fn), " "), rest).

## To buildArrow (preParams: Text, params: Text, right: Text) -> Text:
    Let rt be split(right, " ").
    Let firstR be item 1 of rt.
    Let nR be length of rt.
    If firstR is equal to chr(123):
        Let bEnd be blockEndIdx(rt, 1, 0, "").
        Let bodyInner be joinRange(rt, 2, bEnd - 1, "").
        Let rest be joinRange(rt, bEnd + 1, nR, "").
        Return joinFour(preParams, fnForm(params, bodyInner), rest).
    Let eEnd be exprBodyEnd(rt, 1, 0, "").
    Let body be joinRange(rt, 1, eEnd - 1, "").
    Let rest be joinRange(rt, eEnd, nR, "").
    Return joinFour(preParams, fnForm(params, concat("return ", body)), rest).

## To desugarArrows (expr: Text) -> Text:
    If substringBefore(expr, " => ") is equal to expr:
        Return expr.
    Let left be substringBefore(expr, " => ").
    Let right be substringAfter(expr, " => ").
    Let lt be split(left, " ").
    Let nL be length of lt.
    Let lastL be item nL of lt.
    If lastL is equal to ")":
        Let openIdx be matchOpenLeft(lt, nL, 0, "").
        Return desugarArrows(buildArrow(joinRange(lt, 1, openIdx - 1, ""), joinRange(lt, openIdx + 1, nL - 1, ""), right)).
    Return desugarArrows(buildArrow(joinRange(lt, 1, nL - 1, ""), lastL, right)).

## To desugarTemplates (s: Text, i: Int, mode: Int, depth: Int, acc: Text) -> Text:
    If i is greater than length of s:
        Return acc.
    Let c be item i of s.
    If mode is equal to 0:
        If c is equal to chr(96):
            Return desugarTemplates(s, i + 1, 1, 0, concat(acc, chr(34))).
        Return desugarTemplates(s, i + 1, 0, 0, concat(acc, c)).
    If mode is equal to 1:
        If c is equal to chr(96):
            Return desugarTemplates(s, i + 1, 0, 0, concat(acc, chr(34))).
        If c is equal to "$":
            If i is less than length of s:
                If item (i + 1) of s is equal to chr(123):
                    Return desugarTemplates(s, i + 2, 2, 1, concat(acc, concat(chr(34), " + ("))).
            Return desugarTemplates(s, i + 1, 1, 0, concat(acc, c)).
        Return desugarTemplates(s, i + 1, 1, 0, concat(acc, c)).
    If mode is equal to 3:
        If c is equal to chr(34):
            Return desugarTemplates(s, i + 1, 2, depth, concat(acc, c)).
        Return desugarTemplates(s, i + 1, 3, depth, concat(acc, c)).
    If c is equal to chr(34):
        Return desugarTemplates(s, i + 1, 3, depth, concat(acc, c)).
    If c is equal to chr(123):
        Return desugarTemplates(s, i + 1, 2, depth + 1, concat(acc, c)).
    If c is equal to chr(125):
        If depth is equal to 1:
            Return desugarTemplates(s, i + 1, 1, 0, concat(acc, concat(") + ", chr(34)))).
        Return desugarTemplates(s, i + 1, 2, depth - 1, concat(acc, c)).
    Return desugarTemplates(s, i + 1, 2, depth, concat(acc, c)).

# Class desugar: `class C { constructor(p){ctor} m(q){body} }` becomes a constructor function
# `function C (p) { this.m = function(q){body} ; ctor }` — each non-constructor method is assigned
# onto `this` (an instance-own function value bound dynamically by callMethod), the constructor's
# own params/body drive the function. classWalk peels one `name (params) {body}` member at a time,
# using braceBody's accumulated length to find each member's matching brace and the remainder.
# `class B extends A`: the parent name from the class head (empty for a base class).
## To classParent (head: Seq of Text) -> Text:
    If length of head is greater than 2:
        If item 2 of head is equal to "extends":
            Return item 3 of head.
    Return "".

# Records the parent for `instanceChain` (so `b instanceof A` holds); a base class binds nothing.
## To superBindOf (cname: Text, parent: Text) -> Text:
    If parent is equal to "":
        Return "".
    Return concat(concat(concat("__super_", cname), concat(" = ", concat(chr(34), concat(parent, chr(34))))), " ; ").

# Order the constructor's inner statements. Base class: methods then ctor body. Subclass: the
# `super(args)` call (always the first ctor statement in JS) is rewritten to `__super__ Parent
# (args)` and run FIRST — it invokes the parent constructor with THIS, populating inherited
# fields+methods — then the child's own method assignments (which override the parent's), then
# the rest of the child ctor body.
## To superFirst (parent: Text, cbody: Text, methods: Text, fields: Text) -> Text:
    If parent is equal to "":
        Return concat(concat(methods, fields), cbody).
    Let afterOpen be substringAfter(cbody, chr(40)).
    Let sargs be balancedArg(concat(afterOpen, ""), 1, 0, "").
    Let afterClose be strSliceLoop(afterOpen, (length of sargs) + 2, length of afterOpen, "").
    Let restBody be trim(substringAfter(concat(afterClose, ""), ";")).
    Let superCall be concat(concat(concat(concat("__super__ ", parent), " ( "), sargs), " ) ; ").
    Return concat(concat(concat(superCall, methods), fields), restBody).

# A `static m(){…}` member binds `__static_<Class>_m = function(…){…}` at class-definition time
# (it belongs to the class, not instances) — dispatched by resolveCalls when the receiver of a
# call is a class name. Every other member is an instance method assigned onto `this`.
# A class-body member is a FIELD (not a method) when its name is a plain identifier — not
# constructor/get/set/static/async — that is NOT immediately followed by `(`. `x = expr ;` initializes
# to expr, a bare `x ;` to undefined; both become `this . x = …` prepended into the constructor (after
# super). A `#private` name is just an unusually-spelled property key, so private fields fall out free.
## To isClassField (name: Text, tok2: Text) -> Bool:
    If name is equal to "constructor":
        Return false.
    If name is equal to "static":
        Return false.
    If name is equal to "get":
        Return false.
    If name is equal to "set":
        Return false.
    If name is equal to "async":
        Return false.
    If tok2 is equal to chr(40):
        Return false.
    Return true.

# Safe space-token access: the i-th token of s, or "" past the end. classWalk consumes a class body
# member by member and inspects the second token to tell a field from a method; a single-token member
# (a bare field `a`, or the remnant of an empty `;;` member) has no second token — `item 2 of` would
# panic (out of bounds), so all such lookups go through nthTok.
## To nthTok (s: Text, i: Int) -> Text:
    Let parts be split(s, " ").
    If i is greater than length of parts:
        Return "".
    Return item i of parts.

## To classWalk (cname: Text, parent: Text, body: Text, cparams: Text, cbody: Text, methods: Text, statics: Text, fields: Text) -> Text:
    Let b be trim(body).
    If b is equal to "":
        Let head be concat(concat(concat(concat("function ", cname), " ( "), cparams), " ) ").
        Let fnDef be concat(concat(concat(concat(head, chr(123)), concat(" ", superFirst(parent, cbody, methods, fields))), " "), chr(125)).
        Return concat(statics, fnDef).
    If startsWith(b, ";"):
        Return classWalk(cname, parent, trim(substringAfter(b, ";")), cparams, cbody, methods, statics, fields).
    Let name be item 1 of split(b, " ").
    If isClassField(name, nthTok(concat(b, ""), 2)):
        If nthTok(concat(b, ""), 2) is equal to "=":
            Let fval be trim(substringBefore(substringAfter(b, " = "), " ; ")).
            Let frest be trim(substringAfter(substringAfter(b, " = "), " ; ")).
            Let finit be concat(concat(concat("this . ", name), concat(" = ", fval)), " ; ").
            Return classWalk(cname, parent, frest, cparams, cbody, methods, statics, concat(fields, finit)).
        Let brest be trim(substringAfter(b, " ; ")).
        Let binit be concat(concat("this . ", name), " = undefined ; ").
        Return classWalk(cname, parent, brest, cparams, cbody, methods, statics, concat(fields, binit)).
    Let params be trim(substringBefore(substringAfter(b, chr(40)), chr(41))).
    Let afterBrace be substringAfter(b, chr(123)).
    Let mbody be braceBody(afterBrace, 1, 0, "").
    Let rest be strSliceLoop(afterBrace, (length of mbody) + 2, length of afterBrace, "").
    If name is equal to "constructor":
        Return classWalk(cname, parent, rest, params, trim(mbody), methods, statics, fields).
    If name is equal to "static":
        If nthTok(concat(b, ""), 2) is not equal to chr(40):
            Let sname be nthTok(concat(b, ""), 2).
            Let sHead be concat(concat(concat(concat(concat("__static_", cname), "_"), sname), concat(" = function ( ", params)), " ) ").
            Let sbind be concat(concat(concat(concat(sHead, chr(123)), concat(" ", trim(mbody))), " "), concat(chr(125), " ; ")).
            Return classWalk(cname, parent, rest, cparams, cbody, methods, concat(statics, sbind), fields).
    If name is equal to "get":
        If nthTok(concat(b, ""), 2) is not equal to chr(40):
            Let gHead be concat(concat(concat("this . __get_", nthTok(concat(b, ""), 2)), concat(" = function ( ", params)), " ) ").
            Let gAssign be concat(concat(concat(concat(gHead, chr(123)), concat(" ", trim(mbody))), " "), concat(chr(125), " ; ")).
            Return classWalk(cname, parent, rest, cparams, cbody, concat(methods, gAssign), statics, fields).
    If name is equal to "set":
        If nthTok(concat(b, ""), 2) is not equal to chr(40):
            Let stHead be concat(concat(concat("this . __set_", nthTok(concat(b, ""), 2)), concat(" = function ( ", params)), " ) ").
            Let stAssign be concat(concat(concat(concat(stHead, chr(123)), concat(" ", trim(mbody))), " "), concat(chr(125), " ; ")).
            Return classWalk(cname, parent, rest, cparams, cbody, concat(methods, stAssign), statics, fields).
    Let assignHead be concat(concat(concat(concat("this . ", name), " = function ( "), params), " ) ").
    Let assign be concat(concat(concat(concat(concat(assignHead, chr(123)), concat(" ", trim(mbody))), " "), chr(125)), " ; ").
    Return classWalk(cname, parent, rest, cparams, cbody, concat(methods, assign), statics, fields).

## To desugarClass (expr: Text) -> Text:
    If substringBefore(expr, "class ") is equal to expr:
        Return expr.
    Let bef be substringBefore(expr, "class ").
    Let aft be substringAfter(expr, "class ").
    Let head be split(trim(substringBefore(aft, chr(123))), " ").
    Let cname be item 1 of head.
    Let parent be classParent(head).
    Let afterBrace be substringAfter(aft, chr(123)).
    Let cbody be braceBody(afterBrace, 1, 0, "").
    Let remainder be strSliceLoop(afterBrace, (length of cbody) + 2, length of afterBrace, "").
    Let fnPart be concat(concat(superBindOf(cname, parent), classWalk(cname, parent, trim(cbody), "", "", "", "", "")), " ; ").
    Return desugarClass(concat(concat(bef, fnPart), remainder)).

# `async` adds no new control flow in this synchronous-drain model — an async function runs like
# any function and `await` extracts a promise's settled value — so it is stripped: `async function`
# → `function`, `async (`/`async x =>` → the plain arrow. (`await` itself is handled in jsEvalIn.)
## To stripAsync (s: Text) -> Text:
    Return replaceAll(replaceAll(replaceAll(s, "async function", "function"), "async (", "("), "async ", "").

# Generators (eager-collect): `function* g(params){ body }` becomes a normal function that brackets
# its body with `__GENRESET` (start a fresh yield buffer) and `return __GENMAKE` (package the
# collected yields as a generator object). `yield` statements push onto that buffer as the body
# runs. This works for finite generators; an infinite `while(true) yield` can't be pre-collected.
## To desugarGenerators (expr: Text) -> Text:
    If substringBefore(expr, "function * ") is equal to expr:
        Return expr.
    Let bef be substringBefore(expr, "function * ").
    Let aft be substringAfter(expr, "function * ").
    Let name be item 1 of split(trim(aft), " ").
    Let params be trim(substringBefore(substringAfter(aft, chr(40)), chr(41))).
    Let afterBrace be substringAfter(aft, chr(123)).
    Let body be braceBody(afterBrace, 1, 0, "").
    Let remainder be strSliceLoop(afterBrace, (length of body) + 2, length of afterBrace, "").
    Let head be concat(concat(concat(concat("function ", name), " ( "), params), " ) ").
    Let wrapped be concat(concat(concat(head, chr(123)), concat(concat(" __GENRESET ; ", trim(body)), " ; return __GENMAKE ")), chr(125)).
    Return desugarGenerators(concat(concat(concat(bef, wrapped), " "), remainder)).

# Regex literals (E4.2): rewrite `/pat/flags` → `new RegExp("escaped-pat")` before normJs mangles the
# pattern's operators. This runs first on raw source so the pattern is emitted as an ordinary double-
# quoted string literal (backslashes doubled, quotes escaped) that flows through the tested string
# path and the `new RegExp (` handler. A `/` begins a regex only in expression position — after an
# operator / open-bracket / comma / statement boundary, or an expression keyword (return, typeof, …);
# otherwise it is division. `//` and `/* */` comments are copied through untouched (never regex).
# Flags are dropped (the engine currently ignores them). Regexes inside `${…}` template holes are not
# rewritten (backtick content is treated as an opaque string here).
## To rxRegexPos (c: Text) -> Bool:
    If c is equal to chr(123):
        Return true.
    Let ops be ["", "(", ",", "=", "[", "!", "&", "|", "?", ":", ";", "+", "-", "*", "%", "<", ">", "~", "^"].
    Return ops contains c.

## To rxIsAlpha (c: Text) -> Bool:
    Let o be ord(c).
    If o is greater than or equal to 65:
        If o is less than or equal to 90:
            Return true.
    If o is greater than or equal to 97:
        If o is less than or equal to 122:
            Return true.
    Return false.

## To rxIsIdentChar (c: Text) -> Bool:
    Let o be ord(c).
    If o is greater than or equal to 48:
        If o is less than or equal to 57:
            Return true.
    If c is equal to "_":
        Return true.
    If c is equal to "$":
        Return true.
    Return rxIsAlpha(c).

## To rxIsSpace (c: Text) -> Bool:
    If c is equal to " ":
        Return true.
    If c is equal to chr(9):
        Return true.
    If c is equal to chr(10):
        Return true.
    If c is equal to chr(13):
        Return true.
    Return false.

## To rxLastSigIdx (s: Text, k: Int) -> Int:
    If k is less than 1:
        Return 0.
    If rxIsSpace(item k of s):
        Return rxLastSigIdx(s, k - 1).
    Return k.

## To rxEndsWithWord (acc: Text, w: Text) -> Bool:
    Let e be rxLastSigIdx(acc, length of acc).
    If e is equal to 0:
        Return false.
    Let m be length of w.
    If e is less than m:
        Return false.
    Let tail be strSliceLoop(acc, e - m + 1, e, "").
    If tail is not equal to w:
        Return false.
    If e is equal to m:
        Return true.
    Return rxIsIdentChar(item (e - m) of acc) is equal to false.

## To rxKeyBefore (acc: Text) -> Bool:
    If rxEndsWithWord(acc, "return"):
        Return true.
    If rxEndsWithWord(acc, "typeof"):
        Return true.
    If rxEndsWithWord(acc, "case"):
        Return true.
    If rxEndsWithWord(acc, "do"):
        Return true.
    If rxEndsWithWord(acc, "else"):
        Return true.
    If rxEndsWithWord(acc, "in"):
        Return true.
    If rxEndsWithWord(acc, "of"):
        Return true.
    If rxEndsWithWord(acc, "yield"):
        Return true.
    Return false.

## To rxIsStart (lastSig: Text, acc: Text) -> Bool:
    If rxRegexPos(lastSig):
        Return true.
    Return rxKeyBefore(acc).

## To rxBodyEnd (s: Text, j: Int, inClass: Bool) -> Int:
    If j is greater than length of s:
        Return 0.
    Let c be item j of s.
    If c is equal to chr(92):
        Return rxBodyEnd(s, j + 2, inClass).
    If inClass:
        If c is equal to chr(93):
            Return rxBodyEnd(s, j + 1, false).
        Return rxBodyEnd(s, j + 1, inClass).
    If c is equal to chr(91):
        Return rxBodyEnd(s, j + 1, true).
    If c is equal to "/":
        Return j.
    Return rxBodyEnd(s, j + 1, inClass).

## To rxFlagsEnd (s: Text, k: Int) -> Int:
    If k is greater than length of s:
        Return k.
    If rxIsAlpha(item k of s):
        Return rxFlagsEnd(s, k + 1).
    Return k.

## To rxLineEnd (s: Text, k: Int) -> Int:
    If k is greater than length of s:
        Return k.
    If item k of s is equal to chr(10):
        Return k.
    Return rxLineEnd(s, k + 1).

## To rxBlockEnd (s: Text, k: Int) -> Int:
    If k is greater than length of s:
        Return k.
    If item k of s is equal to "*":
        If k + 1 is less than or equal to length of s:
            If item (k + 1) of s is equal to "/":
                Return k + 2.
    Return rxBlockEnd(s, k + 1).

## To rxEscape (pat: Text, i: Int, acc: Text) -> Text:
    If i is greater than length of pat:
        Return acc.
    Let c be item i of pat.
    If c is equal to chr(92):
        Return rxEscape(pat, i + 1, concat(acc, concat(chr(92), chr(92)))).
    If c is equal to chr(34):
        Return rxEscape(pat, i + 1, concat(acc, concat(chr(92), chr(34)))).
    Return rxEscape(pat, i + 1, concat(acc, c)).

## To rxNextOr (s: Text, j: Int) -> Text:
    If j is greater than length of s:
        Return "".
    Return item j of s.

## To desugarRegexLits (s: Text, i: Int, lastSig: Text, inStr: Bool, strCh: Text, acc: Text) -> Text:
    If i is greater than length of s:
        Return acc.
    Let c be item i of s.
    If inStr:
        If c is equal to chr(92):
            If i is less than length of s:
                Let nc be item (i + 1) of s.
                Return desugarRegexLits(s, i + 2, lastSig, true, strCh, concat(acc, concat(c, nc))).
            Return desugarRegexLits(s, i + 1, lastSig, true, strCh, concat(acc, c)).
        If c is equal to strCh:
            Return desugarRegexLits(s, i + 1, strCh, false, "", concat(acc, c)).
        Return desugarRegexLits(s, i + 1, lastSig, true, strCh, concat(acc, c)).
    If c is equal to chr(34):
        Return desugarRegexLits(s, i + 1, concat(c, ""), true, concat(c, ""), concat(acc, c)).
    If c is equal to chr(39):
        Return desugarRegexLits(s, i + 1, concat(c, ""), true, concat(c, ""), concat(acc, c)).
    If c is equal to chr(96):
        Return desugarRegexLits(s, i + 1, concat(c, ""), true, concat(c, ""), concat(acc, c)).
    If c is equal to "/":
        Let nx be rxNextOr(s, i + 1).
        If nx is equal to "/":
            Let le be rxLineEnd(s, i).
            Let seg be strSliceLoop(s, i, le - 1, "").
            Return desugarRegexLits(s, le, lastSig, false, "", concat(acc, seg)).
        If nx is equal to "*":
            Let bend be rxBlockEnd(s, i + 2).
            Let bseg be strSliceLoop(s, i, bend - 1, "").
            Return desugarRegexLits(s, bend, lastSig, false, "", concat(acc, bseg)).
        If rxIsStart(lastSig, acc):
            Let closeIdx be rxBodyEnd(s, i + 1, false).
            If closeIdx is equal to 0:
                Return desugarRegexLits(s, i + 1, "/", false, "", concat(acc, c)).
            Let pat be strSliceLoop(s, i + 1, closeIdx - 1, "").
            Let fend be rxFlagsEnd(s, closeIdx + 1).
            Let flags be strSliceLoop(s, closeIdx + 1, fend - 1, "").
            Let repl be concat("new RegExp(", concat(chr(34), concat(rxEscape(pat, 1, ""), concat(chr(34), concat(", ", concat(chr(34), concat(flags, concat(chr(34), ")")))))))).
            Return desugarRegexLits(s, fend, ")", false, "", concat(acc, repl)).
        Return desugarRegexLits(s, i + 1, "/", false, "", concat(acc, c)).
    If rxIsSpace(c):
        Return desugarRegexLits(s, i + 1, lastSig, false, "", concat(acc, c)).
    Return desugarRegexLits(s, i + 1, concat(c, ""), false, "", concat(acc, c)).

# Single-quoted strings are normalized to double-quoted FIRST (the tokenizer only knows `"`): inside a
# `'…'`, a literal `"` becomes `\"`, a `\'` becomes a bare `'`, other escapes pass through, and the
# delimiters flip to `"`. Double-quoted and backtick strings pass through untouched (single quotes
# inside a `${…}` template hole are not converted — a rare edge). mode: 0 normal · 1 single · 2 double
# · 3 backtick.
## To convertQuotes (s: Text, i: Int, mode: Int, acc: Text) -> Text:
    If i is greater than length of s:
        Return acc.
    Let c be item i of s.
    If mode is equal to 0:
        If c is equal to chr(39):
            Return convertQuotes(s, i + 1, 1, concat(acc, chr(34))).
        If c is equal to chr(34):
            Return convertQuotes(s, i + 1, 2, concat(acc, c)).
        If c is equal to chr(96):
            Return convertQuotes(s, i + 1, 3, concat(acc, c)).
        Return convertQuotes(s, i + 1, 0, concat(acc, c)).
    If mode is equal to 1:
        If c is equal to chr(92):
            If i is less than length of s:
                Let nx be item (i + 1) of s.
                If nx is equal to chr(39):
                    Return convertQuotes(s, i + 2, 1, concat(acc, chr(39))).
                Return convertQuotes(s, i + 2, 1, concat(acc, concat(c, nx))).
            Return convertQuotes(s, i + 1, 1, concat(acc, c)).
        If c is equal to chr(39):
            Return convertQuotes(s, i + 1, 0, concat(acc, chr(34))).
        If c is equal to chr(34):
            Return convertQuotes(s, i + 1, 1, concat(acc, concat(chr(92), chr(34)))).
        Return convertQuotes(s, i + 1, 1, concat(acc, c)).
    If mode is equal to 2:
        If c is equal to chr(92):
            If i is less than length of s:
                Let nx2 be item (i + 1) of s.
                Return convertQuotes(s, i + 2, 2, concat(acc, concat(c, nx2))).
            Return convertQuotes(s, i + 1, 2, concat(acc, c)).
        If c is equal to chr(34):
            Return convertQuotes(s, i + 1, 0, concat(acc, c)).
        Return convertQuotes(s, i + 1, 2, concat(acc, c)).
    If c is equal to chr(92):
        If i is less than length of s:
            Let nx3 be item (i + 1) of s.
            Return convertQuotes(s, i + 2, 3, concat(acc, concat(c, nx3))).
        Return convertQuotes(s, i + 1, 3, concat(acc, c)).
    If c is equal to chr(96):
        Return convertQuotes(s, i + 1, 0, concat(acc, c)).
    Return convertQuotes(s, i + 1, 3, concat(acc, c)).

# Object method shorthand and accessors desugar to the `key : function` form the object machinery
# already handles. It must run BEFORE resolveCalls, which would otherwise consume a bare `name ( )` as
# a function CALL. Disambiguation is a brace-kind scan: a `{` in value position (after = ( [ , : return ?
# || &&) opens an OBJECT (`o`), else a BLOCK (`b`); `(`/`[` push `p`. A method key sits directly inside
# an `o` frame right after that `{` or a top-level `,`. Misreading a block as an object only misses a
# rewrite (harmless — resolveObjects still builds real objects); the dangerous direction (a real call
# rewritten) needs a value-context token before `{`, which a statement/`)` block never has.
## To objStartTok (t: Text) -> Bool:
    If t is equal to "=":
        Return true.
    If t is equal to "(":
        Return true.
    If t is equal to chr(91):
        Return true.
    If t is equal to ",":
        Return true.
    If t is equal to ":":
        Return true.
    If t is equal to "return":
        Return true.
    If t is equal to "?":
        Return true.
    If t is equal to "||":
        Return true.
    If t is equal to "&&":
        Return true.
    Return false.

## To topChar (stack: Text) -> Text:
    If stack is equal to "":
        Return "".
    Return item (length of stack) of stack.

## To isWordChar1 (t: Text) -> Bool:
    If length of t is less than 1:
        Return false.
    Let c be item 1 of t.
    If c is equal to "_":
        Return true.
    If c is equal to "$":
        Return true.
    If substringBefore("abcdefghijklmnopqrstuvwxyz", c) is not equal to "abcdefghijklmnopqrstuvwxyz":
        Return true.
    If substringBefore("ABCDEFGHIJKLMNOPQRSTUVWXYZ", c) is not equal to "ABCDEFGHIJKLMNOPQRSTUVWXYZ":
        Return true.
    Return false.

## To domStack (stack: Text, t: Text, prev: Text) -> Text:
    If t is equal to "(":
        Return concat(stack, "p").
    If t is equal to chr(91):
        Return concat(stack, "p").
    If t is equal to ")":
        Return popLast(stack).
    If t is equal to chr(93):
        Return popLast(stack).
    If t is equal to chr(123):
        If objStartTok(prev):
            Return concat(stack, "o").
        Return concat(stack, "b").
    If t is equal to chr(125):
        Return popLast(stack).
    Return stack.

## To atKeyPos (stack: Text, prev: Text) -> Bool:
    If topChar(stack) is not equal to "o":
        Return false.
    If prev is equal to chr(123):
        Return true.
    If prev is equal to ",":
        Return true.
    Return false.

## To domNext (toks: Seq of Text, j: Int) -> Text:
    If j is greater than length of toks:
        Return "".
    Return item j of toks.

## To domAppend (acc: Text, t: Text) -> Text:
    If acc is equal to "":
        Return t.
    Return concat(concat(acc, " "), t).

## To domWalk (toks: Seq of Text, i: Int, stack: Text, prev: Text, acc: Text) -> Text:
    If i is greater than length of toks:
        Return acc.
    Let t be item i of toks.
    If atKeyPos(stack, prev):
        If t is equal to "get":
            If isWordChar1(domNext(toks, i + 1)):
                If domNext(toks, i + 2) is equal to "(":
                    Let g1 be domAppend(acc, concat("__get_", domNext(toks, i + 1))).
                    Let g3 be domAppend(domAppend(g1, ":"), "function").
                    Return domWalk(toks, i + 2, stack, "function", g3).
        If t is equal to "set":
            If isWordChar1(domNext(toks, i + 1)):
                If domNext(toks, i + 2) is equal to "(":
                    Let s1 be domAppend(acc, concat("__set_", domNext(toks, i + 1))).
                    Let s3 be domAppend(domAppend(s1, ":"), "function").
                    Return domWalk(toks, i + 2, stack, "function", s3).
        If isWordChar1(t):
            If domNext(toks, i + 1) is equal to "(":
                Let m1 be domAppend(acc, t).
                Let m3 be domAppend(domAppend(m1, ":"), "function").
                Return domWalk(toks, i + 1, stack, "function", m3).
    Let newStack be domStack(stack, t, prev).
    Let newAcc be domAppend(acc, t).
    Return domWalk(toks, i + 1, newStack, t, newAcc).

## To desugarObjMethods (s: Text) -> Text:
    Return domWalk(split(s, " "), 1, "", "", "").

# Class-body ASI: a class field terminated by a newline (`class C { a\n b = 1\n m(){} }`) has no
# `;`, so after normJs collapses the newline classWalk can't tell where one member ends and the next
# begins. This pre-pass (raw source, after quote-normalization) inserts ` ; ` at each newline that is
# at the TOP level of a class body (brace/paren/bracket depth 0, not inside a string), unless the line
# clearly continues (ends in an operator / `{` / `,` / `(` etc). Scoped strictly to `class … { }`
# bodies — non-class code is returned untouched.
## To lastNonWs (s: Text, i: Int) -> Text:
    If i is less than 1:
        Return "".
    Let c be item i of s.
    If c is equal to " ":
        Return lastNonWs(s, i - 1).
    If c is equal to chr(10):
        Return lastNonWs(s, i - 1).
    If c is equal to chr(9):
        Return lastNonWs(s, i - 1).
    If c is equal to chr(13):
        Return lastNonWs(s, i - 1).
    Return c.

## To continuesLine (c: Text) -> Bool:
    Let conts be ["", ";", chr(123), ",", "(", chr(91), "=", "+", "-", "*", "/", "%", "&", "|", ".", ":", "?", "<", ">", "!"].
    Return conts contains c.

## To insertBodySemis (s: Text, i: Int, depth: Int, sm: Int, acc: Text) -> Text:
    If i is greater than length of s:
        Return acc.
    Let c be item i of s.
    If sm is equal to 1:
        If c is equal to chr(34):
            Return insertBodySemis(s, i + 1, depth, 0, concat(acc, c)).
        If c is equal to chr(92):
            If i is less than length of s:
                Let nx be item (i + 1) of s.
                Return insertBodySemis(s, i + 2, depth, 1, concat(concat(acc, c), nx)).
        Return insertBodySemis(s, i + 1, depth, 1, concat(acc, c)).
    If sm is equal to 2:
        If c is equal to chr(96):
            Return insertBodySemis(s, i + 1, depth, 0, concat(acc, c)).
        Return insertBodySemis(s, i + 1, depth, 2, concat(acc, c)).
    If c is equal to chr(34):
        Return insertBodySemis(s, i + 1, depth, 1, concat(acc, c)).
    If c is equal to chr(96):
        Return insertBodySemis(s, i + 1, depth, 2, concat(acc, c)).
    If c is equal to chr(123):
        Return insertBodySemis(s, i + 1, depth + 1, 0, concat(acc, c)).
    If c is equal to "(":
        Return insertBodySemis(s, i + 1, depth + 1, 0, concat(acc, c)).
    If c is equal to chr(91):
        Return insertBodySemis(s, i + 1, depth + 1, 0, concat(acc, c)).
    If c is equal to chr(125):
        Return insertBodySemis(s, i + 1, depth - 1, 0, concat(acc, c)).
    If c is equal to ")":
        Return insertBodySemis(s, i + 1, depth - 1, 0, concat(acc, c)).
    If c is equal to chr(93):
        Return insertBodySemis(s, i + 1, depth - 1, 0, concat(acc, c)).
    If c is equal to chr(10):
        If depth is equal to 0:
            If continuesLine(lastNonWs(concat(acc, ""), length of acc)):
                Return insertBodySemis(s, i + 1, depth, 0, concat(acc, " ")).
            Return insertBodySemis(s, i + 1, depth, 0, concat(acc, " ; ")).
        Return insertBodySemis(s, i + 1, depth, 0, concat(acc, " ")).
    Return insertBodySemis(s, i + 1, depth, 0, concat(acc, c)).

## To classBodySemis (s: Text) -> Text:
    If substringBefore(s, "class ") is equal to s:
        Return s.
    Let bef be substringBefore(s, "class ").
    Let aft be substringAfter(s, "class ").
    Let head be substringBefore(aft, chr(123)).
    Let afterBrace be substringAfter(aft, chr(123)).
    Let body be braceBody(afterBrace, 1, 0, "").
    Let remainder be strSliceLoop(afterBrace, (length of body) + 2, length of afterBrace, "").
    Let fixedBody be insertBodySemis(concat(body, ""), 1, 0, 0, "").
    Return concat(concat(concat(concat(concat(concat(bef, "class "), head), chr(123)), fixedBody), chr(125)), classBodySemis(concat(remainder, ""))).

## To normalizeJs (s: Text) -> Text:
    Let sq be classBodySemis(convertQuotes(s, 1, 0, "")).
    Let rx be desugarRegexLits(sq, 1, "", false, "", "").
    Let templated be desugarTemplates(rx, 1, 0, 0, "").
    Let normed be joinNonEmpty(split(normJs(templated, 1, false, ""), " "), 1, "").
    Return joinNonEmpty(split(desugarObjMethods(desugarClass(desugarArrows(stripAsync(desugarGenerators(normed))))), " "), 1, "").

# --- Regex engine (E4): a backtracking matcher in LOGOS ---
# JS regex needs backreferences/lookahead that Rust's regex crate lacks, so the matcher is hand-
# rolled here. matchHere recursively matches the pattern from a position against the text, with
# greedy `* + ?` backtracking; atoms are a literal, `.`, an escape (\d \w \s and their negations),
# or a `[...]` class (ranges + negation). `^` anchors at reTest; `$` is checked in matchHere.
## To reNot (b: Bool) -> Bool:
    If b:
        Return false.
    Return true.

## To reDigit (ch: Text) -> Bool:
    If ord(ch) is greater than 47:
        If ord(ch) is less than 58:
            Return true.
    Return false.

## To reWord (ch: Text) -> Bool:
    If reDigit(ch):
        Return true.
    If ch is equal to "_":
        Return true.
    If ord(ch) is greater than 64:
        If ord(ch) is less than 91:
            Return true.
    If ord(ch) is greater than 96:
        If ord(ch) is less than 123:
            Return true.
    Return false.

## To reSpace (ch: Text) -> Bool:
    If ord(ch) is equal to 32:
        Return true.
    If ord(ch) is equal to 9:
        Return true.
    If ord(ch) is equal to 10:
        Return true.
    If ord(ch) is equal to 13:
        Return true.
    Return false.

## To classEnd (pat: Text, i: Int) -> Int:
    If i is greater than length of pat:
        Return i.
    If item i of pat is equal to chr(93):
        Return i.
    Return classEnd(pat, i + 1).

## To classContains (pat: Text, i: Int, endPos: Int, ch: Text) -> Bool:
    If i is greater than (endPos - 1):
        Return false.
    If (i + 2) is less than endPos:
        If item (i + 1) of pat is equal to "-":
            If ord(ch) is greater than (ord(item i of pat) - 1):
                If ord(ch) is less than (ord(item (i + 2) of pat) + 1):
                    Return true.
            Return classContains(pat, i + 3, endPos, ch).
    If item i of pat is equal to ch:
        Return true.
    Return classContains(pat, i + 1, endPos, ch).

## To reClassMatch (pat: Text, i: Int, ch: Text) -> Bool:
    If item i of pat is equal to "^":
        Return reNot(classContains(pat, i + 1, classEnd(pat, i), ch)).
    Return classContains(pat, i, classEnd(pat, i), ch).

## To escapeMatches (e: Text, ch: Text) -> Bool:
    If e is equal to "d":
        Return reDigit(ch).
    If e is equal to "w":
        Return reWord(ch).
    If e is equal to "s":
        Return reSpace(ch).
    If e is equal to "D":
        Return reNot(reDigit(ch)).
    If e is equal to "W":
        Return reNot(reWord(ch)).
    If e is equal to "S":
        Return reNot(reSpace(ch)).
    Return e is equal to ch.

## To atomLen (pat: Text, pi: Int) -> Int:
    If item pi of pat is equal to chr(92):
        Return 2.
    If item pi of pat is equal to chr(91):
        Return (classEnd(pat, pi + 1) - pi) + 1.
    Return 1.

## To atomMatches (pat: Text, pi: Int, ch: Text) -> Bool:
    Let c be item pi of pat.
    If c is equal to ".":
        Return true.
    If c is equal to chr(92):
        Return escapeMatches(item (pi + 1) of pat, ch).
    If c is equal to chr(91):
        Return reClassMatch(pat, pi + 1, ch).
    Return c is equal to ch.

## To starBacktrack (pat: Text, npi: Int, text: Text, ti: Int, k: Int) -> Int:
    Let r be matchHere(pat, npi, text, ti + k).
    If r is greater than 0:
        Return r.
    If k is equal to 0:
        Return 0.
    Return starBacktrack(pat, npi, text, ti, k - 1).

## To countAtoms (pat: Text, api: Int, text: Text, ti: Int, k: Int) -> Int:
    If (ti + k) is greater than length of text:
        Return k.
    If atomMatches(pat, api, item (ti + k) of text):
        Return countAtoms(pat, api, text, ti, k + 1).
    Return k.

## To matchHere (pat: Text, pi: Int, text: Text, ti: Int) -> Int:
    If pi is greater than length of pat:
        Return ti.
    If item pi of pat is equal to "$":
        If pi is equal to length of pat:
            If ti is greater than length of text:
                Return ti.
            Return 0.
    Let alen be atomLen(pat, pi).
    Let aend be pi + alen.
    If aend is less than (length of pat + 1):
        If item aend of pat is equal to "*":
            Return starBacktrack(pat, aend + 1, text, ti, countAtoms(pat, pi, text, ti, 0)).
        If item aend of pat is equal to "+":
            If ti is greater than length of text:
                Return 0.
            If atomMatches(pat, pi, item ti of text):
                Return starBacktrack(pat, aend + 1, text, ti + 1, countAtoms(pat, pi, text, ti + 1, 0)).
            Return 0.
        If item aend of pat is equal to "?":
            If ti is less than (length of text + 1):
                If atomMatches(pat, pi, item ti of text):
                    Let rq be matchHere(pat, aend + 1, text, ti + 1).
                    If rq is greater than 0:
                        Return rq.
            Return matchHere(pat, aend + 1, text, ti).
    If ti is greater than length of text:
        Return 0.
    If atomMatches(pat, pi, item ti of text):
        Return matchHere(pat, aend, text, ti + 1).
    Return 0.

## To reSearchFrom (pat: Text, text: Text, ti: Int) -> Int:
    If matchHere(pat, 1, text, ti) is greater than 0:
        Return ti.
    If ti is greater than length of text:
        Return 0.
    Return reSearchFrom(pat, text, ti + 1).

## To reTest (pat: Text, text: Text) -> Bool:
    If startsWith(pat, "^"):
        Return matchHere(pat, 2, text, 1) is greater than 0.
    Return reSearchFrom(pat, text, 1) is greater than 0.

# A RegExp value is a heap object carrying its source pattern and flags; isRegex classifies it.
# reFind returns the first matched substring in text ("" for no match). reMatchEnd finds where the
# match starting at `start` ends (matchHere from pattern start, honoring a leading ^).
## To newRegex (src: Text, flags: Text) -> Text:
    Return objSet(objSet(newObjRef(concat(tagObj (), tagObjEnd ())), "__regex_src", concat(tagStr (), src)), "__regex_flags", concat(tagStr (), flags)).

## To isRegex (v: Text) -> Bool:
    If isObjRef(v):
        Return objGet(concat(v, ""), "__regex_src") is not equal to "undefined".
    Return false.

## To reSearchStart (pat: Text, text: Text) -> Int:
    If startsWith(pat, "^"):
        If matchHere(pat, 2, text, 1) is greater than 0:
            Return 1.
        Return 0.
    Return reSearchFrom(pat, text, 1).

## To reMatchEnd (pat: Text, text: Text, start: Int) -> Int:
    If startsWith(pat, "^"):
        Return matchHere(pat, 2, text, start).
    Return matchHere(pat, 1, text, start).

## To reFind (pat: Text, text: Text) -> Text:
    Let start be reSearchStart(pat, text).
    If start is equal to 0:
        Return "".
    Return strSliceLoop(text, start, (reMatchEnd(pat, text, start) - 1), "").

## To reFlagsArg (rargs: Seq of Text, env: Text) -> Text:
    If length of rargs is less than 2:
        Return "".
    If trim(item 2 of rargs) is equal to "":
        Return "".
    Return decodeStr(materialize(jsEvalIn(trim(item 2 of rargs), env))).

## To reHasG (flags: Text) -> Bool:
    Return substringBefore(flags, "g") is not equal to flags.

# reReplaceLoop rebuilds text with each match replaced by `repl`, operating on DECODED text (the
# regex engine and .replace/.split all decode first). Non-global replaces the first match; global
# walks left-to-right. A zero-width match (endp <= start) would loop forever, so global stops after
# one substitution there. reSplit reuses this: replace every match with chr(0), then strSplit on it.
## To reReplaceLoop (pat: Text, text: Text, repl: Text, global: Bool, acc: Text) -> Text:
    Let start be reSearchStart(pat, text).
    If start is equal to 0:
        Return concat(acc, text).
    Let endp be reMatchEnd(pat, text, start).
    Let before be strSliceLoop(text, 1, start - 1, "").
    Let after be strSliceLoop(text, endp, length of text, "").
    If global is equal to false:
        Return concat(acc, concat(before, concat(repl, after))).
    If endp is greater than start:
        Let nextAcc be concat(acc, concat(before, concat(repl, ""))).
        Return reReplaceLoop(pat, after, repl, true, nextAcc).
    Return concat(acc, concat(before, concat(repl, after))).

# Inverse of decodeStr: re-encode a raw string's structural characters back into the byte vocabulary,
# so a value produced from DECODED text (regex replace/split results) is a well-formed jsint string.
## To encodeStr (s: Text) -> Text:
    Let a be replaceAll(s, " ", encSpace ()).
    Let b be replaceAll(a, chr(91), encBrkL ()).
    Let c be replaceAll(b, chr(93), encBrkR ()).
    Let d be replaceAll(c, chr(123), encBraceL ()).
    Let e be replaceAll(d, chr(125), encBraceR ()).
    Let f be replaceAll(e, "(", encParenL ()).
    Let g be replaceAll(f, ")", encParenR ()).
    Let h be replaceAll(g, chr(34), encQuote ()).
    Let ii be replaceAll(h, chr(92), encBackslash ()).
    Return replaceAll(ii, chr(10), encNewline ()).

## To reReplace (pat: Text, text: Text, repl: Text, flags: Text) -> Text:
    Return concat(tagStr (), encodeStr(reReplaceLoop(pat, text, repl, reHasG(flags), ""))).

# .replace(regex, fn): like reReplaceLoop, but each match's replacement is fn(match, offset) — the
# callback is invoked per match (via callFnIdx, match bound to param 1, offset to param 2) and its
# returned string (decoded) spliced in. First match only, or all under the g flag.
## To reReplaceFnLoop (pat: Text, text: Text, fnval: Text, global: Bool, env: Text, acc: Text) -> Text:
    Let start be reSearchStart(pat, text).
    If start is equal to 0:
        Return concat(acc, text).
    Let endp be reMatchEnd(pat, text, start).
    Let before be strSliceLoop(text, 1, start - 1, "").
    Let matched be strSliceLoop(text, start, endp - 1, "").
    Let after be strSliceLoop(text, endp, length of text, "").
    Let repl be decodeStr(materialize(callFnIdx(concat(fnval, ""), concat(tagStr (), matched), toText(start - 1), concat(env, "")))).
    If global is equal to false:
        Return concat(acc, concat(before, concat(repl, after))).
    If endp is greater than start:
        Let nextAcc be concat(acc, concat(before, repl)).
        Return reReplaceFnLoop(pat, after, fnval, true, env, nextAcc).
    Return concat(acc, concat(before, concat(repl, after))).

## To reReplaceFn (pat: Text, text: Text, fnval: Text, flags: Text, env: Text) -> Text:
    Return concat(tagStr (), encodeStr(reReplaceFnLoop(pat, text, fnval, reHasG(flags), env, ""))).

## To reSplit (pat: Text, text: Text) -> Text:
    Return strSplit(reReplaceLoop(pat, text, chr(0), true, ""), chr(0)).

# --- Map / Set (E5) ---
# A Map is a heap object with parallel __map_keys / __map_vals arrays (insertion order preserved,
# any key type — keys compared by materialized value); a Set is a heap object with a __set_vals
# array. Mutators write THROUGH the heap handle (arrays are refs), so a Map/Set aliased by another
# binding sees updates.
## To newMap () -> Text:
    Return objSet(objSet(newObjRef(concat(tagObj (), tagObjEnd ())), "__map_keys", newArr(concat(tagArr (), tagArrEnd ()))), "__map_vals", newArr(concat(tagArr (), tagArrEnd ()))).

## To isMap (v: Text) -> Bool:
    If isObjRef(v):
        Return objGet(concat(v, ""), "__map_keys") is not equal to "undefined".
    Return false.

## To mapKeyIdx (keys: Seq of Text, i: Int, k: Text) -> Int:
    If i is greater than length of keys:
        Return 0.
    If materialize(item i of keys) is equal to materialize(concat(k, "")):
        Return i.
    Return mapKeyIdx(keys, i + 1, k).

## To mapSet (m: Text, k: Text, v: Text) -> Text:
    Let idx be mapKeyIdx(arrElements(objGet(concat(m, ""), "__map_keys")), 1, concat(k, "")).
    If idx is greater than 0:
        Let du be arrSetIdx(objGet(concat(m, ""), "__map_vals"), idx - 1, concat(v, "")).
        Return concat(m, "").
    Let dk be arrPush(objGet(concat(m, ""), "__map_keys"), concat(k, "")).
    Let dv be arrPush(objGet(concat(m, ""), "__map_vals"), concat(v, "")).
    Return concat(m, "").

## To mapGet (m: Text, k: Text) -> Text:
    Let idx be mapKeyIdx(arrElements(objGet(concat(m, ""), "__map_keys")), 1, concat(k, "")).
    If idx is equal to 0:
        Return "undefined".
    Return item idx of arrElements(objGet(concat(m, ""), "__map_vals")).

# Remove the element at 1-based idx from an array (in place via mutArr — the heap ref is preserved,
# so a Map/Set's parallel key/val arrays stay wired). mapDelete/setDelete return "true"/"false" per JS.
## To arrRemoveAtLoop (els: Seq of Text, i: Int, skip: Int, acc: Text) -> Text:
    If i is greater than length of els:
        Return acc.
    If i is equal to skip:
        Return arrRemoveAtLoop(els, i + 1, skip, acc).
    Let el be item i of els.
    If acc is equal to "":
        Return arrRemoveAtLoop(els, i + 1, skip, el).
    Return arrRemoveAtLoop(els, i + 1, skip, concat(concat(acc, tagArrSep ()), el)).

## To arrRemoveAt (arrval: Text, idx: Int) -> Text:
    Let els be arrElements(arrval).
    Return mutArr(concat(arrval, ""), concat(concat(tagArr (), arrRemoveAtLoop(els, 1, idx, "")), tagArrEnd ())).

## To mapDelete (m: Text, k: Text) -> Text:
    Let idx be mapKeyIdx(arrElements(objGet(concat(m, ""), "__map_keys")), 1, concat(k, "")).
    If idx is equal to 0:
        Return "false".
    Let dk be arrRemoveAt(objGet(concat(m, ""), "__map_keys"), idx).
    Let dv be arrRemoveAt(objGet(concat(m, ""), "__map_vals"), idx).
    Return "true".

## To setDelete (s: Text, v: Text) -> Text:
    Let idx be mapKeyIdx(arrElements(objGet(concat(s, ""), "__set_vals")), 1, concat(v, "")).
    If idx is equal to 0:
        Return "false".
    Let dv be arrRemoveAt(objGet(concat(s, ""), "__set_vals"), idx).
    Return "true".

# Map/Set forEach: invoke the callback per entry — cb(value, key) for a Map, cb(value, value) for a
# Set (mirrors arrForEach; heap-mutating callbacks persist, scalar accumulation does not — same as
# arrays). Returns undefined. `Let vv`/`kk` first to dodge the arg-order E0382 borrow.
## To mapForEachLoop (keys: Seq of Text, vals: Seq of Text, i: Int, fnval: Text, env: Text) -> Text:
    If i is greater than length of keys:
        Return "undefined".
    Let vv be item i of vals.
    Let kk be item i of keys.
    Let r be callFnIdx(concat(fnval, ""), vv, kk, concat(env, "")).
    Return mapForEachLoop(keys, vals, i + 1, fnval, env).

## To mapForEach (m: Text, fnval: Text, env: Text) -> Text:
    Return mapForEachLoop(arrElements(objGet(concat(m, ""), "__map_keys")), arrElements(objGet(concat(m, ""), "__map_vals")), 1, fnval, env).

## To setForEachLoop (vals: Seq of Text, i: Int, fnval: Text, env: Text) -> Text:
    If i is greater than length of vals:
        Return "undefined".
    Let vv be item i of vals.
    Let r be callFnIdx(concat(fnval, ""), vv, vv, concat(env, "")).
    Return setForEachLoop(vals, i + 1, fnval, env).

## To setForEach (s: Text, fnval: Text, env: Text) -> Text:
    Return setForEachLoop(arrElements(objGet(concat(s, ""), "__set_vals")), 1, fnval, env).

# A Set: __set_vals holds its distinct values.
## To newSetFrom (arrval: Text) -> Text:
    Let s be objSet(newObjRef(concat(tagObj (), tagObjEnd ())), "__set_vals", newArr(concat(tagArr (), tagArrEnd ()))).
    Return setAddAll(concat(s, ""), arrElements(concat(arrval, "")), 1).

## To setAddAll (s: Text, vals: Seq of Text, i: Int) -> Text:
    If i is greater than length of vals:
        Return concat(s, "").
    Let d be setAdd(concat(s, ""), item i of vals).
    Return setAddAll(concat(s, ""), vals, i + 1).

## To isSet (v: Text) -> Bool:
    If isObjRef(v):
        Return objGet(concat(v, ""), "__set_vals") is not equal to "undefined".
    Return false.

## To setAdd (s: Text, v: Text) -> Text:
    If mapKeyIdx(arrElements(objGet(concat(s, ""), "__set_vals")), 1, concat(v, "")) is greater than 0:
        Return concat(s, "").
    Let d be arrPush(objGet(concat(s, ""), "__set_vals"), concat(v, "")).
    Return concat(s, "").

## To collSize (v: Text) -> Int:
    If isMap(v):
        Return length of arrElements(objGet(concat(v, ""), "__map_keys")).
    Return length of arrElements(objGet(concat(v, ""), "__set_vals")).

## To jsExec (program: Text) -> Text:
    Return decodeStr(materialize(jsRun(normalizeJs(program)))).

## To heapProbe () -> Text:
    Let h be heapAlloc("v1").
    Let alias be concat(h, "").
    heapSet(alias, "v2").
    Return heapGet(h).

# console.log renders a top-level BigInt with a trailing `n` (its inspect form) — distinct from
# String(10n) / `10n + ""`, which drop it. Other values format via materialize as usual.
## To bigDisplay (v: Text) -> Text:
    If startsWith(v, tagBig ()):
        Return concat(substringAfter(v, tagBig ()), "n").
    Return materialize(v).

## To consoleFmt (args: Seq of Text, i: Int, env: Text, acc: Text) -> Text:
    If i is greater than length of args:
        Return acc.
    Let piece be bigDisplay(jsEvalIn(trim(item i of args), concat(env, ""))).
    If i is equal to 1:
        Return consoleFmt(args, i + 1, env, piece).
    Return consoleFmt(args, i + 1, env, concat(concat(acc, " "), piece)).

## To doConsoleLog (logArg: Text, env: Text) -> Text:
    Let formatted be decodeStr(consoleFmt(patFields(logArg), 1, env, "")).
    If throwPending() is equal to "1":
        Return env.
    puts(concat(formatted, chr(10))).
    Return env.

## To doConsoleErr (logArg: Text, env: Text) -> Text:
    eputs(decodeStr(consoleFmt(patFields(logArg), 1, env, ""))).
    Return env.

## To doExit (arg: Text, env: Text) -> Text:
    If trim(arg) is equal to "":
        exitWith(0).
    exitWith(safeInt(materialize(jsEvalIn(trim(arg), env)))).
    Return env.

## To runSink (finalEnv: Text) -> Text:
    Return "".

## To argvBuild (args: Seq of Text, i: Int, acc: Text) -> Text:
    If i is greater than length of args:
        Return acc.
    Let el be concat(tagStr (), item i of args).
    Return argvBuild(args, i + 1, concat(concat(acc, tagArrSep ()), el)).

# --- E6 modules: import / export, multi-file resolution ---
# ESM is handled as a source transform + a runtime module registry. A module's imports are resolved
# and its dependencies evaluated FIRST (depth-first, each exactly once — the native module cache keyed
# by resolved path is the once-guard and the cycle break), then the module's own body runs with the
# `export` keywords stripped, and finally its exported names are lifted into an exports env (the same
# `name=val;` shape env uses). Because the object heap is a shared thread-local, a value exported by
# one module is a handle that stays valid when bound into the importer — no serialization across the
# module boundary. `import`/`export` are top-level statements, so this works line-oriented on the raw
# source (a multi-line `import { … } from "…"` is first folded to one logical line by joinImportLines).

## To countQuoteChars (s: Text, i: Int, n: Int) -> Int:
    If i is greater than length of s:
        Return n.
    Let c be item i of s.
    If c is equal to chr(34):
        Return countQuoteChars(s, i + 1, n + 1).
    If c is equal to chr(39):
        Return countQuoteChars(s, i + 1, n + 1).
    Return countQuoteChars(s, i + 1, n).

## To importComplete (s: Text) -> Bool:
    Return countQuoteChars(concat(s, ""), 1, 0) is greater than 1.

## To joinImportLines (lines: Seq of Text, i: Int, pending: Text, acc: Text) -> Text:
    If i is greater than length of lines:
        If pending is equal to "":
            Return acc.
        Return concat(acc, pending).
    Let ln be item i of lines.
    If pending is not equal to "":
        Let merged be concat(concat(pending, " "), trim(ln)).
        If importComplete(merged):
            Return joinImportLines(lines, i + 1, "", concat(concat(acc, merged), chr(10))).
        Return joinImportLines(lines, i + 1, merged, acc).
    If startsWith(trim(ln), "import "):
        If importComplete(ln) is equal to false:
            Return joinImportLines(lines, i + 1, trim(ln), acc).
    Return joinImportLines(lines, i + 1, "", concat(concat(acc, ln), chr(10))).

## To modIdent (s: Text) -> Text:
    Let a be replaceAll(replaceAll(replaceAll(replaceAll(replaceAll(s, "=", " "), "(", " "), ";", " "), ":", " "), chr(123), " ").
    Return trim(item 1 of split(trim(a), " ")).

## To stringLit (s: Text) -> Text:
    If substringBefore(s, chr(34)) is not equal to s:
        Return substringBefore(substringAfter(s, chr(34)), chr(34)).
    If substringBefore(s, chr(39)) is not equal to s:
        Return substringBefore(substringAfter(s, chr(39)), chr(39)).
    Return "".

## To importSpec (t: Text) -> Text:
    Return stringLit(t).

## To importClause (t: Text) -> Text:
    Let afterKw be substringAfter(t, "import ").
    If substringBefore(afterKw, " from ") is not equal to afterKw:
        Return trim(substringBefore(afterKw, " from ")).
    Return "".

## To bindNamedImports (parts: Seq of Text, i: Int, exportsBlob: Text, env: Text) -> Text:
    If i is greater than length of parts:
        Return env.
    Let p be trim(item i of parts).
    If p is equal to "":
        Return bindNamedImports(parts, i + 1, exportsBlob, env).
    If substringBefore(p, " as ") is not equal to p:
        Let orig be trim(substringBefore(p, " as ")).
        Let local be trim(substringAfter(p, " as ")).
        Return bindNamedImports(parts, i + 1, concat(exportsBlob, ""), envSet(env, local, envGet(exportsBlob, orig))).
    Return bindNamedImports(parts, i + 1, concat(exportsBlob, ""), envSet(env, p, envGet(exportsBlob, p))).

## To nsBuild (entries: Seq of Text, i: Int, obj: Text) -> Text:
    If i is greater than length of entries:
        Return obj.
    Let e be item i of entries.
    If e is equal to "":
        Return nsBuild(entries, i + 1, obj).
    Let nm be substringBefore(e, "=").
    If nm is equal to e:
        Return nsBuild(entries, i + 1, obj).
    Return nsBuild(entries, i + 1, objSet(obj, nm, substringAfter(e, "="))).

## To namespaceObj (exportsBlob: Text) -> Text:
    Return nsBuild(split(exportsBlob, ";"), 1, newObjRef(concat(tagObj (), tagObjEnd ()))).

## To bindImports (clause: Text, exportsBlob: Text, env: Text) -> Text:
    If clause is equal to "":
        Return env.
    If startsWith(clause, chr(123)):
        Let inner be substringBefore(substringAfter(clause, chr(123)), chr(125)).
        Return bindNamedImports(split(inner, ","), 1, exportsBlob, env).
    If startsWith(clause, "* as "):
        Return envSet(env, trim(substringAfter(clause, "* as ")), namespaceObj(exportsBlob)).
    If substringBefore(clause, ",") is not equal to clause:
        Let defName be trim(substringBefore(clause, ",")).
        Let restClause be trim(substringAfter(clause, ",")).
        Return bindImports(restClause, concat(exportsBlob, ""), envSet(env, defName, envGet(exportsBlob, "default"))).
    Return envSet(env, trim(clause), envGet(exportsBlob, "default")).

## To applyImports (lines: Seq of Text, i: Int, dir: Text, env: Text) -> Text:
    If i is greater than length of lines:
        Return env.
    Let t be trim(item i of lines).
    If startsWith(t, "import "):
        Let spec be importSpec(t).
        If spec is equal to "":
            Return applyImports(lines, i + 1, dir, env).
        Let exportsBlob be loadModule(pathResolve(dir, spec)).
        Return applyImports(lines, i + 1, dir, bindImports(importClause(t), exportsBlob, env)).
    If startsWith(t, "export "):
        If importSpec(t) is not equal to "":
            Let reeval be loadModule(pathResolve(dir, importSpec(t))).
            Return applyImports(lines, i + 1, dir, env).
    Return applyImports(lines, i + 1, dir, env).

## To stripModLines (lines: Seq of Text, i: Int, acc: Text) -> Text:
    If i is greater than length of lines:
        Return acc.
    Let ln be item i of lines.
    Let t be trim(ln).
    If startsWith(t, "import "):
        Return stripModLines(lines, i + 1, acc).
    If startsWith(t, "export default "):
        Let rest be substringAfter(t, "export default ").
        If defaultBindingName(substringAfter(t, "export default ")) is not equal to "__default__":
            Return stripModLines(lines, i + 1, concat(concat(acc, rest), chr(10))).
        Return stripModLines(lines, i + 1, concat(concat(acc, concat("const __default__ = ", rest)), chr(10))).
    If startsWith(t, concat("export ", chr(123))):
        Return stripModLines(lines, i + 1, acc).
    If startsWith(t, "export "):
        Return stripModLines(lines, i + 1, concat(concat(acc, substringAfter(ln, "export ")), chr(10))).
    Return stripModLines(lines, i + 1, concat(concat(acc, ln), chr(10))).

## To stripModuleSyntax (src: Text) -> Text:
    Return stripModLines(split(src, chr(10)), 1, "").

## To defaultBindingName (rest: Text) -> Text:
    If startsWith(rest, "function "):
        Let nm be modIdent(substringAfter(rest, "function ")).
        If nm is not equal to "":
            Return nm.
    If startsWith(rest, "class "):
        Let nc be modIdent(substringAfter(rest, "class ")).
        If nc is not equal to "":
            Return nc.
    Return "__default__".

## To addExportList (parts: Seq of Text, i: Int, env: Text, acc: Text) -> Text:
    If i is greater than length of parts:
        Return acc.
    Let p be trim(item i of parts).
    If p is equal to "":
        Return addExportList(parts, i + 1, env, acc).
    If substringBefore(p, " as ") is not equal to p:
        Let local be trim(substringBefore(p, " as ")).
        Let pub be trim(substringAfter(p, " as ")).
        Return addExportList(parts, i + 1, concat(env, ""), envSet(acc, pub, envGet(env, local))).
    Return addExportList(parts, i + 1, concat(env, ""), envSet(acc, p, envGet(env, p))).

## To mergeAllExports (entries: Seq of Text, i: Int, acc: Text) -> Text:
    If i is greater than length of entries:
        Return acc.
    Let e be item i of entries.
    If e is equal to "":
        Return mergeAllExports(entries, i + 1, acc).
    Let nm be substringBefore(e, "=").
    If nm is equal to e:
        Return mergeAllExports(entries, i + 1, acc).
    If nm is equal to "default":
        Return mergeAllExports(entries, i + 1, acc).
    Return mergeAllExports(entries, i + 1, envSet(acc, nm, substringAfter(e, "="))).

## To collectExports (lines: Seq of Text, i: Int, dir: Text, env: Text, acc: Text) -> Text:
    If i is greater than length of lines:
        Return acc.
    Let t be trim(item i of lines).
    If startsWith(t, "export * from"):
        Let ebAll be loadModule(pathResolve(dir, importSpec(t))).
        Return collectExports(lines, i + 1, concat(dir, ""), concat(env, ""), mergeAllExports(split(ebAll, ";"), 1, acc)).
    If startsWith(t, "export "):
      If importSpec(t) is not equal to "":
        Let inner be substringBefore(substringAfter(t, chr(123)), chr(125)).
        Let ebList be loadModule(pathResolve(dir, importSpec(t))).
        Return collectExports(lines, i + 1, concat(dir, ""), concat(env, ""), addExportList(split(inner, ","), 1, ebList, acc)).
    If startsWith(t, "export default "):
        Return collectExports(lines, i + 1, concat(dir, ""), concat(env, ""), envSet(acc, "default", envGet(env, defaultBindingName(substringAfter(t, "export default "))))).
    If startsWith(t, concat("export ", chr(123))):
        Let inner2 be substringBefore(substringAfter(t, chr(123)), chr(125)).
        Return collectExports(lines, i + 1, concat(dir, ""), concat(env, ""), addExportList(split(inner2, ","), 1, env, acc)).
    If startsWith(t, "export function "):
        Let nf be modIdent(substringAfter(t, "export function ")).
        Return collectExports(lines, i + 1, concat(dir, ""), concat(env, ""), envSet(acc, nf, envGet(env, nf))).
    If startsWith(t, "export class "):
        Let nc be modIdent(substringAfter(t, "export class ")).
        Return collectExports(lines, i + 1, concat(dir, ""), concat(env, ""), envSet(acc, nc, envGet(env, nc))).
    If startsWith(t, "export const "):
        Let nk be modIdent(substringAfter(t, "export const ")).
        Return collectExports(lines, i + 1, concat(dir, ""), concat(env, ""), envSet(acc, nk, envGet(env, nk))).
    If startsWith(t, "export let "):
        Let nl be modIdent(substringAfter(t, "export let ")).
        Return collectExports(lines, i + 1, concat(dir, ""), concat(env, ""), envSet(acc, nl, envGet(env, nl))).
    If startsWith(t, "export var "):
        Let nv be modIdent(substringAfter(t, "export var ")).
        Return collectExports(lines, i + 1, concat(dir, ""), concat(env, ""), envSet(acc, nv, envGet(env, nv))).
    Return collectExports(lines, i + 1, dir, env, acc).

## To runModuleBody (src: Text, dir: Text, baseEnv: Text) -> Text:
    Let joined be joinImportLines(split(src, chr(10)), 1, "", "").
    Let importedEnv be applyImports(split(joined, chr(10)), 1, dir, baseEnv).
    Let body be stripModuleSyntax(joined).
    Return runBlock(split(splitTop(normalizeJs(body), 1, 0, ""), chr(10)), 1, importedEnv).

## To loadModule (resolved: Text) -> Text:
    If moduleCacheHas(resolved) is equal to "1":
        Return moduleCacheGet(resolved).
    Let guard be moduleCacheSet(resolved, "").
    Let msrc be readFile(resolved).
    Let joined be joinImportLines(split(msrc, chr(10)), 1, "", "").
    Let menv be runModuleBody(msrc, pathDir(resolved), "").
    Let exportsBlob be collectExports(split(joined, chr(10)), 1, pathDir(resolved), menv, "").
    Let done be moduleCacheSet(resolved, exportsBlob).
    Return exportsBlob.

# An uncaught value thrown at the top level (or propagated out of a called function) is Node/bun-fatal:
# print it to stderr and exit non-zero. An Error object renders as `name: message`; any other value
# renders through its display. This is both runtime-correct and the pass/fail signal the test262 runner
# relies on (a test that fails throws a Test262Error, which must surface as a non-zero exit).
## To formatThrown (v: Text) -> Text:
    If isObjRef(concat(v, "")):
        Let nm be objGet(concat(v, ""), "name").
        If nm is not equal to "undefined":
            Return concat(concat(materialize(nm), ": "), materialize(objGet(concat(v, ""), "message"))).
        Let msg be objGet(concat(v, ""), "message").
        If msg is not equal to "undefined":
            Return materialize(msg).
    Return decodeStr(materialize(concat(v, ""))).

## To jsRunFile (src: Text, argv: Text) -> Text:
    Return jsRunFileIn(src, argv, "").

## To jsRunFileIn (src: Text, argv: Text, dir: Text) -> Text:
    Let procObj be objSet(newObjRef(concat(tagObj (), tagObjEnd ())), "argv", argv).
    Let env0 be envSet("", "process", procObj).
    Let finalEnv be runModuleBody(src, dir, env0).
    Let drained be drainMicrotasks("", concat(finalEnv, "")).
    If hasThrow(concat(finalEnv, "")):
        eputs(concat(formatThrown(envGet(concat(finalEnv, ""), "__throw")), chr(10))).
        exitWith(1).
        Return "".
    If throwPending() is equal to "1":
        eputs(concat(formatThrown(throwGet()), chr(10))).
        exitWith(1).
        Return "".
    Return runSink(finalEnv).

## To looksLikeScript (cmd: Text) -> Bool:
    If strEndsWith(cmd, ".js"):
        Return true.
    If strEndsWith(cmd, ".mjs"):
        Return true.
    If strEndsWith(cmd, ".cjs"):
        Return true.
    If strEndsWith(cmd, ".ts"):
        Return true.
    Return false.

## To secondArg (xs: Seq of Text) -> Text:
    If length of xs is greater than 1:
        Return item 2 of xs.
    Return "".

## To isSubcommand (cmd: Text) -> Bool:
    Let subcommands be ["install", "i", "add", "a", "remove", "rm", "update", "upgrade", "outdated", "link", "unlink", "pm", "patch", "publish", "audit", "why", "info", "run", "test", "build", "x", "bunx", "create", "c", "init", "repl", "exec", "lint", "feedback", "completions", "discord"].
    If subcommands contains cmd:
        Return true.
    Return false.

## To startsWithDash (s: Text) -> Bool:
    If length of s is greater than 0:
        If item 1 of s is equal to "-":
            Return true.
    Return false.

## Main
Let arguments be args().
Let cmd be secondArg(arguments).
If cmd is equal to "--version":
    Show "1.4.0".
Otherwise If cmd is equal to "-v":
    Show "1.4.0".
Otherwise If cmd is equal to "--revision":
    Show "1.4.0-canary.1+43ee03834".
Otherwise If cmd is equal to "__semver-compare":
    Let versionA be item 3 of arguments.
    Let versionB be item 4 of arguments.
    Show orderingToInt(compareVersions(versionA, versionB)).
Otherwise If cmd is equal to "__semver-satisfies":
    Let theVersion be item 3 of arguments.
    Let theRange be item 4 of arguments.
    If satisfies(theVersion, theRange):
        Show "true".
    Otherwise:
        Show "false".
Otherwise If cmd is equal to "__semver-max":
    Show maxSatisfying(item 3 of arguments, item 4 of arguments).
Otherwise If cmd is equal to "__semver-min":
    Show minSatisfying(item 3 of arguments, item 4 of arguments).
Otherwise If cmd is equal to "__glob":
    If glob(item 3 of arguments, item 4 of arguments):
        Show "true".
    Otherwise:
        Show "false".
Otherwise If cmd is equal to "__glob-path":
    If globPath(item 3 of arguments, item 4 of arguments):
        Show "true".
    Otherwise:
        Show "false".
Otherwise If cmd is equal to "__toml-get":
    Show tomlGet(item 3 of arguments, item 4 of arguments).
Otherwise If cmd is equal to "__base64":
    Show base64Encode(item 3 of arguments).
Otherwise If cmd is equal to "__base64-decode":
    Show base64Decode(item 3 of arguments).
Otherwise If cmd is equal to "__hex":
    Show toHex(item 3 of arguments).
Otherwise If cmd is equal to "__hex-decode":
    Show fromHex(item 3 of arguments).
Otherwise If cmd is equal to "__js-eval":
    Show decodeStr(materialize(jsEvalTernary(item 3 of arguments))).
Otherwise If cmd is equal to "__js-run":
    Show decodeStr(materialize(jsRun(item 3 of arguments))).
Otherwise If cmd is equal to "__js":
    Show jsExec(item 3 of arguments).
Otherwise If cmd is equal to "__heap-probe":
    Show heapProbe().
Otherwise If cmd is equal to "__regex-test":
    Show cmpResult(reTest(item 3 of arguments, item 4 of arguments)).
Otherwise If cmd is equal to "run":
    Let runSrc be readFile(item 3 of arguments).
    Let runExec be concat(tagStr (), item 1 of arguments).
    Let runArgv be newArr(concat(concat(tagArr (), argvBuild(arguments, 3, runExec)), tagArrEnd ())).
    puts(jsRunFileIn(runSrc, runArgv, pathDir(item 3 of arguments))).
Otherwise If looksLikeScript(cmd):
    Let bareSrc be readFile(cmd).
    Let bareExec be concat(tagStr (), item 1 of arguments).
    Let bareArgv be newArr(concat(concat(tagArr (), argvBuild(arguments, 2, bareExec)), tagArrEnd ())).
    puts(jsRunFileIn(bareSrc, bareArgv, pathDir(cmd))).
Otherwise If isSubcommand(cmd):
    eputs("error: this command is not yet implemented in logos-bun").
    exitWith(1).
Otherwise If cmd is equal to "":
    Show "Bun is a fast JavaScript runtime, package manager, bundler, and test runner. (1.4.0-canary.1+43ee03834)".
Otherwise If startsWithDash(cmd):
    Show "Bun is a fast JavaScript runtime, package manager, bundler, and test runner. (1.4.0-canary.1+43ee03834)".
Otherwise:
    eputs("error: Script not found " + chr(34) + cmd + chr(34)).
    exitWith(1).
