# bun

## An Ordering is one of:
    A Less.
    An Equal.
    A Greater.

## To native split (s: Text, sep: Text) -> Seq of Text
## To native substringAfter (s: Text, sep: Text) -> Text
## To native compareText (a: Text, b: Text) -> Int
## To native isDigits (s: Text) -> Bool
## To native startsWith (s: Text, prefix: Text) -> Bool
## To native toText (n: Int) -> Text
## To native trim (s: Text) -> Text
## To native substringBefore (s: Text, sep: Text) -> Text
## To native ord (s: Text) -> Int
## To native concat (a: Text, b: Text) -> Text
## To native parseInt (s: Text) -> Int
## To native exitWith (code: Int) -> Unit
## To native eputs (s: Text) -> Unit

# jsint byte vocabulary. A JS value is a flat Text carrying a tag byte: a string is
# tagStr+content, an array is tagArr..tagArrEnd with tagArrSep between elements, an
# object is tagObj..tagObjEnd with tagObjSep between entries and tagObjKV between key
# and value. Inside a string value, characters that would otherwise be read as syntax
# by the array/object/paren passes are escaped to their enc* placeholder (mirroring
# how a space becomes encSpace), and decoded back at every output boundary.
## To tagStr () -> Text:
    Return chr(3).

## To tagArr () -> Text:
    Return chr(5).

## To tagArrSep () -> Text:
    Return chr(6).

## To tagArrEnd () -> Text:
    Return chr(15).

## To tagObj () -> Text:
    Return chr(7).

## To tagObjKV () -> Text:
    Return chr(8).

## To tagObjSep () -> Text:
    Return chr(11).

## To tagObjEnd () -> Text:
    Return chr(14).

## To encSpace () -> Text:
    Return chr(4).

## To encBrkL () -> Text:
    Return chr(24).

## To encBrkR () -> Text:
    Return chr(25).

## To encBraceL () -> Text:
    Return chr(26).

## To encBraceR () -> Text:
    Return chr(27).

## To encParenL () -> Text:
    Return chr(28).

## To encParenR () -> Text:
    Return chr(29).

## To encBackslash () -> Text:
    Return chr(30).

## To encNewline () -> Text:
    Return chr(31).

## To encQuote () -> Text:
    Return chr(127).

## To numericCore (part: Text) -> Int:
    Let beforePre be item 1 of split(part, "-").
    Let beforeBuild be item 1 of split(beforePre, "+").
    Return parseInt(beforeBuild).

## To nthNumber (v: Text, n: Int) -> Int:
    Let parts be split(v, ".").
    If length of parts is greater than or equal to n:
        Return numericCore(item n of parts).
    Return 0.

## To major (v: Text) -> Int:
    Return nthNumber(v, 1).

## To minor (v: Text) -> Int:
    Return nthNumber(v, 2).

## To patch (v: Text) -> Int:
    Return nthNumber(v, 3).

## To cmpInt (a: Int, b: Int) -> Ordering:
    If a is less than b:
        Return a new Less.
    If a is greater than b:
        Return a new Greater.
    Return a new Equal.

## To intToOrdering (n: Int) -> Ordering:
    If n is less than 0:
        Return a new Less.
    If n is greater than 0:
        Return a new Greater.
    Return a new Equal.

## To minInt (a: Int, b: Int) -> Int:
    If a is less than b:
        Return a.
    Return b.

## To buildStripped (v: Text) -> Text:
    Return item 1 of split(v, "+").

## To prereleaseOf (v: Text) -> Text:
    Return substringAfter(buildStripped(v), "-").

## To comparePrereleaseIds (a: Text, b: Text) -> Ordering:
    If isDigits(a):
        If isDigits(b):
            Return cmpInt(parseInt(a), parseInt(b)).
        Return a new Less.
    If isDigits(b):
        Return a new Greater.
    Return intToOrdering(compareText(a, b)).

## To comparePrerelease (pa: Text, pb: Text) -> Ordering:
    If pa is equal to "":
        If pb is equal to "":
            Return a new Equal.
        Return a new Greater.
    If pb is equal to "":
        Return a new Less.
    Let idsA be split(pa, ".").
    Let idsB be split(pb, ".").
    Let countA be length of idsA.
    Let countB be length of idsB.
    Let shared be minInt(countA, countB).
    Repeat for i from 1 to shared:
        Let verdict be comparePrereleaseIds(item i of idsA, item i of idsB).
        If orderingToInt(verdict) is not equal to 0:
            Return verdict.
    Return cmpInt(countA, countB).

## To compareVersions (a: Text, b: Text) -> Ordering:
    Let majorA be major(a).
    Let majorB be major(b).
    If majorA is not equal to majorB:
        Return cmpInt(majorA, majorB).
    Let minorA be minor(a).
    Let minorB be minor(b).
    If minorA is not equal to minorB:
        Return cmpInt(minorA, minorB).
    Let patchA be patch(a).
    Let patchB be patch(b).
    If patchA is not equal to patchB:
        Return cmpInt(patchA, patchB).
    Return comparePrerelease(prereleaseOf(a), prereleaseOf(b)).

## To orderingToInt (o: Ordering) -> Int:
    Inspect o:
        When Less:
            Return -1.
        When Greater:
            Return 1.
        Otherwise:
            Return 0.

## To cmpNum (a: Text, b: Text) -> Int:
    Return orderingToInt(compareVersions(a, b)).

## To versionString (m: Int, n: Int, p: Int) -> Text:
    Return toText(m) + "." + toText(n) + "." + toText(p).

## To isWild (part: Text) -> Bool:
    If part is equal to "x":
        Return true.
    If part is equal to "X":
        Return true.
    If part is equal to "*":
        Return true.
    If part is equal to "":
        Return true.
    Return false.

## To specCount (spec: Text) -> Int:
    Let parts be split(spec, ".").
    Let upto be minInt(3, length of parts).
    Repeat for i from 1 to upto:
        If isWild(item i of parts):
            Return i - 1.
    Return upto.

## To compOr0 (spec: Text, i: Int) -> Int:
    Let parts be split(spec, ".").
    If length of parts is greater than or equal to i:
        Let part be item i of parts.
        If isWild(part):
            Return 0.
        Return numericCore(part).
    Return 0.

## To xLo (spec: Text) -> Text:
    Return versionString(compOr0(spec, 1), compOr0(spec, 2), compOr0(spec, 3)).

## To loBound (spec: Text) -> Text:
    If specCount(spec) is equal to 3:
        Return spec.
    Return xLo(spec).

## To partialUpper (spec: Text) -> Text:
    If specCount(spec) is equal to 2:
        Return versionString(compOr0(spec, 1), compOr0(spec, 2) + 1, 0).
    Return versionString(compOr0(spec, 1) + 1, 0, 0).

## To caretUpper (spec: Text) -> Text:
    Let m be compOr0(spec, 1).
    Let n be compOr0(spec, 2).
    Let p be compOr0(spec, 3).
    Let c be specCount(spec).
    If m is greater than 0:
        Return versionString(m + 1, 0, 0).
    If c is equal to 1:
        Return versionString(1, 0, 0).
    If c is equal to 3:
        If n is greater than 0:
            Return versionString(0, n + 1, 0).
        Return versionString(0, 0, p + 1).
    Return versionString(0, n + 1, 0).

## To tildeUpper (spec: Text) -> Text:
    If specCount(spec) is equal to 1:
        Return versionString(compOr0(spec, 1) + 1, 0, 0).
    Return versionString(compOr0(spec, 1), compOr0(spec, 2) + 1, 0).

## To testGE (version: Text, spec: Text) -> Bool:
    Return cmpNum(version, loBound(spec)) is greater than or equal to 0.

## To testLT (version: Text, spec: Text) -> Bool:
    Return cmpNum(version, loBound(spec)) is less than 0.

## To testLE (version: Text, spec: Text) -> Bool:
    If specCount(spec) is equal to 3:
        Return cmpNum(version, spec) is less than or equal to 0.
    Return cmpNum(version, partialUpper(spec)) is less than 0.

## To testGT (version: Text, spec: Text) -> Bool:
    If specCount(spec) is equal to 3:
        Return cmpNum(version, spec) is greater than 0.
    Return cmpNum(version, partialUpper(spec)) is greater than or equal to 0.

## To testXRange (version: Text, spec: Text) -> Bool:
    Let c be specCount(spec).
    If c is equal to 0:
        Return true.
    If c is equal to 3:
        Return cmpNum(version, spec) is equal to 0.
    If testGE(version, spec):
        Return cmpNum(version, partialUpper(spec)) is less than 0.
    Return false.

## To testCaret (version: Text, spec: Text) -> Bool:
    If testGE(version, spec):
        Return cmpNum(version, caretUpper(spec)) is less than 0.
    Return false.

## To testTilde (version: Text, spec: Text) -> Bool:
    If testGE(version, spec):
        Return cmpNum(version, tildeUpper(spec)) is less than 0.
    Return false.

## To testComparator (version: Text, token: Text) -> Bool:
    If token is equal to "":
        Return true.
    If startsWith(token, ">="):
        Return testGE(version, substringAfter(token, "=")).
    If startsWith(token, "<="):
        Return testLE(version, substringAfter(token, "=")).
    If startsWith(token, ">"):
        Return testGT(version, substringAfter(token, ">")).
    If startsWith(token, "<"):
        Return testLT(version, substringAfter(token, "<")).
    If startsWith(token, "="):
        Return testXRange(version, substringAfter(token, "=")).
    If startsWith(token, "^"):
        Return testCaret(version, substringAfter(token, "^")).
    If startsWith(token, "~"):
        Return testTilde(version, substringAfter(token, "~")).
    Return testXRange(version, token).

## To stripOp (token: Text) -> Text:
    If startsWith(token, ">="):
        Return substringAfter(token, "=").
    If startsWith(token, "<="):
        Return substringAfter(token, "=").
    If startsWith(token, ">"):
        Return substringAfter(token, ">").
    If startsWith(token, "<"):
        Return substringAfter(token, "<").
    If startsWith(token, "="):
        Return substringAfter(token, "=").
    If startsWith(token, "^"):
        Return substringAfter(token, "^").
    If startsWith(token, "~"):
        Return substringAfter(token, "~").
    Return token.

## To sameTuple (a: Text, b: Text) -> Bool:
    If major(a) is not equal to major(b):
        Return false.
    If minor(a) is not equal to minor(b):
        Return false.
    If patch(a) is equal to patch(b):
        Return true.
    Return false.

## To tokenAllowsPre (token: Text, version: Text) -> Bool:
    Let spec be stripOp(token).
    If prereleaseOf(spec) is equal to "":
        Return false.
    Return sameTuple(spec, version).

## To testSet (version: Text, setStr: Text) -> Bool:
    Let hyphenParts be split(setStr, " - ").
    If length of hyphenParts is equal to 2:
        Let loH be item 1 of hyphenParts.
        Let hiH be item 2 of hyphenParts.
        If testGE(version, loH):
            If testLE(version, hiH):
                If prereleaseOf(version) is equal to "":
                    Return true.
                If tokenAllowsPre(loH, version):
                    Return true.
                If tokenAllowsPre(hiH, version):
                    Return true.
        Return false.
    Let tokens be split(setStr, " ").
    Repeat for i from 1 to length of tokens:
        If not testComparator(version, item i of tokens):
            Return false.
    If prereleaseOf(version) is equal to "":
        Return true.
    Repeat for i from 1 to length of tokens:
        If tokenAllowsPre(item i of tokens, version):
            Return true.
    Return false.

## To satisfies (version: Text, range: Text) -> Bool:
    Let sets be split(range, "||").
    Repeat for i from 1 to length of sets:
        If testSet(version, item i of sets):
            Return true.
    Return false.

## To maxSatFrom (candidates: Seq of Text, range: Text, i: Int, best: Text) -> Text:
    If i is greater than length of candidates:
        Return best.
    Let cand be item i of candidates.
    If satisfies(cand, range):
        If best is equal to "":
            Return maxSatFrom(candidates, range, i + 1, cand).
        If cmpNum(cand, best) is greater than 0:
            Return maxSatFrom(candidates, range, i + 1, cand).
    Return maxSatFrom(candidates, range, i + 1, best).

## To maxSatisfying (versionsCsv: Text, range: Text) -> Text:
    Return maxSatFrom(split(versionsCsv, ","), range, 1, "").

## To minSatFrom (candidates: Seq of Text, range: Text, i: Int, best: Text) -> Text:
    If i is greater than length of candidates:
        Return best.
    Let cand be item i of candidates.
    If satisfies(cand, range):
        If best is equal to "":
            Return minSatFrom(candidates, range, i + 1, cand).
        If cmpNum(cand, best) is less than 0:
            Return minSatFrom(candidates, range, i + 1, cand).
    Return minSatFrom(candidates, range, i + 1, best).

## To minSatisfying (versionsCsv: Text, range: Text) -> Text:
    Return minSatFrom(split(versionsCsv, ","), range, 1, "").

## To findClassEnd (pat: Text, i: Int) -> Int:
    If i is greater than length of pat:
        Return 0.
    If item i of pat is equal to "]":
        Return i.
    Return findClassEnd(pat, i + 1).

## To classNegated (pat: Text, start: Int) -> Bool:
    Let c be item start of pat.
    If c is equal to "!":
        Return true.
    If c is equal to "^":
        Return true.
    Return false.

## To charInClass (pat: Text, i: Int, end: Int, ch: Text) -> Bool:
    If i is greater than or equal to end:
        Return false.
    Let lo be item i of pat.
    If i + 2 is less than end:
        If item (i + 1) of pat is equal to "-":
            Let hi be item (i + 2) of pat.
            If compareText(ch, lo) is greater than or equal to 0:
                If compareText(ch, hi) is less than or equal to 0:
                    Return true.
            Return charInClass(pat, i + 3, end, ch).
    If ch is equal to lo:
        Return true.
    Return charInClass(pat, i + 1, end, ch).

## To classMatch (pat: Text, start: Int, end: Int, ch: Text) -> Bool:
    If classNegated(pat, start):
        If charInClass(pat, start + 1, end, ch):
            Return false.
        Return true.
    Return charInClass(pat, start, end, ch).

## To globMatch (pat: Text, text: Text, pi: Int, ti: Int) -> Bool:
    Let plen be length of pat.
    Let tlen be length of text.
    If pi is greater than plen:
        Return ti is greater than tlen.
    Let pc be item pi of pat.
    If pc is equal to "*":
        If globMatch(pat, text, pi + 1, ti):
            Return true.
        If ti is less than or equal to tlen:
            Return globMatch(pat, text, pi, ti + 1).
        Return false.
    If ti is greater than tlen:
        Return false.
    If pc is equal to "?":
        Return globMatch(pat, text, pi + 1, ti + 1).
    If pc is equal to "[":
        Let closeIdx be findClassEnd(pat, pi + 1).
        If closeIdx is equal to 0:
            If pc is equal to item ti of text:
                Return globMatch(pat, text, pi + 1, ti + 1).
            Return false.
        If classMatch(pat, pi + 1, closeIdx, item ti of text):
            Return globMatch(pat, text, closeIdx + 1, ti + 1).
        Return false.
    If pc is equal to item ti of text:
        Return globMatch(pat, text, pi + 1, ti + 1).
    Return false.

## To glob (pat: Text, text: Text) -> Bool:
    Return globMatch(pat, text, 1, 1).

## To matchSegs (patSegs: Seq of Text, pathSegs: Seq of Text, pi: Int, ti: Int) -> Bool:
    Let plen be length of patSegs.
    Let tlen be length of pathSegs.
    If pi is greater than plen:
        Return ti is greater than tlen.
    Let patSeg be item pi of patSegs.
    If patSeg is equal to "**":
        If pi is equal to plen:
            Return ti is less than or equal to tlen.
        If matchSegs(patSegs, pathSegs, pi + 1, ti):
            Return true.
        If ti is less than or equal to tlen:
            Return matchSegs(patSegs, pathSegs, pi, ti + 1).
        Return false.
    If ti is greater than tlen:
        Return false.
    If glob(patSeg, item ti of pathSegs):
        Return matchSegs(patSegs, pathSegs, pi + 1, ti + 1).
    Return false.

## To globPath (pat: Text, path: Text) -> Bool:
    Return matchSegs(split(pat, "/"), split(path, "/"), 1, 1).

## To tomlUnquote (v: Text) -> Text:
    If startsWith(v, chr(34)):
        Return item 1 of split(substringAfter(v, chr(34)), chr(34)).
    Return trim(substringBefore(v, "#")).

## To tomlFullKey (currentTable: Text, key: Text) -> Text:
    If currentTable is equal to "":
        Return key.
    Return currentTable + "." + key.

## To tomlScan (lines: Seq of Text, dottedKey: Text, i: Int, currentTable: Text) -> Text:
    If i is greater than length of lines:
        Return "".
    Let line be trim(item i of lines).
    If line is equal to "":
        Return tomlScan(lines, dottedKey, i + 1, currentTable).
    If startsWith(line, "#"):
        Return tomlScan(lines, dottedKey, i + 1, currentTable).
    If startsWith(line, "["):
        Let tbl be trim(item 1 of split(substringAfter(line, "["), "]")).
        Return tomlScan(lines, dottedKey, i + 1, tbl).
    Let beforeEq be substringBefore(line, "=").
    If beforeEq is not equal to line:
        Let key be trim(beforeEq).
        If tomlFullKey(currentTable, key) is equal to dottedKey:
            Return tomlUnquote(trim(substringAfter(line, "="))).
    Return tomlScan(lines, dottedKey, i + 1, currentTable).

## To tomlGet (doc: Text, dottedKey: Text) -> Text:
    Return tomlScan(split(doc, chr(10)), dottedKey, 1, "").

## To b64Char (n: Int) -> Text:
    Return item (n + 1) of "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/".

## To b64Quad (c1: Text, c2: Text, c3: Text, c4: Text) -> Text:
    Return concat(concat(concat(c1, c2), c3), c4).

## To b64Encode (s: Text, i: Int, acc: Text) -> Text:
    Let n be length of s.
    If i is greater than n:
        Return acc.
    Let b1 be ord(item i of s).
    Let c1 be b64Char(b1 // 4).
    Let remaining be n - i + 1.
    If remaining is equal to 1:
        Let c2 be b64Char((b1 % 4) * 16).
        Return b64Encode(s, i + 3, concat(acc, b64Quad(c1, c2, "=", "="))).
    Let b2 be ord(item (i + 1) of s).
    If remaining is equal to 2:
        Let c2 be b64Char(((b1 % 4) * 16) + (b2 // 16)).
        Let c3 be b64Char((b2 % 16) * 4).
        Return b64Encode(s, i + 3, concat(acc, b64Quad(c1, c2, c3, "="))).
    Let b3 be ord(item (i + 2) of s).
    Let c2 be b64Char(((b1 % 4) * 16) + (b2 // 16)).
    Let c3 be b64Char(((b2 % 16) * 4) + (b3 // 64)).
    Let c4 be b64Char(b3 % 64).
    Return b64Encode(s, i + 3, concat(acc, b64Quad(c1, c2, c3, c4))).

## To base64Encode (s: Text) -> Text:
    Return b64Encode(s, 1, "").

## To b64Index (c: Text) -> Int:
    Let o be ord(c).
    If o is greater than or equal to 65:
        If o is less than or equal to 90:
            Return o - 65.
    If o is greater than or equal to 97:
        If o is less than or equal to 122:
            Return o - 71.
    If o is greater than or equal to 48:
        If o is less than or equal to 57:
            Return o + 4.
    If o is equal to 43:
        Return 62.
    Return 63.

## To b64DecodeTrip (c1: Text, c2: Text, c3: Text, c4: Text) -> Text:
    Let v1 be b64Index(c1).
    Let v2 be b64Index(c2).
    Let out1 be chr((v1 * 4) + (v2 // 16)).
    If c3 is equal to "=":
        Return out1.
    Let v3 be b64Index(c3).
    Let out2 be concat(out1, chr(((v2 % 16) * 16) + (v3 // 4))).
    If c4 is equal to "=":
        Return out2.
    Let v4 be b64Index(c4).
    Return concat(out2, chr(((v3 % 4) * 64) + v4)).

## To b64Decode (s: Text, i: Int, acc: Text) -> Text:
    If i is greater than length of s:
        Return acc.
    Let trip be b64DecodeTrip(item i of s, item (i + 1) of s, item (i + 2) of s, item (i + 3) of s).
    Return b64Decode(s, i + 4, concat(acc, trip)).

## To base64Decode (s: Text) -> Text:
    Return b64Decode(s, 1, "").

## To hexDigit (n: Int) -> Text:
    If n is less than 10:
        Return chr(48 + n).
    Return chr(87 + n).

## To hexEncode (s: Text, i: Int, acc: Text) -> Text:
    If i is greater than length of s:
        Return acc.
    Let b be ord(item i of s).
    Let pair be concat(hexDigit(b // 16), hexDigit(b % 16)).
    Return hexEncode(s, i + 1, concat(acc, pair)).

## To toHex (s: Text) -> Text:
    Return hexEncode(s, 1, "").

## To hexVal (c: Text) -> Int:
    Let o be ord(c).
    If o is less than or equal to 57:
        Return o - 48.
    If o is less than or equal to 70:
        Return o - 55.
    Return o - 87.

## To hexDecode (s: Text, i: Int, acc: Text) -> Text:
    If i is greater than length of s:
        Return acc.
    Let hi be hexVal(item i of s).
    Let lo be hexVal(item (i + 1) of s).
    Return hexDecode(s, i + 2, concat(acc, chr((hi * 16) + lo))).

## To fromHex (s: Text) -> Text:
    Return hexDecode(s, 1, "").

## To jsEvalAdd (tokens: Seq of Text, i: Int, acc: Int, curProduct: Int, curSign: Int) -> Int:
    If i is greater than length of tokens:
        Return acc + (curSign * curProduct).
    Let op be item i of tokens.
    Let num be parseInt(item (i + 1) of tokens).
    If op is equal to "+":
        Return jsEvalAdd(tokens, i + 2, acc + (curSign * curProduct), num, 1).
    If op is equal to "-":
        Return jsEvalAdd(tokens, i + 2, acc + (curSign * curProduct), num, -1).
    If op is equal to "*":
        Return jsEvalAdd(tokens, i + 2, acc, curProduct * num, curSign).
    Return jsEvalAdd(tokens, i + 2, acc, curProduct % num, curSign).

## To lastMatchIdx (toks: Seq of Text, target: Text, i: Int) -> Int:
    If i is less than 1:
        Return 0.
    If item i of toks is equal to target:
        Return i.
    Return lastMatchIdx(toks, target, i - 1).

## To powReduce (expr: Text, idx: Int) -> Text:
    Let toks be split(expr, " ").
    Let base be parseInt(item (idx - 1) of toks).
    Let exp be parseInt(item (idx + 1) of toks).
    Let left be joinRange(toks, 1, idx - 2, "").
    Let right be joinRange(toks, idx + 2, length of toks, "").
    Return joinNonEmpty(split(concat(concat(concat(left, " "), toText(powInt(base, exp, 1))), concat(" ", right)), " "), 1, "").

## To resolvePow (expr: Text) -> Text:
    Let idx be lastMatchIdx(split(expr, " "), "**", length of split(expr, " ")).
    If idx is equal to 0:
        Return expr.
    Return resolvePow(powReduce(expr, idx)).

## To jsEvalNorm (expr: Text) -> Int:
    Let tokens be split(resolvePow(expr), " ").
    Return jsEvalAdd(tokens, 2, 0, parseInt(item 1 of tokens), 1).

## To jsEval (expr: Text) -> Int:
    If startsWith(trim(expr), "- "):
        Return jsEvalNorm(concat("0 ", trim(expr))).
    If startsWith(trim(expr), "+ "):
        Return jsEvalNorm(concat("0 ", trim(expr))).
    Return jsEvalNorm(expr).

## To joinPieces (pieces: Seq of Text, i: Int, upto: Int, acc: Text) -> Text:
    If i is greater than upto:
        Return acc.
    If i is equal to 1:
        Let firstPiece be item 1 of pieces.
        Return joinPieces(pieces, 2, upto, firstPiece).
    Let piece be item i of pieces.
    Let nextAcc be concat(concat(acc, "("), piece).
    Return joinPieces(pieces, i + 1, upto, nextAcc).

## To evalParens (expr: Text) -> Int:
    If substringBefore(expr, "(") is equal to expr:
        Return jsEval(expr).
    Let leftOfClose be substringBefore(expr, ")").
    Let rest be substringAfter(expr, ")").
    Let pieces be split(leftOfClose, "(").
    Let np be length of pieces.
    Let inner be trim(item np of pieces).
    Let prefix be joinPieces(pieces, 1, np - 1, "").
    Return evalParens(concat(concat(prefix, toText(jsEval(inner))), rest)).

## To cmpResult (b: Bool) -> Text:
    If b:
        Return "true".
    Return "false".

## To hasSep (expr: Text, sep: Text) -> Bool:
    Return substringBefore(expr, sep) is not equal to expr.

## To notOf (b: Text) -> Text:
    If b is equal to "false":
        Return "true".
    If b is equal to "0":
        Return "true".
    If b is equal to "":
        Return "true".
    If b is equal to "null":
        Return "true".
    If b is equal to "undefined":
        Return "true".
    Return "false".

## To jsEvalCmp (expr: Text) -> Text:
    If startsWith(trim(expr), "! "):
        Return notOf(jsEvalCmp(trim(substringAfter(trim(expr), "! ")))).
    If hasSep(expr, " <= "):
        Let parts be split(expr, " <= ").
        Return cmpResult(cmpVals(evalValue(item 1 of parts), evalValue(item 2 of parts)) is less than or equal to 0).
    If hasSep(expr, " >= "):
        Let parts be split(expr, " >= ").
        Return cmpResult(cmpVals(evalValue(item 1 of parts), evalValue(item 2 of parts)) is greater than or equal to 0).
    If hasSep(expr, " === "):
        Let parts be split(expr, " === ").
        Return cmpResult(cmpVals(evalValue(item 1 of parts), evalValue(item 2 of parts)) is equal to 0).
    If hasSep(expr, " !== "):
        Let parts be split(expr, " !== ").
        Return cmpResult(cmpVals(evalValue(item 1 of parts), evalValue(item 2 of parts)) is not equal to 0).
    If hasSep(expr, " == "):
        Let parts be split(expr, " == ").
        Return cmpResult(cmpVals(evalValue(item 1 of parts), evalValue(item 2 of parts)) is equal to 0).
    If hasSep(expr, " != "):
        Let parts be split(expr, " != ").
        Return cmpResult(cmpVals(evalValue(item 1 of parts), evalValue(item 2 of parts)) is not equal to 0).
    If hasSep(expr, " < "):
        Let parts be split(expr, " < ").
        Return cmpResult(cmpVals(evalValue(item 1 of parts), evalValue(item 2 of parts)) is less than 0).
    If hasSep(expr, " > "):
        Let parts be split(expr, " > ").
        Return cmpResult(cmpVals(evalValue(item 1 of parts), evalValue(item 2 of parts)) is greater than 0).
    Return evalValue(expr).

## To boolOf (t: Text) -> Bool:
    If t is equal to "true":
        Return true.
    If t is equal to "false":
        Return false.
    If t is equal to "0":
        Return false.
    If t is equal to "":
        Return false.
    If t is equal to tagStr ():
        Return false.
    If t is equal to "null":
        Return false.
    If t is equal to "undefined":
        Return false.
    Return true.

## To jsAndAll (parts: Seq of Text, i: Int) -> Bool:
    If i is greater than length of parts:
        Return true.
    Let part be trim(item i of parts).
    If boolOf(jsEvalCmp(part)):
        Return jsAndAll(parts, i + 1).
    Return false.

## To jsOrAll (groups: Seq of Text, i: Int) -> Bool:
    If i is greater than length of groups:
        Return false.
    Let group be item i of groups.
    If jsAndAll(split(group, " && "), 1):
        Return true.
    Return jsOrAll(groups, i + 1).

## To jsAndVal (parts: Seq of Text, i: Int) -> Text:
    Let v be jsEvalCmp(trim(item i of parts)).
    If i is equal to length of parts:
        Return v.
    If boolOf(v):
        Return jsAndVal(parts, i + 1).
    Return v.

## To jsOrVal (groups: Seq of Text, i: Int) -> Text:
    Let v be jsAndVal(split(trim(item i of groups), " && "), 1).
    If i is equal to length of groups:
        Return v.
    If boolOf(v):
        Return v.
    Return jsOrVal(groups, i + 1).

## To isNullish (v: Text) -> Bool:
    If v is equal to "null":
        Return true.
    If v is equal to "undefined":
        Return true.
    Return false.

## To jsNullishVal (parts: Seq of Text, i: Int) -> Text:
    Let v be jsEvalCmp(trim(item i of parts)).
    If i is equal to length of parts:
        Return v.
    If isNullish(v):
        Return jsNullishVal(parts, i + 1).
    Return v.

## To jsEvalLogic (expr: Text) -> Text:
    If hasSep(expr, " ?? "):
        Return jsNullishVal(split(expr, " ?? "), 1).
    If hasSep(expr, " || "):
        Return jsOrVal(split(expr, " || "), 1).
    If hasSep(expr, " && "):
        Return jsAndVal(split(expr, " && "), 1).
    Return jsEvalCmp(expr).

## To jsEvalTernary (expr: Text) -> Text:
    If hasSep(expr, " ? "):
        Let cond be substringBefore(expr, " ? ").
        Let rest be substringAfter(expr, " ? ").
        Let thenPart be substringBefore(rest, " : ").
        Let elsePart be substringAfter(rest, " : ").
        If boolOf(jsEvalLogic(cond)):
            Return jsEvalTernary(thenPart).
        Return jsEvalTernary(elsePart).
    Return jsEvalLogic(expr).

## To envScan (pairs: Seq of Text, i: Int, name: Text) -> Text:
    If i is greater than length of pairs:
        Return "".
    Let pair be item i of pairs.
    If substringBefore(pair, "=") is equal to name:
        Return substringAfter(pair, "=").
    Return envScan(pairs, i + 1, name).

## To envGet (env: Text, name: Text) -> Text:
    Return envScan(split(env, ";"), 1, name).

# A token in PROPERTY position (right after `.`) or KEY position (right after `{`/`,`
# and right before `:`) names a member, not a variable — so it must NOT be substituted,
# else a variable whose name matches a key/property corrupts that slot (BUG-40).
## To substTokens (tokens: Seq of Text, i: Int, env: Text, acc: Text) -> Text:
    If i is greater than length of tokens:
        Return trim(acc).
    Let tok be item i of tokens.
    If i is greater than 1:
        If item (i - 1) of tokens is equal to ".":
            Return substTokens(tokens, i + 1, env, concat(concat(acc, " "), tok)).
    If i is greater than 1:
        If i is less than length of tokens:
            If item (i + 1) of tokens is equal to ":":
                If item (i - 1) of tokens is equal to chr(123):
                    Return substTokens(tokens, i + 1, env, concat(concat(acc, " "), tok)).
                If item (i - 1) of tokens is equal to ",":
                    Return substTokens(tokens, i + 1, env, concat(concat(acc, " "), tok)).
    Let val be envGet(env, tok).
    If val is not equal to "":
        Return substTokens(tokens, i + 1, env, concat(concat(acc, " "), val)).
    Return substTokens(tokens, i + 1, env, concat(concat(acc, " "), tok)).

## To substitute (expr: Text, env: Text) -> Text:
    Return substTokens(split(expr, " "), 1, env, "").

## To joinAll (parts: Seq of Text, i: Int, sep: Text, acc: Text) -> Text:
    If i is greater than length of parts:
        Return acc.
    If i is equal to 1:
        Let firstPiece be item 1 of parts.
        Return joinAll(parts, 2, sep, firstPiece).
    Let piece be item i of parts.
    Let nextAcc be concat(concat(acc, sep), piece).
    Return joinAll(parts, i + 1, sep, nextAcc).

## To replaceAll (s: Text, pat: Text, rep: Text) -> Text:
    Return joinAll(split(s, pat), 1, rep, "").

## To joinRange (parts: Seq of Text, i: Int, upto: Int, acc: Text) -> Text:
    If i is greater than upto:
        Return acc.
    If i is equal to 1:
        Let firstPiece be item 1 of parts.
        Return joinRange(parts, 2, upto, firstPiece).
    Let piece be item i of parts.
    Let nextAcc be concat(concat(acc, " "), piece).
    Return joinRange(parts, i + 1, upto, nextAcc).

## To hasReturn (env: Text) -> Bool:
    Return envGet(env, "__ret") is not equal to "".

## To bindParams (params: Seq of Text, args: Seq of Text, i: Int, callerEnv: Text, acc: Text) -> Text:
    If i is greater than length of params:
        Return acc.
    Let pname be trim(item i of params).
    If pname is equal to "":
        Return bindParams(params, args, i + 1, callerEnv, acc).
    Let aval be jsEvalIn(item i of args, callerEnv).
    Return bindParams(params, args, i + 1, callerEnv, envSet(acc, pname, aval)).

## To callFn (fnVal: Text, argsText: Text, env: Text) -> Text:
    Let afterMark be substringAfter(fnVal, chr(1)).
    Let paramStr be decFn(substringBefore(afterMark, chr(1))).
    Let body be decFn(substringAfter(afterMark, chr(1))).
    Let localEnv be bindParams(split(paramStr, ","), split(argsText, ","), 1, env, env).
    Let doneEnv be runBlockStr(body, localEnv).
    Return envGet(doneEnv, "__ret").

## To callFn2 (fnVal: Text, v1: Text, v2: Text, env: Text) -> Text:
    Let afterMark be substringAfter(fnVal, chr(1)).
    Let paramStr be decFn(substringBefore(afterMark, chr(1))).
    Let body be decFn(substringAfter(afterMark, chr(1))).
    Let params be split(paramStr, ",").
    Let e1 be envSet(env, trim(item 1 of params), v1).
    Let e2 be envSet(e1, trim(item 2 of params), v2).
    Let doneEnv be runBlockStr(body, e2).
    Return envGet(doneEnv, "__ret").

## To isGlobalFn (name: Text) -> Bool:
    Let names be ["parseInt", "String", "Number", "Boolean"].
    Return names contains name.

## To globalCall (name: Text, av: Text) -> Text:
    If name is equal to "parseInt":
        Return toText(parseInt(materialize(av))).
    If name is equal to "Number":
        Return toText(parseInt(materialize(av))).
    If name is equal to "String":
        Return concat(tagStr (), materialize(av)).
    If name is equal to "Boolean":
        Return cmpResult(boolOf(av)).
    Return av.

## To joinComma (els: Seq of Text, i: Int, acc: Text) -> Text:
    If i is greater than length of els:
        Return acc.
    Let el be item i of els.
    If i is equal to 1:
        Return joinComma(els, i + 1, el).
    Return joinComma(els, i + 1, concat(concat(acc, ","), el)).

## To expandSpreadLoop (args: Seq of Text, i: Int, env: Text, acc: Text) -> Text:
    If i is greater than length of args:
        Return acc.
    Let arg be trim(item i of args).
    If startsWith(arg, "..."):
        Let elems be joinComma(arrElements(jsEvalIn(trim(substringAfter(arg, "...")), concat(env, ""))), 1, "").
        If acc is equal to "":
            Return expandSpreadLoop(args, i + 1, env, elems).
        Return expandSpreadLoop(args, i + 1, env, concat(concat(acc, ","), elems)).
    If acc is equal to "":
        Return expandSpreadLoop(args, i + 1, env, arg).
    Return expandSpreadLoop(args, i + 1, env, concat(concat(acc, ","), arg)).

## To expandSpreadArgs (inner: Text, env: Text) -> Text:
    If substringBefore(inner, "...") is equal to inner:
        Return inner.
    Return expandSpreadLoop(splitArgsN(inner), 1, env, "").

## To resolveCalls (expr: Text, env: Text) -> Text:
    If substringBefore(expr, "(") is equal to expr:
        Return expr.
    Let leftOfClose be substringBefore(expr, ")").
    Let rest be substringAfter(expr, ")").
    Let pieces be split(leftOfClose, "(").
    Let np be length of pieces.
    Let inner be expandSpreadArgs(trim(item np of pieces), concat(env, "")).
    Let prefix be trim(joinPieces(pieces, 1, np - 1, "")).
    Let ptoks be split(prefix, " ").
    Let lastTok be item (length of ptoks) of ptoks.
    If startsWith(lastTok, chr(1)):
        Let result be callFn(lastTok, inner, env).
        Let newPrefix be joinRange(ptoks, 1, (length of ptoks) - 1, "").
        Return resolveCalls(concat(concat(concat(newPrefix, " "), result), rest), env).
    Let fnVal be envGet(env, lastTok).
    If startsWith(fnVal, chr(1)):
        Let result be callFn(fnVal, inner, env).
        Let newPrefix be joinRange(ptoks, 1, (length of ptoks) - 1, "").
        Return resolveCalls(concat(concat(concat(newPrefix, " "), result), rest), env).
    If isGlobalFn(lastTok):
        Let av be jsEvalIn(inner, env).
        Let newPrefix be joinRange(ptoks, 1, (length of ptoks) - 1, "").
        Return resolveCalls(concat(concat(concat(newPrefix, " "), globalCall(lastTok, av)), rest), env).
    Let innerVal be jsEvalTernary(substitute(resolveCalls(inner, env), env)).
    Return resolveCalls(concat(concat(concat(prefix, " "), innerVal), rest), env).

## To matArr (els: Seq of Text, i: Int, acc: Text) -> Text:
    If i is greater than length of els:
        Return acc.
    Let m be materialize(item i of els).
    If i is equal to 1:
        Return matArr(els, i + 1, m).
    Return matArr(els, i + 1, concat(concat(acc, ","), m)).

## To materialize (v: Text) -> Text:
    If startsWith(v, tagStr ()):
        Return substringAfter(v, tagStr ()).
    If startsWith(v, tagArr ()):
        Return matArr(arrElements(v), 1, "").
    If startsWith(v, tagObj ()):
        Return "[object Object]".
    Return v.

## To hasStr (expr: Text) -> Bool:
    If substringBefore(expr, chr(34)) is not equal to expr:
        Return true.
    If substringBefore(expr, tagStr ()) is not equal to expr:
        Return true.
    Return false.

## To joinUpto (parts: Seq of Text, i: Int, upto: Int, sep: Text, acc: Text) -> Text:
    If i is greater than upto:
        Return acc.
    If i is equal to 1:
        Let firstPiece be item 1 of parts.
        Return joinUpto(parts, 2, upto, sep, firstPiece).
    Let piece be item i of parts.
    Let nextAcc be concat(concat(acc, sep), piece).
    Return joinUpto(parts, i + 1, upto, sep, nextAcc).

## To splitArrElemsDepth (s: Text, i: Int, depth: Int, acc: Text) -> Text:
    If i is greater than length of s:
        Return acc.
    Let c be item i of s.
    If c is equal to tagArr ():
        Return splitArrElemsDepth(s, i + 1, depth + 1, concat(acc, c)).
    If c is equal to tagArrEnd ():
        Return splitArrElemsDepth(s, i + 1, depth - 1, concat(acc, c)).
    If c is equal to tagArrSep ():
        If depth is equal to 0:
            Return splitArrElemsDepth(s, i + 1, 0, concat(acc, chr(10))).
        Return splitArrElemsDepth(s, i + 1, depth, concat(acc, c)).
    Return splitArrElemsDepth(s, i + 1, depth, concat(acc, c)).

## To arrElements (arrval: Text) -> Seq of Text:
    Let inner be substringAfter(arrval, tagArr ()).
    Let content be strSliceLoop(inner, 1, (length of inner) - 1, "").
    If content is equal to "":
        Return [] of Text.
    Return split(splitArrElemsDepth(content, 1, 0, ""), chr(10)).

## To buildArr (elems: Seq of Text, i: Int, acc: Text) -> Text:
    If i is greater than length of elems:
        Return concat(concat(tagArr (), acc), tagArrEnd ()).
    Let el be trim(item i of elems).
    If startsWith(el, "..."):
        Let sEls be arrElements(evalValue(trim(substringAfter(el, "...")))).
        If length of sEls is less than 1:
            Return buildArr(elems, i + 1, acc).
        Let sJoined be joinChr6(sEls, 1, length of sEls, "").
        If acc is equal to "":
            Return buildArr(elems, i + 1, sJoined).
        Return buildArr(elems, i + 1, concat(concat(acc, tagArrSep ()), sJoined)).
    Let elVal be evalValue(el).
    If acc is equal to "":
        Return buildArr(elems, i + 1, elVal).
    Return buildArr(elems, i + 1, concat(concat(acc, tagArrSep ()), elVal)).

## To arrGet (arrVal: Text, idx: Int) -> Text:
    Let els be arrElements(arrVal).
    If idx + 1 is greater than length of els:
        Return "undefined".
    Return item (idx + 1) of els.

## To resolveArrays (expr: Text) -> Text:
    If substringBefore(expr, chr(91)) is equal to expr:
        Return expr.
    Let leftOfClose be substringBefore(expr, chr(93)).
    Let rest be substringAfter(expr, chr(93)).
    Let pieces be split(leftOfClose, chr(91)).
    Let np be length of pieces.
    Let inner be trim(item np of pieces).
    Let rawPrefix be joinUpto(pieces, 1, np - 1, chr(91), "").
    Let prefix be trim(rawPrefix).
    Let ptoks be split(prefix, " ").
    Let lastTok be item (length of ptoks) of ptoks.
    If startsWith(lastTok, tagArr ()):
        Let elem be arrGet(lastTok, parseInt(evalValue(inner))).
        Let newPrefix be joinRange(ptoks, 1, (length of ptoks) - 1, "").
        Return resolveArrays(trim(concat(concat(concat(newPrefix, " "), elem), rest))).
    If startsWith(lastTok, tagObj ()):
        Let got be objGet(lastTok, materialize(evalValue(inner))).
        Let newPrefix be joinRange(ptoks, 1, (length of ptoks) - 1, "").
        Return resolveArrays(trim(concat(concat(concat(newPrefix, " "), got), rest))).
    If inner is equal to "":
        Return resolveArrays(trim(concat(concat(rawPrefix, concat(tagArr (), tagArrEnd ())), rest))).
    Return resolveArrays(trim(concat(concat(rawPrefix, buildArr(split(inner, ","), 1, "")), rest))).

## To splitObjEntriesDepth (s: Text, i: Int, depth: Int, acc: Text) -> Text:
    If i is greater than length of s:
        Return acc.
    Let c be item i of s.
    If c is equal to tagObj ():
        Return splitObjEntriesDepth(s, i + 1, depth + 1, concat(acc, c)).
    If c is equal to tagObjEnd ():
        Return splitObjEntriesDepth(s, i + 1, depth - 1, concat(acc, c)).
    If c is equal to tagObjSep ():
        If depth is equal to 0:
            Return splitObjEntriesDepth(s, i + 1, 0, concat(acc, chr(10))).
        Return splitObjEntriesDepth(s, i + 1, depth, concat(acc, c)).
    Return splitObjEntriesDepth(s, i + 1, depth, concat(acc, c)).

## To objScanLast (entries: Seq of Text, i: Int, key: Text, found: Text) -> Text:
    If i is greater than length of entries:
        Return found.
    Let entry be item i of entries.
    If substringBefore(entry, tagObjKV ()) is equal to key:
        Return objScanLast(entries, i + 1, key, substringAfter(entry, tagObjKV ())).
    Return objScanLast(entries, i + 1, key, found).

## To objGet (objVal: Text, key: Text) -> Text:
    Let inner be substringAfter(objVal, tagObj ()).
    Let content be strSliceLoop(inner, 1, (length of inner) - 1, "").
    If content is equal to "":
        Return "undefined".
    Return objScanLast(split(splitObjEntriesDepth(content, 1, 0, ""), chr(10)), 1, key, "undefined").

## To objKeysLoop (entries: Seq of Text, i: Int, acc: Text) -> Text:
    If i is greater than length of entries:
        Return acc.
    Let entry be item i of entries.
    Let k be concat(tagStr (), substringBefore(entry, tagObjKV ())).
    If i is equal to 1:
        Return objKeysLoop(entries, i + 1, k).
    Return objKeysLoop(entries, i + 1, concat(concat(acc, tagArrSep ()), k)).

## To objValuesLoop (entries: Seq of Text, i: Int, acc: Text) -> Text:
    If i is greater than length of entries:
        Return acc.
    Let entry be item i of entries.
    Let v be substringAfter(entry, tagObjKV ()).
    If i is equal to 1:
        Return objValuesLoop(entries, i + 1, v).
    Return objValuesLoop(entries, i + 1, concat(concat(acc, tagArrSep ()), v)).

## To objEntriesLoop (entries: Seq of Text, i: Int, acc: Text) -> Text:
    If i is greater than length of entries:
        Return acc.
    Let entry be item i of entries.
    Let pair be concat(concat(tagArr (), concat(concat(concat(tagStr (), substringBefore(entry, tagObjKV ())), tagArrSep ()), substringAfter(entry, tagObjKV ()))), tagArrEnd ()).
    If i is equal to 1:
        Return objEntriesLoop(entries, i + 1, pair).
    Return objEntriesLoop(entries, i + 1, concat(concat(acc, tagArrSep ()), pair)).

## To objEntrySeq (objVal: Text) -> Seq of Text:
    Let inner be substringAfter(objVal, tagObj ()).
    Let content be strSliceLoop(inner, 1, (length of inner) - 1, "").
    If content is equal to "":
        Return [] of Text.
    Return split(splitObjEntriesDepth(content, 1, 0, ""), chr(10)).

## To objKeys (objVal: Text) -> Text:
    Return concat(concat(tagArr (), objKeysLoop(objEntrySeq(objVal), 1, "")), tagArrEnd ()).

## To objValues (objVal: Text) -> Text:
    Return concat(concat(tagArr (), objValuesLoop(objEntrySeq(objVal), 1, "")), tagArrEnd ()).

## To objEntries (objVal: Text) -> Text:
    Return concat(concat(tagArr (), objEntriesLoop(objEntrySeq(objVal), 1, "")), tagArrEnd ()).

## To jsonEscape (s: Text, i: Int, acc: Text) -> Text:
    If i is greater than length of s:
        Return acc.
    Let c be item i of s.
    If c is equal to encQuote ():
        Return jsonEscape(s, i + 1, concat(acc, concat(chr(92), chr(34)))).
    If c is equal to encBackslash ():
        Return jsonEscape(s, i + 1, concat(acc, concat(chr(92), chr(92)))).
    If c is equal to encNewline ():
        Return jsonEscape(s, i + 1, concat(acc, concat(chr(92), "n"))).
    If c is equal to chr(9):
        Return jsonEscape(s, i + 1, concat(acc, concat(chr(92), "t"))).
    If c is equal to chr(34):
        Return jsonEscape(s, i + 1, concat(acc, concat(chr(92), chr(34)))).
    If c is equal to chr(92):
        Return jsonEscape(s, i + 1, concat(acc, concat(chr(92), chr(92)))).
    Return jsonEscape(s, i + 1, concat(acc, c)).

## To jsonArrLoop (els: Seq of Text, i: Int, acc: Text) -> Text:
    If i is greater than length of els:
        Return acc.
    Let s be jsonStringify(concat(item i of els, "")).
    If i is equal to 1:
        Return jsonArrLoop(els, i + 1, s).
    Return jsonArrLoop(els, i + 1, concat(concat(acc, ","), s)).

## To jsonObjLoop (entries: Seq of Text, i: Int, acc: Text) -> Text:
    If i is greater than length of entries:
        Return acc.
    Let entry be item i of entries.
    Let pair be concat(concat(concat(concat(chr(34), jsonEscape(substringBefore(entry, tagObjKV ()), 1, "")), chr(34)), ":"), jsonStringify(concat(substringAfter(entry, tagObjKV ()), ""))).
    If i is equal to 1:
        Return jsonObjLoop(entries, i + 1, pair).
    Return jsonObjLoop(entries, i + 1, concat(concat(acc, ","), pair)).

## To jsonStringify (v: Text) -> Text:
    If startsWith(v, tagStr ()):
        Return concat(concat(chr(34), jsonEscape(substringAfter(v, tagStr ()), 1, "")), chr(34)).
    If startsWith(v, tagArr ()):
        Return concat(concat(encBrkL (), jsonArrLoop(arrElements(v), 1, "")), encBrkR ()).
    If startsWith(v, tagObj ()):
        Return concat(concat(encBraceL (), jsonObjLoop(objEntrySeq(v), 1, "")), encBraceR ()).
    Return v.

## To jsonSplitTop (s: Text, i: Int, depth: Int, inStr: Bool, acc: Text) -> Text:
    If i is greater than length of s:
        Return acc.
    Let c be item i of s.
    If inStr:
        If c is equal to encQuote ():
            Return jsonSplitTop(s, i + 1, depth, false, concat(acc, c)).
        Return jsonSplitTop(s, i + 1, depth, true, concat(acc, c)).
    If c is equal to encQuote ():
        Return jsonSplitTop(s, i + 1, depth, true, concat(acc, c)).
    If c is equal to encBraceL ():
        Return jsonSplitTop(s, i + 1, depth + 1, false, concat(acc, c)).
    If c is equal to encBrkL ():
        Return jsonSplitTop(s, i + 1, depth + 1, false, concat(acc, c)).
    If c is equal to encBraceR ():
        Return jsonSplitTop(s, i + 1, depth - 1, false, concat(acc, c)).
    If c is equal to encBrkR ():
        Return jsonSplitTop(s, i + 1, depth - 1, false, concat(acc, c)).
    If c is equal to ",":
        If depth is equal to 0:
            Return jsonSplitTop(s, i + 1, 0, false, concat(acc, chr(10))).
        Return jsonSplitTop(s, i + 1, depth, false, concat(acc, c)).
    Return jsonSplitTop(s, i + 1, depth, false, concat(acc, c)).

# JSON permits insignificant whitespace between tokens; in the encoded content that
# is encSpace/encNewline. encTrim strips it from a value's ends (whitespace INSIDE a
# string is significant and lies between the encQuote delimiters, so it is untouched).
## To encTrimHead (s: Text, i: Int) -> Int:
    If i is greater than length of s:
        Return i.
    Let c be item i of s.
    If c is equal to encSpace ():
        Return encTrimHead(s, i + 1).
    If c is equal to encNewline ():
        Return encTrimHead(s, i + 1).
    Return i.

## To encTrimTail (s: Text, i: Int) -> Int:
    If i is less than 1:
        Return 0.
    Let c be item i of s.
    If c is equal to encSpace ():
        Return encTrimTail(s, i - 1).
    If c is equal to encNewline ():
        Return encTrimTail(s, i - 1).
    Return i.

## To encTrim (s: Text) -> Text:
    Return strSliceLoop(s, encTrimHead(s, 1), encTrimTail(s, length of s), "").

## To jsonBuildObj (entries: Seq of Text, i: Int, acc: Text) -> Text:
    If i is greater than length of entries:
        Return concat(concat(tagObj (), acc), tagObjEnd ()).
    Let entry be item i of entries.
    Let keyRaw be encTrim(substringBefore(entry, ":")).
    Let k be strSliceLoop(keyRaw, 2, (length of keyRaw) - 1, "").
    Let val be jsonParse(substringAfter(entry, ":")).
    Let pair be concat(concat(k, tagObjKV ()), val).
    If i is equal to 1:
        Return jsonBuildObj(entries, i + 1, pair).
    Return jsonBuildObj(entries, i + 1, concat(concat(acc, tagObjSep ()), pair)).

## To jsonBuildArr (elems: Seq of Text, i: Int, acc: Text) -> Text:
    If i is greater than length of elems:
        Return concat(concat(tagArr (), acc), tagArrEnd ()).
    Let val be jsonParse(item i of elems).
    If i is equal to 1:
        Return jsonBuildArr(elems, i + 1, val).
    Return jsonBuildArr(elems, i + 1, concat(concat(acc, tagArrSep ()), val)).

## To jsonParse (v: Text) -> Text:
    Let t be encTrim(v).
    If startsWith(t, encBraceL ()):
        Let innerO be encTrim(strSliceLoop(t, 2, (length of t) - 1, "")).
        If innerO is equal to "":
            Return concat(tagObj (), tagObjEnd ()).
        Return jsonBuildObj(split(jsonSplitTop(innerO, 1, 0, false, ""), chr(10)), 1, "").
    If startsWith(t, encBrkL ()):
        Let innerA be encTrim(strSliceLoop(t, 2, (length of t) - 1, "")).
        If innerA is equal to "":
            Return concat(tagArr (), tagArrEnd ()).
        Return jsonBuildArr(split(jsonSplitTop(innerA, 1, 0, false, ""), chr(10)), 1, "").
    If startsWith(t, encQuote ()):
        Return concat(tagStr (), strSliceLoop(t, 2, (length of t) - 1, "")).
    Return t.

## To joinObjSep (entries: Seq of Text, i: Int, upto: Int, acc: Text) -> Text:
    If i is greater than upto:
        Return acc.
    If i is equal to 1:
        Let f be item 1 of entries.
        Return joinObjSep(entries, 2, upto, f).
    Let e be item i of entries.
    Return joinObjSep(entries, i + 1, upto, concat(concat(acc, tagObjSep ()), e)).

# JS objects dedupe by key: a repeated key (from a duplicate literal entry or a
# {...spread, override}) keeps its FIRST position but its LAST value. dedupObj
# applies that once an object is built, so access, iteration, and serialization all
# agree. (Re-splits a fresh Seq per step to avoid the Seq-parameter codegen bug.)
## To keyMember (seen: Text, key: Text) -> Bool:
    Return split(seen, chr(10)) contains key.

## To dedupEmit (allStr: Text, i: Int, seen: Text, acc: Text) -> Text:
    If i is greater than length of split(allStr, chr(10)):
        Return acc.
    Let key be substringBefore(item i of split(allStr, chr(10)), tagObjKV ()).
    If keyMember(seen, key):
        Return dedupEmit(allStr, i + 1, seen, acc).
    Let pair be concat(concat(key, tagObjKV ()), objScanLast(split(allStr, chr(10)), 1, key, "undefined")).
    If acc is equal to "":
        Return dedupEmit(allStr, i + 1, concat(concat(seen, chr(10)), key), pair).
    Return dedupEmit(allStr, i + 1, concat(concat(seen, chr(10)), key), concat(concat(acc, tagObjSep ()), pair)).

## To dedupObj (objval: Text) -> Text:
    Let inner be substringAfter(objval, tagObj ()).
    Let content be strSliceLoop(inner, 1, (length of inner) - 1, "").
    If content is equal to "":
        Return objval.
    Return concat(concat(tagObj (), dedupEmit(splitObjEntriesDepth(content, 1, 0, ""), 1, "", "")), tagObjEnd ()).

## To buildObj (entries: Seq of Text, i: Int, acc: Text) -> Text:
    If i is greater than length of entries:
        Return dedupObj(concat(concat(tagObj (), acc), tagObjEnd ())).
    Let entry be trim(item i of entries).
    If startsWith(entry, "..."):
        Let sE be objEntrySeq(evalResolved(trim(substringAfter(entry, "...")))).
        If length of sE is less than 1:
            Return buildObj(entries, i + 1, acc).
        Let sJoined be joinObjSep(sE, 1, length of sE, "").
        If acc is equal to "":
            Return buildObj(entries, i + 1, sJoined).
        Return buildObj(entries, i + 1, concat(concat(acc, tagObjSep ()), sJoined)).
    Let k be materialize(litToStr(trim(substringBefore(entry, " : ")))).
    Let v be evalResolved(trim(substringAfter(entry, " : "))).
    Let pair be concat(concat(k, tagObjKV ()), v).
    If acc is equal to "":
        Return buildObj(entries, i + 1, pair).
    Return buildObj(entries, i + 1, concat(concat(acc, tagObjSep ()), pair)).

## To splitObjEntries (s: Text, i: Int, depth: Int, acc: Text) -> Text:
    If i is greater than length of s:
        Return acc.
    Let c be item i of s.
    If c is equal to chr(91):
        Return splitObjEntries(s, i + 1, depth + 1, concat(acc, c)).
    If c is equal to chr(123):
        Return splitObjEntries(s, i + 1, depth + 1, concat(acc, c)).
    If c is equal to chr(93):
        Return splitObjEntries(s, i + 1, depth - 1, concat(acc, c)).
    If c is equal to chr(125):
        Return splitObjEntries(s, i + 1, depth - 1, concat(acc, c)).
    If c is equal to ",":
        If depth is equal to 0:
            Return splitObjEntries(s, i + 1, 0, concat(acc, chr(10))).
        Return splitObjEntries(s, i + 1, depth, concat(acc, c)).
    Return splitObjEntries(s, i + 1, depth, concat(acc, c)).

## To resolveObjects (expr: Text) -> Text:
    If substringBefore(expr, chr(123)) is equal to expr:
        Return expr.
    Let leftOfClose be substringBefore(expr, chr(125)).
    Let rest be substringAfter(expr, chr(125)).
    Let pieces be split(leftOfClose, chr(123)).
    Let np be length of pieces.
    Let inner be trim(item np of pieces).
    Let prefix be joinUpto(pieces, 1, np - 1, chr(123), "").
    If inner is equal to "":
        Return resolveObjects(trim(concat(concat(prefix, concat(tagObj (), tagObjEnd ())), rest))).
    Return resolveObjects(trim(concat(concat(prefix, buildObj(split(splitObjEntries(inner, 1, 0, ""), chr(10)), 1, "")), rest))).

## To dotSep () -> Text:
    Return concat(concat(" ", chr(46)), " ").

## To resolveObjDot (expr: Text) -> Text:
    If substringBefore(expr, dotSep()) is equal to expr:
        Return expr.
    Let lhs be substringBefore(expr, dotSep()).
    Let tail be substringAfter(expr, dotSep()).
    Let tailToks be split(tail, " ").
    Let lhsToks be split(lhs, " ").
    Let recv be item (length of lhsToks) of lhsToks.
    If startsWith(recv, tagObj ()):
        Let val be objGet(recv, item 1 of tailToks).
        Let newPrefix be joinRange(lhsToks, 1, (length of lhsToks) - 1, "").
        Let restToks be joinRange(tailToks, 2, length of tailToks, "").
        Return resolveObjDot(trim(concat(concat(concat(newPrefix, " "), val), restToks))).
    Return expr.

## To propLength (v: Text) -> Int:
    If startsWith(v, tagArr ()):
        Return length of arrElements(v).
    Return length of materialize(litToStr(v)).

## To resolveProps (expr: Text) -> Text:
    If substringBefore(expr, " . length") is equal to expr:
        Return expr.
    Let lhs be substringBefore(expr, " . length").
    Let tail be substringAfter(expr, " . length").
    Let lhsToks be split(lhs, " ").
    Let recv be item (length of lhsToks) of lhsToks.
    Let n be propLength(recv).
    Let newPrefix be joinRange(lhsToks, 1, (length of lhsToks) - 1, "").
    Return resolveProps(trim(concat(concat(concat(newPrefix, " "), toText(n)), tail))).

## To litToStr (tok: Text) -> Text:
    If startsWith(tok, chr(34)):
        Let content be item 1 of split(substringAfter(tok, chr(34)), chr(34)).
        Return concat(tagStr (), content).
    Return tok.

## To concatTerms (terms: Seq of Text, i: Int, acc: Text) -> Text:
    If i is greater than length of terms:
        Return acc.
    Let t be trim(item i of terms).
    Let lit be litToStr(t).
    If startsWith(lit, tagStr ()):
        Return concatTerms(terms, i + 1, concat(acc, materialize(lit))).
    Return concatTerms(terms, i + 1, concat(acc, materialize(evalValue(t)))).

## To evalValue (expr: Text) -> Text:
    If startsWith(trim(expr), chr(1)):
        Return trim(expr).
    If startsWith(trim(expr), tagArr ()):
        Return trim(expr).
    If startsWith(trim(expr), tagObj ()):
        Return trim(expr).
    If trim(expr) is equal to "true":
        Return "true".
    If trim(expr) is equal to "false":
        Return "false".
    If trim(expr) is equal to "null":
        Return "null".
    If trim(expr) is equal to "undefined":
        Return "undefined".
    If hasStr(expr):
        Return concat(tagStr (), concatTerms(split(expr, " + "), 1, "")).
    Return toText(evalParens(expr)).

## To typeOfTag (tok: Text) -> Text:
    If startsWith(tok, chr(1)):
        Return concat(tagStr (), "function").
    Let v be evalValue(litToStr(tok)).
    If startsWith(v, tagStr ()):
        Return concat(tagStr (), "string").
    If startsWith(v, tagArr ()):
        Return concat(tagStr (), "object").
    If startsWith(v, tagObj ()):
        Return concat(tagStr (), "object").
    If v is equal to "true":
        Return concat(tagStr (), "boolean").
    If v is equal to "false":
        Return concat(tagStr (), "boolean").
    If v is equal to "null":
        Return concat(tagStr (), "object").
    If v is equal to "undefined":
        Return concat(tagStr (), "undefined").
    Return concat(tagStr (), "number").

## To resolveTypeof (expr: Text) -> Text:
    If substringBefore(expr, "typeof ") is equal to expr:
        Return expr.
    Let before be substringBefore(expr, "typeof ").
    Let after be substringAfter(expr, "typeof ").
    Let atoks be split(after, " ").
    Let tok be item 1 of atoks.
    Let restToks be joinRange(atoks, 2, length of atoks, "").
    Return resolveTypeof(trim(concat(concat(before, typeOfTag(tok)), restToks))).

## To cmpVals (a: Text, b: Text) -> Int:
    If startsWith(a, tagStr ()):
        Return compareText(materialize(a), materialize(b)).
    If startsWith(b, tagStr ()):
        Return compareText(materialize(a), materialize(b)).
    Return orderingToInt(cmpInt(parseInt(a), parseInt(b))).

## To maxInt (a: Int, b: Int) -> Int:
    If a is greater than b:
        Return a.
    Return b.

## To absInt (a: Int) -> Int:
    If a is less than 0:
        Return 0 - a.
    Return a.

## To powInt (a: Int, b: Int, acc: Int) -> Int:
    If b is less than or equal to 0:
        Return acc.
    Return powInt(a, b - 1, acc * a).

## To signInt (a: Int) -> Int:
    If a is greater than 0:
        Return 1.
    If a is less than 0:
        Return 0 - 1.
    Return 0.

## To strCharAt (s: Text, i: Int) -> Text:
    If i is less than 0:
        Return tagStr ().
    If i + 1 is greater than length of s:
        Return tagStr ().
    Return concat(tagStr (), item (i + 1) of s).

## To strIndexOf (s: Text, sub: Text) -> Int:
    Let bef be substringBefore(s, sub).
    If bef is equal to s:
        Return -1.
    Return length of bef.

## To arrIndexOfLoop (els: Seq of Text, i: Int, target: Text) -> Int:
    If i is greater than length of els:
        Return -1.
    Let el be item i of els.
    If el is equal to target:
        Return i - 1.
    Return arrIndexOfLoop(els, i + 1, target).

## To arrIndexOf (arrval: Text, target: Text) -> Int:
    Return arrIndexOfLoop(arrElements(arrval), 1, target).

## To idxOf (raw: Text, subEval: Text) -> Int:
    If startsWith(raw, tagArr ()):
        Return arrIndexOf(raw, subEval).
    Return strIndexOf(materialize(raw), materialize(subEval)).

## To arrSliceLoop (els: Seq of Text, i: Int, endEx: Int, acc: Text) -> Text:
    If i is greater than endEx:
        Return acc.
    If i is greater than length of els:
        Return acc.
    Let el be item i of els.
    If acc is equal to "":
        Return arrSliceLoop(els, i + 1, endEx, el).
    Let nextAcc be concat(concat(acc, tagArrSep ()), el).
    Return arrSliceLoop(els, i + 1, endEx, nextAcc).

## To arrSlice (arrval: Text, a: Int, b: Int) -> Text:
    Return concat(concat(tagArr (), arrSliceLoop(arrElements(arrval), a + 1, b, "")), tagArrEnd ()).

## To sliceOf (raw: Text, a: Int, b: Int) -> Text:
    If startsWith(raw, tagArr ()):
        Return arrSlice(raw, a, b).
    Return strSlice(materialize(raw), a, b).

## To arrReverseLoop (els: Seq of Text, i: Int, acc: Text) -> Text:
    If i is less than 1:
        Return acc.
    Let el be item i of els.
    If acc is equal to "":
        Return arrReverseLoop(els, i - 1, el).
    Let nextAcc be concat(concat(acc, tagArrSep ()), el).
    Return arrReverseLoop(els, i - 1, nextAcc).

## To arrReverse (arrval: Text) -> Text:
    Let els be arrElements(arrval).
    Let n be length of els.
    Return concat(concat(tagArr (), arrReverseLoop(els, n, "")), tagArrEnd ()).

## To arrMapLoop (els: Seq of Text, i: Int, fnval: Text, env: Text, acc: Text) -> Text:
    If i is greater than length of els:
        Return acc.
    Let el be item i of els.
    Let r be callFn(concat(fnval, ""), el, concat(env, "")).
    If i is equal to 1:
        Return arrMapLoop(els, i + 1, fnval, env, r).
    Let nextAcc be concat(concat(acc, tagArrSep ()), r).
    Return arrMapLoop(els, i + 1, fnval, env, nextAcc).

## To arrMap (arrval: Text, fnval: Text, env: Text) -> Text:
    Return concat(concat(tagArr (), arrMapLoop(arrElements(arrval), 1, fnval, env, "")), tagArrEnd ()).

## To arrReduceLoop (els: Seq of Text, i: Int, fnval: Text, env: Text, acc: Text) -> Text:
    If i is greater than length of els:
        Return acc.
    Let el be item i of els.
    Let nextAcc be callFn2(concat(fnval, ""), concat(acc, ""), concat(el, ""), concat(env, "")).
    Return arrReduceLoop(els, i + 1, fnval, env, nextAcc).

## To arrReduce (arrval: Text, fnval: Text, init: Text, env: Text) -> Text:
    Return arrReduceLoop(arrElements(arrval), 1, fnval, env, init).

## To joinChr6 (els: Seq of Text, i: Int, upto: Int, acc: Text) -> Text:
    If i is greater than upto:
        Return acc.
    If i is equal to 1:
        Let f be item 1 of els.
        Return joinChr6(els, 2, upto, f).
    Let e be item i of els.
    Return joinChr6(els, i + 1, upto, concat(concat(acc, tagArrSep ()), e)).

## To arrPush (arrval: Text, val: Text) -> Text:
    Let els be arrElements(arrval).
    If length of els is less than 1:
        Return concat(concat(tagArr (), val), tagArrEnd ()).
    Return concat(concat(tagArr (), concat(concat(joinChr6(els, 1, length of els, ""), tagArrSep ()), val)), tagArrEnd ()).

## To arrPop (arrval: Text) -> Text:
    Let els be arrElements(arrval).
    If length of els is less than 1:
        Return arrval.
    Return concat(concat(tagArr (), joinChr6(els, 1, (length of els) - 1, "")), tagArrEnd ()).

## To arrConcat (a: Text, b: Text) -> Text:
    Let ea be arrElements(a).
    Let eb be arrElements(b).
    Let na be length of ea.
    Let nb be length of eb.
    If na is less than 1:
        Return concat(concat(tagArr (), joinChr6(eb, 1, nb, "")), tagArrEnd ()).
    If nb is less than 1:
        Return concat(concat(tagArr (), joinChr6(ea, 1, na, "")), tagArrEnd ()).
    Return concat(concat(tagArr (), concat(concat(joinChr6(ea, 1, na, ""), tagArrSep ()), joinChr6(eb, 1, nb, ""))), tagArrEnd ()).

## To concatOf (a: Text, b: Text) -> Text:
    If startsWith(a, tagArr ()):
        Return arrConcat(a, b).
    Return concat(tagStr (), concat(materialize(a), materialize(b))).

## To arrAt (arrval: Text, i: Int) -> Text:
    Let els be arrElements(arrval).
    Let nEls be length of els.
    If i is less than 0:
        If nEls + i is less than 0:
            Return "undefined".
        Return item (nEls + i + 1) of els.
    If i is greater than nEls - 1:
        Return "undefined".
    Return item (i + 1) of els.

## To strAt (s: Text, i: Int) -> Text:
    Let n be length of s.
    If i is less than 0:
        If n + i is less than 0:
            Return "undefined".
        Return concat(tagStr (), item (n + i + 1) of s).
    If i is greater than n - 1:
        Return "undefined".
    Return concat(tagStr (), item (i + 1) of s).

## To atOf (raw: Text, i: Int) -> Text:
    If startsWith(raw, tagArr ()):
        Return arrAt(raw, i).
    Return strAt(materialize(raw), i).

## To arrFlatLoop (els: Seq of Text, i: Int, acc: Text) -> Text:
    If i is greater than length of els:
        Return acc.
    Let el be item i of els.
    If startsWith(el, tagArr ()):
        Let subEls be arrElements(el).
        If length of subEls is less than 1:
            Return arrFlatLoop(els, i + 1, acc).
        Let sub be joinChr6(subEls, 1, length of subEls, "").
        If acc is equal to "":
            Return arrFlatLoop(els, i + 1, sub).
        Return arrFlatLoop(els, i + 1, concat(concat(acc, tagArrSep ()), sub)).
    If acc is equal to "":
        Return arrFlatLoop(els, i + 1, el).
    Return arrFlatLoop(els, i + 1, concat(concat(acc, tagArrSep ()), el)).

## To arrFlat (arrval: Text) -> Text:
    Return concat(concat(tagArr (), arrFlatLoop(arrElements(arrval), 1, "")), tagArrEnd ()).

## To balancedArg (s: Text, i: Int, depth: Int, acc: Text) -> Text:
    If i is greater than length of s:
        Return acc.
    Let c be item i of s.
    If c is equal to "(":
        Return balancedArg(s, i + 1, depth + 1, concat(acc, c)).
    If c is equal to ")":
        If depth is equal to 0:
            Return acc.
        Return balancedArg(s, i + 1, depth - 1, concat(acc, c)).
    Return balancedArg(s, i + 1, depth, concat(acc, c)).

## To methodArg (aft: Text) -> Text:
    Return balancedArg(aft, 1, 0, "").

## To methodRest (aft: Text) -> Text:
    Return strSliceLoop(aft, (length of balancedArg(aft, 1, 0, "")) + 2, length of aft, "").

## To topCommaIdx (s: Text, i: Int, depth: Int, g: Text) -> Int:
    If i is greater than length of s:
        Return 0.
    Let c be item i of s.
    If c is equal to "(":
        Return topCommaIdx(s, i + 1, depth + 1, concat(g, c)).
    If c is equal to ")":
        Return topCommaIdx(s, i + 1, depth - 1, concat(g, c)).
    If c is equal to ",":
        If depth is equal to 0:
            Return i.
    Return topCommaIdx(s, i + 1, depth, concat(g, c)).

## To splitArgs2 (argStr: Text) -> Seq of Text:
    Let idx be topCommaIdx(argStr, 1, 0, "").
    If idx is equal to 0:
        Return [argStr, ""].
    Return [strSliceLoop(argStr, 1, idx - 1, ""), strSliceLoop(argStr, idx + 1, length of argStr, "")].

## To commaDepthSplit (s: Text, i: Int, depth: Int, g: Text) -> Text:
    If i is greater than length of s:
        Return g.
    Let c be item i of s.
    If c is equal to "(":
        Return commaDepthSplit(s, i + 1, depth + 1, concat(g, c)).
    If c is equal to ")":
        Return commaDepthSplit(s, i + 1, depth - 1, concat(g, c)).
    If c is equal to ",":
        If depth is equal to 0:
            Return commaDepthSplit(s, i + 1, 0, concat(g, chr(10))).
        Return commaDepthSplit(s, i + 1, depth, concat(g, c)).
    Return commaDepthSplit(s, i + 1, depth, concat(g, c)).

## To splitArgsN (argStr: Text) -> Seq of Text:
    Return split(commaDepthSplit(argStr, 1, 0, ""), chr(10)).

## To fnArgVal (s: Text, env: Text) -> Text:
    If startsWith(s, "function ("):
        Return funcValueOf(substitute(s, env)).
    Return jsEvalIn(s, env).

## To arrFilterLoop (els: Seq of Text, i: Int, fnval: Text, env: Text, acc: Text) -> Text:
    If i is greater than length of els:
        Return acc.
    Let el be item i of els.
    Let keep be boolOf(callFn(concat(fnval, ""), concat(el, ""), concat(env, ""))).
    If keep:
        If acc is equal to "":
            Return arrFilterLoop(els, i + 1, fnval, env, el).
        Let nextAcc be concat(concat(acc, tagArrSep ()), el).
        Return arrFilterLoop(els, i + 1, fnval, env, nextAcc).
    Return arrFilterLoop(els, i + 1, fnval, env, acc).

## To arrFilter (arrval: Text, fnval: Text, env: Text) -> Text:
    Return concat(concat(tagArr (), arrFilterLoop(arrElements(arrval), 1, fnval, env, "")), tagArrEnd ()).

## To arrSomeLoop (els: Seq of Text, i: Int, fnval: Text, env: Text) -> Bool:
    If i is greater than length of els:
        Return false.
    Let el be item i of els.
    If boolOf(callFn(concat(fnval, ""), concat(el, ""), concat(env, ""))):
        Return true.
    Return arrSomeLoop(els, i + 1, fnval, env).

## To arrSome (arrval: Text, fnval: Text, env: Text) -> Bool:
    Return arrSomeLoop(arrElements(arrval), 1, fnval, env).

## To arrEveryLoop (els: Seq of Text, i: Int, fnval: Text, env: Text) -> Bool:
    If i is greater than length of els:
        Return true.
    Let el be item i of els.
    If boolOf(callFn(concat(fnval, ""), concat(el, ""), concat(env, ""))):
        Return arrEveryLoop(els, i + 1, fnval, env).
    Return false.

## To arrEvery (arrval: Text, fnval: Text, env: Text) -> Bool:
    Return arrEveryLoop(arrElements(arrval), 1, fnval, env).

## To arrFindLoop (els: Seq of Text, i: Int, fnval: Text, env: Text) -> Text:
    If i is greater than length of els:
        Return "undefined".
    Let el be item i of els.
    If boolOf(callFn(concat(fnval, ""), concat(el, ""), concat(env, ""))):
        Return el.
    Return arrFindLoop(els, i + 1, fnval, env).

## To arrFind (arrval: Text, fnval: Text, env: Text) -> Text:
    Return arrFindLoop(arrElements(arrval), 1, fnval, env).

## To strSliceLoop (s: Text, i: Int, endEx: Int, acc: Text) -> Text:
    If i is greater than endEx:
        Return acc.
    If i is greater than length of s:
        Return acc.
    Let c be item i of s.
    Return strSliceLoop(s, i + 1, endEx, concat(acc, c)).

## To strSlice (s: Text, a: Int, b: Int) -> Text:
    Return concat(tagStr (), strSliceLoop(s, a + 1, b, "")).

## To strRepeat (s: Text, n: Int, acc: Text) -> Text:
    If n is less than or equal to 0:
        Return acc.
    Let acc2 be concat(acc, s).
    Return strRepeat(s, n - 1, acc2).

## To strEndsWith (s: Text, sub: Text) -> Bool:
    Let ls be length of s.
    Let lsub be length of sub.
    If lsub is greater than ls:
        Return false.
    Return strSliceLoop(s, ls - lsub + 1, ls, "") is equal to sub.

## To trimHeadIdx (s: Text, i: Int) -> Int:
    If i is greater than length of s:
        Return i.
    Let c be item i of s.
    If c is equal to encSpace ():
        Return trimHeadIdx(s, i + 1).
    Return i.

## To trimTailIdx (s: Text, i: Int) -> Int:
    If i is less than 1:
        Return 0.
    Let c be item i of s.
    If c is equal to encSpace ():
        Return trimTailIdx(s, i - 1).
    Return i.

## To strTrim (s: Text) -> Text:
    Let a be trimHeadIdx(s, 1).
    Let b be trimTailIdx(s, length of s).
    Return strSliceLoop(s, a, b, "").

## To strSubstring (s: Text, a: Int, b: Int) -> Text:
    If a is greater than b:
        Return strSlice(s, b, a).
    Return strSlice(s, a, b).

## To strPadStart (s: Text, target: Int, pad: Text) -> Text:
    If length of s is greater than or equal to target:
        Return concat(tagStr (), s).
    If pad is equal to "":
        Return concat(tagStr (), s).
    Let need be target - (length of s).
    Let padding be strSliceLoop(strRepeat(pad, need, ""), 1, need, "").
    Return concat(tagStr (), concat(padding, s)).

## To strPadEnd (s: Text, target: Int, pad: Text) -> Text:
    If length of s is greater than or equal to target:
        Return concat(tagStr (), s).
    If pad is equal to "":
        Return concat(tagStr (), s).
    Let need be target - (length of s).
    Let padding be strSliceLoop(strRepeat(pad, need, ""), 1, need, "").
    Return concat(tagStr (), concat(s, padding)).

## To strCharCodeAt (s: Text, i: Int) -> Int:
    If i + 1 is greater than length of s:
        Return 0.
    Let c be item (i + 1) of s.
    If c is equal to encSpace ():
        Return 32.
    Return ord(c).

## To fromCharCodeLoop (codes: Seq of Text, i: Int, env: Text, acc: Text) -> Text:
    If i is greater than length of codes:
        Return concat(tagStr (), acc).
    Let code be parseInt(jsEvalIn(trim(item i of codes), env)).
    If code is equal to 32:
        Return fromCharCodeLoop(codes, i + 1, env, concat(acc, encSpace ())).
    Return fromCharCodeLoop(codes, i + 1, env, concat(acc, chr(code))).

## To splitToArr (pieces: Seq of Text, i: Int, acc: Text) -> Text:
    If i is greater than length of pieces:
        Return acc.
    Let piece be concat(tagStr (), item i of pieces).
    If i is equal to 1:
        Return splitToArr(pieces, i + 1, piece).
    Return splitToArr(pieces, i + 1, concat(concat(acc, tagArrSep ()), piece)).

## To strSplit (s: Text, sep: Text) -> Text:
    Return concat(concat(tagArr (), splitToArr(split(s, sep), 1, "")), tagArrEnd ()).

## To arrJoinLoop (els: Seq of Text, i: Int, sep: Text, acc: Text) -> Text:
    If i is greater than length of els:
        Return acc.
    Let m be materialize(item i of els).
    If i is equal to 1:
        Return arrJoinLoop(els, i + 1, sep, m).
    Let nextAcc be concat(concat(acc, sep), m).
    Return arrJoinLoop(els, i + 1, sep, nextAcc).

## To arrJoin (arrval: Text, sep: Text) -> Text:
    Return concat(tagStr (), arrJoinLoop(arrElements(arrval), 1, sep, "")).

## To strReplace (s: Text, a: Text, b: Text) -> Text:
    Let bef be substringBefore(s, a).
    If bef is equal to s:
        Return concat(tagStr (), s).
    Let tail be substringAfter(s, a).
    Return concat(tagStr (), concat(concat(bef, b), tail)).

## To strUpperLoop (s: Text, i: Int, acc: Text) -> Text:
    If i is greater than length of s:
        Return acc.
    Let c be item i of s.
    Let o be ord(c).
    If o is greater than or equal to 97:
        If o is less than or equal to 122:
            Return strUpperLoop(s, i + 1, concat(acc, chr(o - 32))).
    Return strUpperLoop(s, i + 1, concat(acc, c)).

## To strLowerLoop (s: Text, i: Int, acc: Text) -> Text:
    If i is greater than length of s:
        Return acc.
    Let c be item i of s.
    Let o be ord(c).
    If o is greater than or equal to 65:
        If o is less than or equal to 90:
            Return strLowerLoop(s, i + 1, concat(acc, chr(o + 32))).
    Return strLowerLoop(s, i + 1, concat(acc, c)).

## To mpos (expr: Text, marker: Text) -> Int:
    If substringBefore(expr, marker) is equal to expr:
        Return 1000000.
    Return length of substringBefore(expr, marker).

## To betterMarker (expr: Text, a: Text, b: Text) -> Text:
    If mpos(concat(expr, ""), concat(a, "")) is less than or equal to mpos(concat(expr, ""), concat(b, "")):
        Return a.
    Return b.

## To leftmostMethod (expr: Text) -> Text:
