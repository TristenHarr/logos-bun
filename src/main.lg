        Let recv be recvExpr(concat(bef, "")).
        Let prefix be recvPrefix(concat(bef, "")).
        Let raw be jsEvalIn(recv, env).
        If trim(concat(argStr, "")) is equal to "":
            Return resolveMethods(trim(concat(concat(concat(prefix, " "), toSortedArr(raw, "default", "", env)), rst)), env).
        Let fnval be fnArgValRaw(trim(argStr), env).
        Return resolveMethods(trim(concat(concat(concat(prefix, " "), toSortedArr(raw, "cmp", fnval, env)), rst)), env).
    If lm is equal to " . toReversed (":
