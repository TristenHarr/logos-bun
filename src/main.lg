        Return resolveMethods(trim(concat(concat(concat(prefix, " "), toText(strLastIndexOf(sval, materialize(jsEvalIn(trim(methodArg(aft)), env))))), rst)), env).
    If lm is equal to " . split (":
        Let bef be substringBefore(expr, " . split (").
        Let aft be substringAfter(expr, " . split (").
        Let rst be methodRest(aft).
        Let recv be recvExpr(concat(bef, "")).
        Let prefix be recvPrefix(concat(bef, "")).
        Let sval be materialize(jsEvalIn(recv, env)).
        Let sargs be splitArgsN(methodArg(aft)).
        Let sepraw be jsEvalIn(trim(item 1 of sargs), env).
        If isRegex(sepraw):
            Return resolveMethods(trim(concat(concat(concat(prefix, " "), splitLimit(reSplit(decodeStr(materialize(objGet(concat(sepraw, ""), "__regex_src"))), decodeStr(concat(sval, ""))), sargs, env)), rst)), env).
        Return resolveMethods(trim(concat(concat(concat(prefix, " "), splitLimit(strSplit(sval, materialize(sepraw)), sargs, env)), rst)), env).
    If lm is equal to " . join (":
        Let bef be substringBefore(expr, " . join (").
        Let aft be substringAfter(expr, " . join (").
        Let rst be methodRest(aft).
