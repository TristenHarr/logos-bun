        Return resolveMethods(trim(concat(concat(concat(prefix, " "), cmpResult(startsWith(sval, subv))), rst)), env).
    If lm is equal to " . localeCompare (":
        Let bef be substringBefore(expr, " . localeCompare (").
        Let aft be substringAfter(expr, " . localeCompare (").
        Let rst be methodRest(aft).
        Let recv be recvExpr(concat(bef, "")).
        Let prefix be recvPrefix(concat(bef, "")).
        Let sa be jsEvalIn(recv, env).
        Let sb be jsEvalIn(trim(methodArg(aft)), env).
        Return resolveMethods(trim(concat(concat(concat(prefix, " "), toText(signInt(cmpVals(sa, sb)))), rst)), env).
    If lm is equal to " . endsWith (":
        Let bef be substringBefore(expr, " . endsWith (").
        Let aft be substringAfter(expr, " . endsWith (").
        Let rst be methodRest(aft).
        Let recv be recvExpr(concat(bef, "")).
        Let prefix be recvPrefix(concat(bef, "")).
        Let sval be materialize(jsEvalIn(recv, env)).
        Let subv be materialize(jsEvalIn(trim(methodArg(aft)), env)).
        Return resolveMethods(trim(concat(concat(concat(prefix, " "), cmpResult(strEndsWith(sval, subv))), rst)), env).
    If lm is equal to " . repeat (":
        Let bef be substringBefore(expr, " . repeat (").
        Let aft be substringAfter(expr, " . repeat (").
        Let rst be methodRest(aft).
        Let recv be recvExpr(concat(bef, "")).
        Let prefix be recvPrefix(concat(bef, "")).
