            Return resolveMethods(trim(concat(concat(concat(recvPrefix(concat(mbef, "")), " "), newArr(concat(concat(tagArr (), concat(tagStr (), mfound)), tagArrEnd ()))), methodRest(maft))), env).
    If substringBefore(expr, "new Promise (") is not equal to expr:
        Let bef be substringBefore(expr, "new Promise (").
